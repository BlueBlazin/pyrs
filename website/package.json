{
  "name": "website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:playground": "pnpm run wasm:build && astro dev",
    "build": "node scripts/clean-dist.mjs && astro build",
    "build:playground": "pnpm run wasm:build && pnpm run build",
    "wasm:build": "../scripts/build_wasm_website_bundle.sh",
    "check:links": "node scripts/check-internal-links.mjs",
    "check:release": "node scripts/check-release-artifacts.mjs",
    "report:size": "node scripts/report-build-size.mjs",
    "build:check": "pnpm run build && pnpm run check:links && pnpm run check:release",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/tailwind": "^6.0.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^5.17.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  }
}
