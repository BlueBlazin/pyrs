---
interface Props {
	context?: "home" | "docs" | "playground";
}

const { context = "home" } = Astro.props;
const intrinsicLogoSize = 68;
const withBase = (path = "") => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
const navLinks =
	context === "home"
		? [
				{ label: "Docs", href: withBase("docs/") },
				{ label: "Playground", href: withBase("playground/") },
				{ label: "GitHub", href: "https://github.com/BlueBlazin/pyrs" },
			]
		: context === "docs"
			? [
					{ label: "Home", href: withBase("") },
					{ label: "Playground", href: withBase("playground/") },
					{ label: "GitHub", href: "https://github.com/BlueBlazin/pyrs" },
				]
			: [
					{ label: "Home", href: withBase("") },
					{ label: "Docs", href: withBase("docs/") },
					{ label: "GitHub", href: "https://github.com/BlueBlazin/pyrs" },
				];
---

<header class="global-topbar" data-context={context}>
	<a class="global-brand" href={withBase("")}>
		<img
			src={withBase("images/pyrs-logo-nav.webp")}
			srcset={`${withBase("images/pyrs-logo-nav.webp")} 136w, ${withBase("images/pyrs-logo.webp")} 670w`}
			sizes="68px"
			alt="PYRS logo"
			width={136}
			height={136}
		/>
		<span>PYRS</span>
	</a>
	<nav class="global-topnav">
		{
			navLinks.map((link) => (
				<a href={link.href}>{link.label}</a>
			))
		}
	</nav>
</header>

<style>
	.global-topbar {
		--logo-size: 68px;
		--brand-gap: 0.86rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.4rem 0;
	}

	.global-brand {
		display: inline-flex;
		align-items: center;
		gap: var(--brand-gap);
		text-decoration: none;
		color: #f7eee8;
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		transition: gap 180ms ease;
	}

	.global-brand img {
		width: var(--logo-size);
		height: var(--logo-size);
		border-radius: 0.52rem;
		border: 1px solid rgba(255, 255, 255, 0.14);
		box-shadow: 0 0 22px rgba(233, 125, 70, 0.32);
		transition: width 180ms ease, height 180ms ease, box-shadow 180ms ease;
	}

	.global-topbar[data-context="docs"] .global-brand img {
		box-shadow: 0 0 22px rgba(137, 160, 210, 0.32);
	}

	.global-brand:focus-visible {
		outline: 2px solid rgba(255, 186, 137, 0.92);
		outline-offset: 3px;
		border-radius: 0.52rem;
	}

	.global-topnav {
		display: inline-flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.95rem;
	}

	.global-topnav a {
		text-decoration: none;
		font-size: 0.92rem;
		color: #beaa9f;
		transition: color 130ms ease;
	}

	.global-topnav a:hover {
		color: #f7eee8;
	}

	.global-topnav a:focus-visible {
		outline: 2px solid rgba(255, 186, 137, 0.92);
		outline-offset: 2px;
		border-radius: 0.36rem;
	}

	@media (max-width: 760px) {
		.global-topbar {
			--logo-size: 58px;
		}

		.global-topnav {
			gap: 0.6rem 0.9rem;
		}

		.global-topnav a {
			font-size: 0.88rem;
		}
	}
</style>
