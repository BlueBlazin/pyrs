---
interface Props {
	context?: "home" | "docs" | "playground";
}

const { context = "home" } = Astro.props;
const isHome = context === "home";
const intrinsicLogoSize = 68;
const withBase = (path = "") => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
const navLinks =
	context === "home"
		? [
				{ label: "Docs", href: withBase("docs/") },
				{ label: "Playground", href: withBase("playground/") },
				{ label: "GitHub", href: "https://github.com/BlueBlazin/pyrs" },
			]
		: context === "docs"
			? [
					{ label: "Home", href: withBase("") },
					{ label: "Playground", href: withBase("playground/") },
					{ label: "GitHub", href: "https://github.com/BlueBlazin/pyrs" },
				]
			: [
					{ label: "Home", href: withBase("") },
					{ label: "Docs", href: withBase("docs/") },
					{ label: "GitHub", href: "https://github.com/BlueBlazin/pyrs" },
				];
---

<header class="global-topbar" data-context={context}>
	<a class="global-brand" href={withBase("")}>
		<img src={withBase("images/pyrs-logo.png")} alt="PYRS logo" width={intrinsicLogoSize} height={intrinsicLogoSize} />
		<span>PYRS</span>
	</a>
	<nav class="global-topnav">
		{
			navLinks.map((link) => (
				<a href={link.href}>{link.label}</a>
			))
		}
	</nav>
</header>

{
	isHome && (
		<script>
			const header = document.querySelector(".global-topbar[data-context='home']");
			if (header && header instanceof HTMLElement && header.dataset.scrollBound !== "1") {
				header.dataset.scrollBound = "1";
				const maxScroll = 180;
				const update = () => {
					const progress = Math.max(0, Math.min(1, window.scrollY / maxScroll));
					header.style.setProperty("--home-progress", progress.toFixed(3));
				};
				update();
				window.addEventListener("scroll", update, { passive: true });
				window.addEventListener("resize", update);
			}
		</script>
	)
}

<style>
	.global-topbar {
		--home-progress: 0;
		--logo-size: calc(44px + (1 - var(--home-progress)) * 24px);
		--brand-gap: calc(0.68rem + (1 - var(--home-progress)) * 0.18rem);
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.4rem 0;
	}

	.global-topbar[data-context="home"] {
		--home-progress: 0;
	}

	.global-brand {
		display: inline-flex;
		align-items: center;
		gap: var(--brand-gap);
		text-decoration: none;
		color: #f7eee8;
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		transition: gap 180ms ease;
	}

	.global-brand img {
		width: var(--logo-size);
		height: var(--logo-size);
		border-radius: 0.52rem;
		border: 1px solid rgba(255, 255, 255, 0.14);
		transition: width 180ms ease, height 180ms ease, box-shadow 180ms ease;
	}

	.global-topbar[data-context="home"] .global-brand img {
		box-shadow: 0 0 calc((1 - var(--home-progress)) * 18px) rgba(233, 125, 70, 0.26);
	}

	.global-brand:focus-visible {
		outline: 2px solid rgba(255, 186, 137, 0.92);
		outline-offset: 3px;
		border-radius: 0.52rem;
	}

	.global-topnav {
		display: inline-flex;
		gap: 0.95rem;
	}

	.global-topnav a {
		text-decoration: none;
		font-size: 0.92rem;
		color: #beaa9f;
		transition: color 130ms ease;
	}

	.global-topnav a:hover {
		color: #f7eee8;
	}

	.global-topnav a:focus-visible {
		outline: 2px solid rgba(255, 186, 137, 0.92);
		outline-offset: 2px;
		border-radius: 0.36rem;
	}

	@media (max-width: 760px) {
		.global-topbar {
			--logo-size: calc(44px + (1 - var(--home-progress)) * 14px);
		}
	}
</style>
