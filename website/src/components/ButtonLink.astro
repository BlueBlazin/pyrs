---
import { cn } from "../lib/cn";
import { withBasePath } from "../lib/paths";

interface Props {
	href: string;
	variant?: "primary" | "secondary";
	class?: string;
}

const { href, variant = "secondary", class: className } = Astro.props;
const resolvedHref = withBasePath(href);
---

<a href={resolvedHref} class={cn("btn-link", variant, className)}>
	<slot />
</a>

<style>
	.btn-link {
		padding: 0.72rem 1rem;
		border-radius: 0.72rem;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.91rem;
		transition: transform 150ms ease, box-shadow 150ms ease;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.btn-link:hover {
		transform: translateY(-1px);
		box-shadow: 0 8px 18px rgba(0, 0, 0, 0.24);
	}

	.btn-link:focus-visible {
		outline: 2px solid rgba(255, 163, 105, 0.9);
		outline-offset: 2px;
	}

	.btn-link.primary {
		background: linear-gradient(135deg, #df8b5a 0%, #c76638 100%);
		color: #231108;
	}

	.btn-link.secondary {
		color: var(--text);
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.02);
	}
</style>
