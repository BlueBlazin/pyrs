---
type InstallLine = string | { text: string; prompt?: boolean };

interface Props {
	lines: InstallLine[];
}

const { lines } = Astro.props;
const normalized = lines.map((line) =>
	typeof line === "string"
		? { text: line, prompt: true }
		: { text: line.text, prompt: line.prompt ?? true },
);
const copyPayload = normalized.map((line) => line.text).join("\n");
---

<div class="terminal">
	<div class="terminal-bar">
		<div class="terminal-lights" aria-hidden="true">
			<span class="term-light term-light-red"></span>
			<span class="term-light term-light-amber"></span>
			<span class="term-light term-light-green"></span>
		</div>
		<span class="terminal-title">shell</span>
		<button class="copy-control" type="button" data-copy={copyPayload} data-copy-button="1">Copy</button>
	</div>
	<pre class="cmd-box"><code>{
		normalized.map((line) => (
			<span class="cmd-line">
				<span class={line.prompt ? "cmd-prompt" : "cmd-prompt cmd-prompt-empty"} aria-hidden="true">$</span>
				<span class="cmd-text">{line.text}</span>
			</span>
		))
	}</code></pre>
</div>

<style>
	.terminal {
		margin-top: 0.74rem;
		border: 1px solid #322117;
		border-radius: 0.82rem;
		background: #060505;
		box-shadow: 0 12px 24px rgba(0, 0, 0, 0.24);
		overflow: hidden;
	}

	.terminal-bar {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		padding: 0.52rem 0.62rem;
		border-bottom: 1px solid #261912;
		background: linear-gradient(180deg, #130d0a 0%, #0d0907 100%);
	}

	.terminal-lights {
		display: inline-flex;
		gap: 0.28rem;
	}

	.term-light {
		width: 0.53rem;
		height: 0.53rem;
		border-radius: 50%;
		display: inline-block;
	}

	.term-light-red {
		background: #ff6b62;
	}

	.term-light-amber {
		background: #ffbe58;
	}

	.term-light-green {
		background: #34c46a;
	}

	.terminal-title {
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.7rem;
		color: #b69f91;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.cmd-box {
		margin: 0;
		overflow-x: auto;
		overflow-y: hidden;
		padding: 0.84rem 0.92rem 0.88rem;
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.78rem;
		line-height: 1.52;
		color: #ecd9cd;
		background: #070605;
		scrollbar-width: thin;
		scrollbar-color: rgba(186, 142, 112, 0.6) rgba(25, 16, 12, 0.72);
		scrollbar-gutter: stable both-edges;
	}

	.cmd-box code {
		display: block;
		width: max-content;
		min-width: 100%;
	}

	.cmd-line {
		display: flex;
		align-items: flex-start;
		gap: 0.54rem;
	}

	.cmd-line + .cmd-line {
		margin-top: 0;
	}

	.cmd-prompt {
		display: inline-block;
		width: 0.7rem;
		user-select: none;
		color: #dd9463;
		font-weight: 600;
		text-align: center;
		flex: 0 0 0.7rem;
	}

	.cmd-prompt-empty {
		color: transparent;
	}

	.cmd-text {
		color: #ecd9cd;
		white-space: pre;
		flex: 0 0 auto;
	}

	.cmd-box ::selection {
		background: rgba(201, 110, 66, 0.28);
		color: #fff5ef;
	}

	.cmd-box::-webkit-scrollbar {
		height: 0.44rem;
	}

	.cmd-box::-webkit-scrollbar-track {
		background: rgba(25, 16, 12, 0.72);
		border-radius: 999px;
	}

	.cmd-box::-webkit-scrollbar-thumb {
		background: linear-gradient(90deg, rgba(189, 144, 112, 0.68) 0%, rgba(164, 123, 95, 0.68) 100%);
		border: 1px solid rgba(10, 7, 6, 0.92);
		border-radius: 999px;
	}

	.cmd-box::-webkit-scrollbar-thumb:hover {
		background: linear-gradient(90deg, rgba(205, 160, 127, 0.74) 0%, rgba(178, 136, 107, 0.74) 100%);
	}

	.cmd-box::-webkit-scrollbar-corner {
		background: transparent;
	}

	@media (max-width: 760px) {
		.cmd-box {
			padding: 0.8rem 0.82rem 0.84rem;
			font-size: 0.75rem;
			line-height: 1.48;
		}

		.cmd-line {
			gap: 0.44rem;
		}
	}
</style>
