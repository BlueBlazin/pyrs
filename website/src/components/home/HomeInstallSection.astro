---
import InstallMethod from "./InstallMethod.astro";
import {
	cargoInstallGitHubCommands,
	cargoSourceBuildRunCommands,
	dockerNightlyCommands,
	nightlyArchiveLinuxCommands,
	nightlyArchiveMacosTerminalCommands,
	type TerminalLine,
} from "../../config/installCommands";

type InstallMethodData = {
	title: string;
	description: string;
	recommended?: boolean;
	lines: TerminalLine[];
};

const installMethods: Record<"macos" | "linux", InstallMethodData[]> = {
	macos: [
		{
			title: "Cargo install (GitHub)",
			description: "Install pyrs into your cargo bin directory directly from GitHub.",
			recommended: true,
			lines: cargoInstallGitHubCommands,
		},
		{
			title: "Cargo (source build)",
			description: "Build directly from source with Rust stable.",
			lines: cargoSourceBuildRunCommands,
		},
		{
			title: "Docker (nightly container)",
			description: "Run the latest published nightly image from GHCR.",
			lines: dockerNightlyCommands,
		},
		{
			title: "Nightly archive",
			description: "Download the latest MacOS nightly archive for your architecture.",
			lines: nightlyArchiveMacosTerminalCommands,
		},
	],
	linux: [
		{
			title: "Cargo install (GitHub)",
			description: "Install pyrs into your cargo bin directory directly from GitHub.",
			recommended: true,
			lines: cargoInstallGitHubCommands,
		},
		{
			title: "Cargo (source build)",
			description: "Build from source and run the release binary locally.",
			lines: cargoSourceBuildRunCommands,
		},
		{
			title: "Docker (nightly container)",
			description: "Use the nightly container as a fast runtime path.",
			lines: dockerNightlyCommands,
		},
		{
			title: "Nightly archive",
			description: "Fetch the latest Linux nightly binary archive.",
			lines: nightlyArchiveLinuxCommands,
		},
	],
};
---

<section class="install" id="install">
	<div class="install-head">
		<p class="eyebrow">Install</p>
		<h2>Install on MacOS or Linux.</h2>
		<p class="install-lede">Choose your platform, then pick the installation path that matches your workflow.</p>
	</div>

	<div class="install-tabs">
		<input class="install-tab-input" type="radio" name="install-platform" id="install-tab-macos" checked />
		<input class="install-tab-input" type="radio" name="install-platform" id="install-tab-linux" />

		<div class="install-tab-list" role="tablist" aria-label="Installation platform">
			<label class="install-tab-btn" for="install-tab-macos" role="tab" tabindex="0">MacOS</label>
			<label class="install-tab-btn" for="install-tab-linux" role="tab" tabindex="0">Linux</label>
		</div>

		<div class="install-surface">
			<div class="install-panels">
				<div class="install-panel" id="install-panel-macos">
					{
						installMethods.macos.map((method) => (
							<InstallMethod
								title={method.title}
								description={method.description}
								recommended={method.recommended}
								lines={method.lines}
							/>
						))
					}
				</div>

				<div class="install-panel" id="install-panel-linux">
					{
						installMethods.linux.map((method) => (
							<InstallMethod
								title={method.title}
								description={method.description}
								recommended={method.recommended}
								lines={method.lines}
							/>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const tabLabels = document.querySelectorAll(".install-tab-btn[for]");
	for (const label of tabLabels) {
		label.addEventListener("keydown", (event) => {
			if (event.key !== "Enter" && event.key !== " ") {
				return;
			}
			event.preventDefault();
			const forId = label.getAttribute("for");
			if (!forId) {
				return;
			}
			const target = document.getElementById(forId);
			if (target instanceof HTMLInputElement) {
				target.checked = true;
			}
		});
	}
</script>

<style>
	.eyebrow {
		margin: 0 0 0.9rem;
		color: var(--accent-2);
		letter-spacing: 0.09em;
		text-transform: uppercase;
		font-size: 0.78rem;
		font-weight: 600;
	}

	.install {
		margin-top: 0;
	}

	.install-head h2 {
		margin: 0;
		font-size: clamp(1.4rem, 3.1vw, 1.95rem);
		line-height: 1.2;
		letter-spacing: -0.01em;
	}

	.install-lede {
		margin: 0.75rem 0 0;
		color: var(--text-muted);
		font-size: 0.94rem;
		line-height: 1.55;
		max-width: 62ch;
	}

	.install-tabs {
		margin-top: 1.12rem;
	}

	.install-tab-input {
		display: none;
	}

	.install-tab-list {
		display: inline-flex;
		gap: 0.26rem;
		padding: 0.24rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(15, 10, 8, 0.88);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
	}

	.install-tab-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.44rem 0.96rem;
		border-radius: 999px;
		font-size: 0.84rem;
		font-weight: 600;
		color: var(--text-muted);
		border: 1px solid transparent;
		cursor: pointer;
		transition: color 140ms ease, background-color 140ms ease, border-color 140ms ease;
	}

	.install-tab-btn:hover {
		color: #e4c8b8;
	}

	.install-tab-btn:focus-visible {
		outline: 2px solid rgba(255, 186, 137, 0.9);
		outline-offset: 2px;
	}

	#install-tab-macos:checked ~ .install-tab-list label[for="install-tab-macos"],
	#install-tab-linux:checked ~ .install-tab-list label[for="install-tab-linux"] {
		color: #241108;
		background: linear-gradient(135deg, #df9664 0%, #c66a3e 100%);
		border-color: rgba(198, 106, 62, 0.46);
	}

	.install-surface {
		margin-top: 0.92rem;
		border: 1px solid #563628;
		border-radius: 1rem;
		background:
			linear-gradient(180deg, rgba(201, 110, 66, 0.05) 0%, rgba(201, 110, 66, 0.01) 100%),
			rgba(11, 8, 7, 0.93);
		overflow: hidden;
		box-shadow: 0 16px 32px rgba(0, 0, 0, 0.2);
	}

	.install-panels {
		display: grid;
		grid-template-areas: "stack";
	}

	.install-panel {
		grid-area: stack;
		display: flex;
		flex-direction: column;
		gap: 0;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transform: translateY(4px);
		transition: opacity 180ms ease, transform 180ms ease;
	}

	#install-tab-macos:checked ~ .install-surface .install-panels #install-panel-macos,
	#install-tab-linux:checked ~ .install-surface .install-panels #install-panel-linux {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transform: translateY(0);
	}
</style>
