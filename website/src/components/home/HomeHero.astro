---
import ButtonLink from "../ButtonLink.astro";

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
const playgroundHref = withBase("playground/");
---

<section class="hero">
	<div class="hero-copy">
		<p class="hero-eyebrow">Python in Rust</p>
		<h1>CPython 3.14 compatibility, built for real execution.</h1>
		<p class="lede">
			PYRS is a fully AI agent developed Python interpreter in Rust focused on CPython semantic parity,
			C-API closure, and production-grade runtime behavior.
		</p>
		<div class="cta-row">
			<ButtonLink href="https://github.com/BlueBlazin/pyrs" variant="primary">Explore Repo</ButtonLink>
			<ButtonLink href="#install" variant="secondary">Install</ButtonLink>
			<ButtonLink href={playgroundHref} variant="secondary">Try Online</ButtonLink>
		</div>
		<div class="metrics">
			<div class="metric">
				<span>Target</span>
				<strong>CPython 3.14</strong>
			</div>
			<div class="metric">
				<span>Platforms</span>
				<strong>Linux + macOS</strong>
			</div>
			<div class="metric">
				<span>Implementation</span>
				<strong>Rust VM + stdlib parity</strong>
			</div>
		</div>
	</div>
	<div class="hero-visual">
		<div class="shot-stack" role="img" aria-label="PYRS REPL screenshots">
			<img
				class="shot shot-base"
				src={withBase("images/repl/repl1-1x.webp")}
				srcset={`${withBase("images/repl/repl1-1x.webp")} 649w, ${withBase("images/repl/repl1-md.webp")} 960w, ${withBase("images/repl/repl1.webp")} 1298w`}
				sizes="(max-width: 760px) 100vw, 50vw"
				width={1298}
				height={1048}
				alt="PYRS REPL screenshot showing syntax highlighting and dataclass usage"
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
			<img
				class="shot shot-overlay"
				src={withBase("images/repl/repl2-1x.webp")}
				srcset={`${withBase("images/repl/repl2-1x.webp")} 649w, ${withBase("images/repl/repl2-md.webp")} 960w, ${withBase("images/repl/repl2.webp")} 1298w`}
				sizes="(max-width: 760px) 100vw, 50vw"
				width={1298}
				height={1048}
				alt="PYRS REPL screenshot showing refined syntax highlighting and output"
				loading="eager"
				decoding="async"
			/>
		</div>
		<p class="visual-note">Real PYRS REPL captures from local runtime sessions.</p>
	</div>
</section>

<style>
	.hero {
		display: block;
		padding: 1.6rem 0 0;
	}

	.hero-copy {
		max-width: 62rem;
	}

	.hero-eyebrow {
		margin: 0 0 0.9rem;
		color: var(--accent-2);
		letter-spacing: 0.09em;
		text-transform: uppercase;
		font-size: 0.78rem;
		font-weight: 600;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 5.8vw, 3.4rem);
		line-height: 1.04;
		letter-spacing: -0.02em;
	}

	.lede {
		margin: 1.15rem 0 0;
		max-width: 56ch;
		color: var(--text-muted);
		font-size: 1.02rem;
		line-height: 1.6;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.72rem;
		margin-top: 1.35rem;
	}

	.metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.72rem;
		margin-top: 1.3rem;
	}

	.metric {
		border: 1px solid var(--line);
		border-radius: 0.78rem;
		background: rgba(28, 17, 13, 0.76);
		padding: 0.72rem 0.78rem;
	}

	.metric span {
		display: block;
		color: var(--text-muted);
		font-size: 0.73rem;
		margin-bottom: 0.33rem;
	}

	.metric strong {
		font-size: 0.86rem;
	}

	.hero-visual {
		position: relative;
		margin-top: 1.8rem;
	}

	.shot-stack {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(0, 1.02fr);
		gap: 0.8rem;
		align-items: start;
	}

	.shot {
		display: block;
		width: 100%;
		max-width: none;
		height: auto;
		border: 1px solid #4a3024;
		border-radius: 0.95rem;
		box-shadow: 0 18px 44px rgba(16, 8, 4, 0.5);
	}

	.shot-base {
		background: #0f0907;
	}

	.shot-overlay {
		background: #1a120f;
		position: relative;
		z-index: 2;
		margin-top: 1rem;
		margin-left: -3.6rem;
	}

	.visual-note {
		margin: 0.78rem 0 0;
		font-size: 0.8rem;
		color: #b99985;
	}

	@media (max-width: 1024px) {
		.shot-stack {
			grid-template-columns: 1fr 1fr;
			gap: 0.9rem;
		}

		.shot-overlay {
			margin-left: -1.35rem;
		}
	}

	@media (max-width: 760px) {
		.metrics {
			grid-template-columns: 1fr;
		}

		.shot-stack {
			grid-template-columns: 1fr;
			gap: 0.85rem;
		}

		.shot-overlay {
			margin-top: 0;
			margin-left: 0;
		}
	}

	@media (max-width: 520px) {
		.hero-visual {
			margin-top: 1.3rem;
		}
	}
</style>
