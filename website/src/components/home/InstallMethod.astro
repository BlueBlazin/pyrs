---
import InstallTerminal from "./InstallTerminal.astro";
import HighlightChip from "../ui/HighlightChip.astro";

type InstallLine = string | { text: string; prompt?: boolean };

interface Props {
	title: string;
	description: string;
	lines: InstallLine[];
	recommended?: boolean;
}

const { title, description, lines, recommended = false } = Astro.props;
---

<article class="install-method">
	<div class="install-method-head">
		<h3>{title}</h3>
		{recommended && <HighlightChip label="Recommended" />}
	</div>
	<p>{description}</p>
	<InstallTerminal lines={lines} />
</article>

<style>
	.install-method {
		padding: 1rem 1.08rem 1.06rem;
	}

	.install-method + .install-method {
		border-top: 1px solid rgba(83, 52, 39, 0.72);
	}

	.install-method-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
	}

	.install-method h3 {
		margin: 0;
		font-size: 0.94rem;
		letter-spacing: 0.01em;
	}

	.install-method p {
		margin: 0.43rem 0 0;
		color: var(--text-muted);
		font-size: 0.86rem;
		line-height: 1.52;
	}

	@media (max-width: 760px) {
		.install-method {
			padding: 0.9rem 0.86rem;
		}
	}
</style>
