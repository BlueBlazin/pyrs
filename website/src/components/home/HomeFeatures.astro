---
type FeatureItem = {
	title: string;
	summary: string;
	labels: string[];
};

const features: FeatureItem[] = [
	{
		title: "CPython 3.14 Semantic Parity",
		summary:
			"Grammar behavior, bytecode execution, and runtime contracts are continuously aligned against CPython expectations.",
		labels: ["Parser parity", "Differential gates", "Runtime contracts"],
	},
	{
		title: "Bytecode + Source Execution Modes",
		summary:
			"Run Python from source files, modules, stdin, REPL sessions, or compiled bytecode with consistent interpreter behavior.",
		labels: ["Source mode", ".pyc support", "Interactive REPL"],
	},
	{
		title: "Scientific-Stack Bring-Up",
		summary:
			"C-API closure is tracked as a first-class roadmap lane, focused on pragmatic extension compatibility for real workloads.",
		labels: ["C-API closure", "NumPy gate", "ABI coverage"],
	},
	{
		title: "Production-Focused Diagnostics",
		summary:
			"Tracebacks, syntax diagnostics, and location metadata are shaped for high signal when debugging parity and runtime issues.",
		labels: ["Traceback fidelity", "Caret spans", "Location metadata"],
	},
];
---

<section class="home-features" id="features" aria-labelledby="home-features-title">
	<div class="features-head">
		<h2 id="home-features-title" class="section-title">Features</h2>
		<p class="section-subtitle">CPython-focused runtime and tools.</p>
		<p class="section-description">
			PYRS provides a compatible runtime tailored for real-world execution and practical development workflows.
		</p>
	</div>

	<ul class="feature-grid">
		{
			features.map((feature, index) => (
				<li class="feature-card">
					<div class="feature-index">{(index + 1).toString().padStart(2, "0")}</div>
					<div class="feature-content">
						<h3>{feature.title}</h3>
						<p>{feature.summary}</p>
						<div class="feature-labels" aria-label={`${feature.title} labels`}>
							{feature.labels.map((label) => (
								<span>{label}</span>
							))}
						</div>
					</div>
				</li>
			))
		}
	</ul>
</section>

<style>
	.home-features {
		position: relative;
		margin-top: 2rem;
		padding: 2rem 0;
	}

	.home-features::before {
		content: "";
		position: absolute;
		inset: -2rem 0 auto;
		height: 20rem;
		background: radial-gradient(50% 50% at 20% 0%, rgba(216, 149, 99, 0.08), transparent 72%);
		pointer-events: none;
	}

	.features-head {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-bottom: 3rem;
		text-align: center;
		align-items: center;
	}

	.section-title {
		margin: 0;
		font-size: clamp(2.5rem, 6vw, 4rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: #ffffff;
		font-weight: 700;
	}

	.section-subtitle {
		margin: 0;
		font-size: 1.15rem;
		color: #e4c8b8;
		font-weight: 500;
	}

	.section-description {
		margin: 0.5rem 0 0;
		max-width: 54ch;
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.feature-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.feature-card {
		background: rgba(15, 10, 8, 0.5);
		border: 1px solid rgba(83, 52, 39, 0.3);
		border-radius: 1rem;
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		transition: background-color 200ms ease, border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
	}

	.feature-card:hover {
		background: rgba(20, 13, 10, 0.8);
		border-color: rgba(150, 95, 68, 0.6);
		transform: translateY(-3px);
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
	}

	.feature-index {
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 1rem;
		font-weight: 600;
		color: #d99a6c;
		background: rgba(217, 154, 108, 0.1);
		width: max-content;
		padding: 0.3rem 0.6rem;
		border-radius: 0.4rem;
		user-select: none;
	}

	.feature-content h3 {
		margin: 0;
		font-size: 1.35rem;
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: #f7eee8;
	}

	.feature-content p {
		margin: 0.6rem 0 0;
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.feature-labels {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 1.2rem;
	}

	.feature-labels span {
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.7rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: #fce1cd;
		background: rgba(217, 154, 108, 0.15);
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
		border: 1px solid rgba(217, 154, 108, 0.2);
	}

	@media (max-width: 760px) {
		.features-head {
			text-align: left;
			align-items: flex-start;
			margin-bottom: 2rem;
		}

		.section-title {
			font-size: 2.5rem;
		}

		.feature-card {
			padding: 1.4rem;
		}
	}
</style>
