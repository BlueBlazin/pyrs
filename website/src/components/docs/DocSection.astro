---
import { cn } from "../../lib/cn";

interface Props {
	title?: string;
	id?: string;
	class?: string;
}

const { title, id, class: className } = Astro.props;
---

<section id={id} class={cn("mt-9 first:mt-0", className)}>
	{title && <h2 class="text-[1.15rem] font-semibold tracking-[-0.01em] text-docs-text">{title}</h2>}
	<div
		class={cn(
			title ? "mt-3.5" : "",
			"space-y-3.5 text-docs-muted leading-7 text-[0.97rem]",
			"[&>p]:m-0 [&>ul]:m-0 [&>ol]:m-0 [&>h3]:m-0 [&>h4]:m-0 [&>pre]:m-0",
		)}
	>
		<slot />
	</div>
</section>
