---
import { cn } from "../../lib/cn";

interface Props {
	title?: string;
	id?: string;
	class?: string;
}

const { title, id, class: className } = Astro.props;
---

<section id={id} class={cn("doc-section mt-10 first:mt-0", className)}>
	{title && <h2 class="m-0 text-[1.15rem] font-semibold tracking-[-0.01em] text-docs-text">{title}</h2>}
	<div class={cn(title ? "mt-4" : "", "doc-section-body text-[0.97rem] leading-7 text-docs-muted")}>
		<slot />
	</div>
</section>
