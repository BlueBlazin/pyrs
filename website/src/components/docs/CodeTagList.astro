---
interface Props {
	items: string | string[];
}

const { items } = Astro.props;
const values = (Array.isArray(items) ? items : items.split(","))
	.map((item) => item.trim())
	.filter(Boolean);
---

<ul class="code-tag-list">
	{
		values.map((item) => (
			<li>
				<code>{item}</code>
			</li>
		))
	}
</ul>

<style>
	.code-tag-list {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		padding: 0;
		margin: 1rem 0 0;
	}

	.code-tag-list li {
		margin: 0;
	}

	.code-tag-list code {
		display: inline-flex;
		align-items: center;
		padding: 0.36rem 0.58rem;
		border-radius: 0.7rem;
		border: 1px solid rgba(109, 78, 56, 0.18);
		background: rgba(255, 248, 241, 0.96);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
		font-size: 0.84rem;
		line-height: 1;
		white-space: nowrap;
	}
 </style>
