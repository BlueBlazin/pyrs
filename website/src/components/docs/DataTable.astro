---
import { cn } from "../../lib/cn";

interface Props {
	headers: string[];
	class?: string;
}

const { headers, class: className } = Astro.props;
---

<div class={cn("docs-block data-table-wrap overflow-x-auto rounded-xl border border-[#273143] bg-[#0d121c]", className)}>
	<table class="data-table min-w-full border-collapse text-left">
		<thead>
			<tr>
				{headers.map((header) => (
					<th scope="col" class="data-table-head">
						{header}
					</th>
				))}
			</tr>
		</thead>
		<tbody class="data-table-body">
			<slot />
		</tbody>
	</table>
</div>

<style>
	:global(.data-table-wrap) {
		box-shadow: 0 10px 30px rgba(2, 5, 12, 0.3);
	}

	:global(.data-table) {
		table-layout: fixed;
	}

	:global(.data-table-head) {
		border-bottom: 1px solid #2d3a53;
		background: linear-gradient(180deg, #13203a 0%, #10192b 100%);
		padding: 0.82rem 1.1rem;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #dce7fb;
	}

	:global(.data-table-body > tr > td) {
		border-bottom: 1px solid #263149;
		padding: 0.86rem 1.1rem;
		font-size: 0.92rem;
		line-height: 1.52;
		color: #b7c3db;
		vertical-align: top;
	}

	:global(.data-table-body > tr > td:first-child) {
		width: 38%;
		color: #d2dcef;
		font-weight: 500;
	}

	:global(.data-table-body > tr:last-child > td) {
		border-bottom: 0;
	}

	:global(.data-table-body > tr:nth-child(even) > td) {
		background: rgba(165, 190, 239, 0.03);
	}

	:global(.data-table-body > tr:hover > td) {
		background: rgba(174, 196, 235, 0.09);
	}

	:global(.data-table-body code) {
		display: inline-block;
		padding: 0.11rem 0.4rem;
		border-radius: 0.38rem;
		border: 1px solid #2f4365;
		background: #10192c;
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.82rem;
		color: #dbe7ff;
		line-height: 1.32;
	}

	@media (max-width: 760px) {
		:global(.data-table-head) {
			padding: 0.72rem 0.88rem;
			font-size: 0.69rem;
		}

		:global(.data-table-body > tr > td) {
			padding: 0.72rem 0.88rem;
			font-size: 0.88rem;
		}
	}
</style>
