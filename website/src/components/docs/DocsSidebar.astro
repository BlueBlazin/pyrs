---
import { docsNavGroups } from "../../config/docsNav";

interface Props {
	path: string;
}

const { path } = Astro.props;

const isActive = (href: string) => {
	if (href === "/docs/") {
		return path === "/docs/";
	}
	return path.startsWith(href);
};
---

<aside class="docs-sidebar">
	<details class="sidebar-details" open>
		<summary class="sidebar-summary">Documentation</summary>
		<div class="sidebar-inner">
			<div class="sidebar-title">Documentation</div>
			{docsNavGroups.map((group) => (
				<section class="nav-group">
					<p class="group-label">{group.label}</p>
					<nav class="group-links">
						{group.items.map((item) => (
							<a
								href={item.href}
								class={isActive(item.href) ? "active" : ""}
								aria-current={isActive(item.href) ? "page" : undefined}
							>
								{item.label}
							</a>
						))}
					</nav>
				</section>
			))}
		</div>
	</details>
</aside>

<style>
	.docs-sidebar {
		position: sticky;
		top: 1rem;
		max-height: calc(100vh - 1.5rem);
	}

	.sidebar-details {
		border: 1px solid #232a38;
		border-radius: 0.82rem;
		background: #0c1119;
		overflow: clip;
		box-shadow: 0 10px 24px rgba(2, 5, 12, 0.22);
	}

	.sidebar-summary {
		display: none;
		cursor: pointer;
		list-style: none;
		margin: 0;
		padding: 0.76rem 0.74rem;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #f3f6fb;
	}

	.sidebar-summary::-webkit-details-marker {
		display: none;
	}

	.sidebar-inner {
		padding: 0.86rem 0.78rem 0.88rem;
		max-height: calc(100vh - 4rem);
		overflow: auto;
		scrollbar-width: thin;
		scrollbar-color: #2f3e5b transparent;
	}

	.sidebar-inner::-webkit-scrollbar {
		width: 8px;
	}

	.sidebar-inner::-webkit-scrollbar-thumb {
		background: #2f3e5b;
		border-radius: 999px;
	}

	.sidebar-title {
		font-size: 0.83rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: #f3f6fb;
		margin-bottom: 0.78rem;
	}

	.nav-group + .nav-group {
		margin-top: 0.8rem;
	}

	.group-label {
		margin: 0 0 0.42rem;
		font-size: 0.69rem;
		letter-spacing: 0.09em;
		text-transform: uppercase;
		color: #8d99b3;
		font-weight: 700;
	}

	.group-links {
		display: flex;
		flex-direction: column;
		gap: 0.26rem;
		padding-left: 0.04rem;
		border-left: 1px solid #223049;
	}

	.group-links a {
		text-decoration: none;
		font-size: 0.845rem;
		color: #a5aec0;
		padding: 0.38rem 0.56rem;
		border-radius: 0.52rem;
		transition: color 120ms ease, background-color 120ms ease, border-color 120ms ease;
		border: 1px solid transparent;
		margin-left: -1px;
	}

	.group-links a:hover {
		color: #f3f6fb;
		background: rgba(181, 208, 255, 0.08);
		border-color: rgba(83, 114, 163, 0.32);
	}

	.group-links a:focus-visible {
		outline: 2px solid rgba(176, 199, 241, 0.92);
		outline-offset: 2px;
	}

	.group-links a.active {
		color: #edf4ff;
		background: #162133;
		border: 1px solid #3d547b;
		box-shadow: inset 3px 0 0 #91aee2;
	}

	@media (max-width: 760px) {
		.docs-sidebar {
			position: static;
		}

		.sidebar-summary {
			display: block;
		}

		.sidebar-inner {
			display: none;
			padding-top: 0.32rem;
			max-height: none;
		}

		.sidebar-details[open] .sidebar-inner {
			display: block;
		}
	}
</style>
