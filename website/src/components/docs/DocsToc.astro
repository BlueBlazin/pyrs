---
interface Heading {
	depth: number;
	slug?: string;
	text: string;
}

interface TocConfig {
	enabled?: boolean;
	minLevel?: number;
	maxLevel?: number;
	maxItems?: number;
	subheadings?: "all" | "active" | "none";
	include?: string[];
	exclude?: string[];
}

interface Props {
	headings?: Heading[];
	config?: TocConfig;
}

const defaultConfig: Required<TocConfig> = {
	enabled: true,
	minLevel: 2,
	maxLevel: 3,
	maxItems: 14,
	subheadings: "active",
	include: [],
	exclude: [],
};

const normalizeToken = (value: string): string => value.trim().toLowerCase();
const slugify = (value: string): string =>
	value
		.toLowerCase()
		.trim()
		.replace(/[`"'.,!?():]/g, "")
		.replace(/[^a-z0-9]+/g, "-")
		.replace(/^-+|-+$/g, "");

const { headings = [], config = {} } = Astro.props;
const mergedConfig: Required<TocConfig> = {
	...defaultConfig,
	...config,
	include: config.include ?? defaultConfig.include,
	exclude: config.exclude ?? defaultConfig.exclude,
};

const includeSet = new Set(mergedConfig.include.map(normalizeToken));
const excludeSet = new Set(mergedConfig.exclude.map(normalizeToken));

const shouldInclude = (slug: string, text: string): boolean => {
	const normalizedSlug = normalizeToken(slug);
	const normalizedTextSlug = slugify(text);
	if (includeSet.size > 0 && !includeSet.has(normalizedSlug) && !includeSet.has(normalizedTextSlug)) {
		return false;
	}
	if (excludeSet.has(normalizedSlug) || excludeSet.has(normalizedTextSlug)) {
		return false;
	}
	return true;
};

const tocItems = headings
	.filter((heading) => heading.depth >= mergedConfig.minLevel && heading.depth <= mergedConfig.maxLevel && heading.slug)
	.filter((heading) => shouldInclude(heading.slug ?? "", heading.text));

const hasInitialItems = tocItems.length > 0;
const tocEnabled = mergedConfig.enabled !== false;
---

{
	tocEnabled && (
		<aside
			class={`docs-toc ${hasInitialItems ? "is-ready" : ""}`}
			aria-label="On this page"
			data-toc-root="1"
			data-toc-min-level={String(mergedConfig.minLevel)}
			data-toc-max-level={String(mergedConfig.maxLevel)}
			data-toc-max-items={String(mergedConfig.maxItems)}
			data-toc-subheadings={mergedConfig.subheadings}
			data-toc-include={mergedConfig.include.join(",")}
			data-toc-exclude={mergedConfig.exclude.join(",")}
		>
			<p class="toc-title">On this page</p>
			<nav class="toc-nav" data-toc-nav="1">
				{tocItems.map((item) => (
					<a href={`#${item.slug}`} class={item.depth > mergedConfig.minLevel ? "is-sub" : undefined} data-toc-link>
						{item.text}
					</a>
				))}
			</nav>
		</aside>
	)
}

<style>
	.docs-toc {
		position: sticky;
		top: 5rem;
		max-height: calc(100vh - 5.8rem);
		align-self: start;
		overflow: hidden;
		padding: 0.95rem 0.76rem 0.88rem;
		border-radius: 0.9rem;
		border: 1px solid rgba(128, 152, 188, 0.24);
		background:
			radial-gradient(18rem 16rem at 100% -15%, rgba(109, 133, 173, 0.2), transparent 65%),
			linear-gradient(180deg, rgba(19, 25, 37, 0.96) 0%, rgba(12, 17, 27, 0.97) 100%);
		box-shadow: 0 16px 34px rgba(4, 6, 10, 0.46), inset 0 1px 0 rgba(240, 246, 255, 0.05);
		visibility: hidden;
	}

	.docs-toc::before {
		content: "";
		position: absolute;
		left: 0.9rem;
		right: 0.9rem;
		top: 0;
		height: 1px;
		background: linear-gradient(90deg, transparent 0%, rgba(186, 208, 244, 0.62) 50%, transparent 100%);
		opacity: 0.85;
		pointer-events: none;
	}

	.docs-toc.is-ready {
		visibility: visible;
	}

	.docs-toc.is-empty {
		display: none;
	}

	.toc-title {
		display: flex;
		align-items: center;
		gap: 0.38rem;
		margin: 0 0 0.66rem;
		font-size: 0.67rem;
		font-weight: 640;
		line-height: 1.14;
		letter-spacing: 0.095em;
		text-transform: uppercase;
		color: #a4b4ce;
	}

	.toc-title::before {
		content: "";
		width: 0.46rem;
		height: 0.46rem;
		border-radius: 999px;
		background: linear-gradient(160deg, #b6d3fb 0%, #7697cf 100%);
		box-shadow: 0 0 0 2px rgba(113, 145, 196, 0.22);
	}

	.toc-nav {
		display: flex;
		flex-direction: column;
		gap: 0.22rem;
		max-height: calc(100vh - 8.95rem);
		overflow: auto;
		padding: 0.16rem 0.18rem;
		margin: 0 -0.22rem -0.14rem;
		scrollbar-width: thin;
		scrollbar-color: #495f84 transparent;
	}

	.toc-nav::-webkit-scrollbar {
		width: 5px;
	}

	.toc-nav::-webkit-scrollbar-thumb {
		background: #495f84;
		border-radius: 999px;
	}

	.toc-nav a {
		position: relative;
		display: block;
		padding: 0.36rem 0.5rem 0.36rem 0.76rem;
		border-radius: 0.58rem;
		border: 1px solid transparent;
		color: #a4b2cb;
		font-size: 0.79rem;
		font-weight: 520;
		line-height: 1.31;
		text-decoration: none;
		text-wrap: pretty;
		transition: color 120ms ease, background-color 120ms ease, border-color 120ms ease, transform 120ms ease;
	}

	.toc-nav a.is-sub {
		padding-left: 1.05rem;
		font-size: 0.75rem;
		color: #8f9fb8;
	}

	.toc-nav a:hover {
		color: #eef4ff;
		background: rgba(109, 131, 172, 0.15);
		border-color: rgba(109, 131, 172, 0.33);
		transform: translateX(1px);
	}

	.toc-nav a::before {
		content: "";
		position: absolute;
		left: 0.35rem;
		top: 0.42rem;
		bottom: 0.42rem;
		width: 2px;
		border-radius: 999px;
		background: rgba(152, 183, 232, 0.34);
		opacity: 0.28;
		transform: scaleY(0.45);
		transition: background-color 120ms ease, opacity 120ms ease, transform 120ms ease;
	}

	.toc-nav a.is-sub::before {
		left: 0.62rem;
		width: 1.5px;
		opacity: 0.24;
	}

	.toc-nav a:hover::before {
		opacity: 0.68;
		transform: scaleY(1);
	}

	.toc-nav a.active {
		color: #f8fbff;
		background: linear-gradient(90deg, rgba(104, 136, 187, 0.29) 0%, rgba(63, 84, 117, 0.21) 100%);
		border-color: rgba(141, 172, 221, 0.42);
		font-weight: 620;
	}

	.toc-nav a.active::before {
		background: #a5c5f6;
		opacity: 1;
		transform: scaleY(1);
	}

	.toc-nav a.is-collapsed,
	.toc-nav a.is-hidden {
		display: none;
	}

	.toc-nav a:focus-visible {
		outline: 2px solid rgba(255, 186, 137, 0.92);
		outline-offset: 2px;
	}

	@media (max-width: 1080px) {
		.docs-toc {
			display: none;
		}
	}
</style>

<script>
	(() => {
		const toc = document.querySelector(".docs-toc[data-toc-root='1']");
		if (!(toc instanceof HTMLElement) || toc.dataset.bound === "1") {
			return;
		}
		toc.dataset.bound = "1";

		const nav = toc.querySelector("[data-toc-nav='1']");
		if (!(nav instanceof HTMLElement)) {
			toc.classList.add("is-empty");
			return;
		}

		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const toInt = (raw, fallback) => {
			const parsed = Number.parseInt(raw || "", 10);
			return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;
		};
		const normalizeToken = (value) => value.trim().toLowerCase();
		const parseTokens = (raw) =>
			(raw || "")
				.split(",")
				.map((token) => normalizeToken(token))
				.filter(Boolean);

		const minLevel = toInt(toc.dataset.tocMinLevel, 2);
		const maxLevel = toInt(toc.dataset.tocMaxLevel, 3);
		const maxItems = toInt(toc.dataset.tocMaxItems, 14);
		const subheadingsMode = ["all", "active", "none"].includes(toc.dataset.tocSubheadings)
			? toc.dataset.tocSubheadings
			: "active";
		const includeSet = new Set(parseTokens(toc.dataset.tocInclude));
		const excludeSet = new Set(parseTokens(toc.dataset.tocExclude));

		const slugify = (value) =>
			value
				.toLowerCase()
				.trim()
				.replace(/[`"'.,!?():]/g, "")
				.replace(/[^a-z0-9]+/g, "-")
				.replace(/^-+|-+$/g, "");

		const usedIds = new Set(Array.from(document.querySelectorAll("[id]")).map((node) => node.id));
		const ensureId = (heading) => {
			if (!(heading instanceof HTMLElement)) {
				return null;
			}
			if (heading.id) {
				usedIds.add(heading.id);
				return heading.id;
			}
			const base = slugify(heading.textContent || "");
			if (!base) {
				return null;
			}
			let nextId = base;
			let counter = 2;
			while (usedIds.has(nextId)) {
				nextId = `${base}-${counter}`;
				counter += 1;
			}
			heading.id = nextId;
			usedIds.add(nextId);
			return nextId;
		};

		const shouldIncludeHeading = (headingId, label) => {
			const normalizedId = normalizeToken(headingId);
			const normalizedLabel = slugify(label || "");
			if (includeSet.size > 0 && !includeSet.has(normalizedId) && !includeSet.has(normalizedLabel)) {
				return false;
			}
			if (excludeSet.has(normalizedId) || excludeSet.has(normalizedLabel)) {
				return false;
			}
			return true;
		};

		const collectFromRenderedHeadings = () => {
			const headingNodes = Array.from(
				document.querySelectorAll(".docs-content h2, .docs-content h3, .docs-content h4, .docs-content h5, .docs-content h6"),
			);
			const collected = [];
			for (const node of headingNodes) {
				if (!(node instanceof HTMLHeadingElement)) {
					continue;
				}
				if (node.closest(".docs-page-header")) {
					continue;
				}
				if (node.dataset.tocExclude === "1" || node.getAttribute("data-toc") === "false") {
					continue;
				}
				const depth = Number.parseInt(node.tagName.slice(1), 10);
				if (!Number.isFinite(depth) || depth < minLevel || depth > maxLevel) {
					continue;
				}
				const label = (node.dataset.tocLabel || node.textContent || "").trim();
				if (!label) {
					continue;
				}
				const id = ensureId(node);
				if (!id || !shouldIncludeHeading(id, label)) {
					continue;
				}
				collected.push({
					id,
					label,
					depth,
					heading: node,
					parentId: null,
					link: null,
				});
			}

			let activeRoot = null;
			for (const item of collected) {
				if (item.depth === minLevel) {
					activeRoot = item.id;
				} else {
					item.parentId = activeRoot;
				}
			}

			if (subheadingsMode === "none") {
				return collected.filter((item) => item.depth === minLevel);
			}
			return collected;
		};

		const renderNav = (items) => {
			nav.innerHTML = "";
			for (const item of items) {
				const link = document.createElement("a");
				link.href = `#${item.id}`;
				link.textContent = item.label;
				link.setAttribute("data-toc-link", "1");
				link.dataset.tocId = item.id;
				link.dataset.tocDepth = String(item.depth);
				if (item.parentId) {
					link.dataset.tocParent = item.parentId;
				}
				if (item.depth > minLevel) {
					link.classList.add("is-sub");
				}
				nav.append(link);
				item.link = link;
			}
		};

		let items = collectFromRenderedHeadings();
		if (items.length === 0) {
			toc.classList.add("is-empty");
			return;
		}

		renderNav(items);

		const overflowIds = new Set(items.slice(maxItems).map((item) => item.id));
		let expandedOverflow = false;
		let activeId = null;
		const activationOffset = 136;
		const itemById = new Map(items.map((item) => [item.id, item]));

		const applySubheadingVisibility = (currentActiveId) => {
			if (subheadingsMode !== "active") {
				for (const item of items) {
					item.link.classList.remove("is-collapsed");
				}
				return;
			}
			const activeItem = currentActiveId ? itemById.get(currentActiveId) : null;
			const activeRoot = activeItem
				? activeItem.depth === minLevel
					? activeItem.id
					: activeItem.parentId
				: null;
			for (const item of items) {
				if (item.depth === minLevel) {
					item.link.classList.remove("is-collapsed");
					continue;
				}
				const shouldShow = Boolean(activeRoot && item.parentId === activeRoot);
				item.link.classList.toggle("is-collapsed", !shouldShow);
			}
		};

		const applyOverflowVisibility = (currentActiveId) => {
			if (items.length <= maxItems) {
				for (const item of items) {
					item.link.classList.remove("is-hidden");
				}
				return;
			}

			const forceExpanded = currentActiveId ? overflowIds.has(currentActiveId) : false;
			const shouldExpand = expandedOverflow || forceExpanded;
			for (let index = 0; index < items.length; index += 1) {
				const item = items[index];
				const hidden = index >= maxItems && !shouldExpand;
				item.link.classList.toggle("is-hidden", hidden);
			}
		};

		const setActive = (nextActiveId) => {
			for (const item of items) {
				const isActive = item.id === nextActiveId;
				item.link.classList.toggle("active", isActive);
				item.link.setAttribute("aria-current", isActive ? "location" : "false");
			}
		};

		const syncHash = (nextActiveId) => {
			if (!nextActiveId) {
				return;
			}
			const targetHash = `#${nextActiveId}`;
			if (window.location.hash === targetHash) {
				return;
			}
			history.replaceState(history.state, "", `${window.location.pathname}${window.location.search}${targetHash}`);
		};

		const followActiveLink = (nextActiveId) => {
			if (!nextActiveId) {
				return;
			}
			const activeItem = itemById.get(nextActiveId);
			if (!activeItem || activeItem.link.classList.contains("is-hidden")) {
				return;
			}
			activeItem.link.scrollIntoView({ block: "nearest" });
		};

		const computeActiveId = () => {
			let nextActiveId = items[0].id;
			for (const item of items) {
				const top = item.heading.getBoundingClientRect().top;
				if (top <= activationOffset) {
					nextActiveId = item.id;
					continue;
				}
				break;
			}
			return nextActiveId;
		};

		const refresh = () => {
			const nextActiveId = computeActiveId();
			applySubheadingVisibility(nextActiveId);
			applyOverflowVisibility(nextActiveId);
			if (nextActiveId === activeId) {
				return;
			}
			activeId = nextActiveId;
			setActive(activeId);
			syncHash(activeId);
			followActiveLink(activeId);
		};

		nav.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof Element)) {
				return;
			}
			const link = target.closest("a[data-toc-link]");
			if (!(link instanceof HTMLAnchorElement)) {
				return;
			}
			event.preventDefault();
			const headingId = decodeURIComponent(link.hash.slice(1));
			const heading = headingId ? document.getElementById(headingId) : null;
			if (!heading) {
				return;
			}
			const targetY = Math.max(heading.getBoundingClientRect().top + window.scrollY - (activationOffset - 12), 0);
			window.scrollTo({ top: targetY, behavior: prefersReducedMotion ? "auto" : "smooth" });
			history.pushState(history.state, "", `${window.location.pathname}${window.location.search}#${headingId}`);
			activeId = headingId;
			setActive(activeId);
			applySubheadingVisibility(activeId);
			applyOverflowVisibility(activeId);
			followActiveLink(activeId);
		});

		let refreshRaf = 0;
		const scheduleRefresh = () => {
			if (refreshRaf !== 0) {
				return;
			}
			refreshRaf = window.requestAnimationFrame(() => {
				refreshRaf = 0;
				refresh();
			});
		};

		window.addEventListener("scroll", scheduleRefresh, { passive: true });
		window.addEventListener("hashchange", scheduleRefresh);
		if ("IntersectionObserver" in window) {
			const observer = new IntersectionObserver(scheduleRefresh, {
				rootMargin: `-${activationOffset}px 0px -65% 0px`,
				threshold: [0, 1],
			});
			for (const item of items) {
				observer.observe(item.heading);
			}
		}

		toc.classList.add("is-ready");
		refresh();
	})();
</script>
