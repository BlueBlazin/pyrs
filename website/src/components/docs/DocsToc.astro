---
interface Heading {
	depth: number;
	slug?: string;
	text: string;
}

interface Props {
	headings?: Heading[];
}

const { headings = [] } = Astro.props;
const tocItems = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3 && heading.slug);
const hasInitialItems = tocItems.length > 0;
---

<aside
	class={`docs-toc ${hasInitialItems ? "is-ready" : ""}`}
	aria-label="On this page"
	data-toc-root="1"
	data-has-initial={hasInitialItems ? "1" : "0"}
>
	<div class="toc-inner">
		<p class="toc-title">On this page</p>
		<nav class="toc-nav" data-toc-nav="1">
			{tocItems.map((item) => (
				<a href={`#${item.slug}`} class={item.depth === 3 ? "is-sub" : undefined} data-toc-link>
					{item.text}
				</a>
			))}
		</nav>
	</div>
</aside>

<style>
	.docs-toc {
		position: sticky;
		top: 5.35rem;
		max-height: calc(100vh - 6rem);
		visibility: hidden;
	}

	.docs-toc.is-ready {
		visibility: visible;
	}

	.docs-toc.is-empty {
		display: none;
	}

	.toc-inner {
		padding: 0;
	}

	.toc-title {
		margin: 0 0 0.76rem;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #7f8ba4;
		font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
	}

	.toc-nav {
		display: flex;
		flex-direction: column;
		gap: 0.04rem;
		max-height: calc(100vh - 9.85rem);
		overflow: auto;
		padding-left: 0.72rem;
		padding-right: 0.18rem;
		border-left: 1px solid #22324a;
		scrollbar-width: thin;
		scrollbar-color: #324463 transparent;
	}

	.toc-nav::-webkit-scrollbar {
		width: 5px;
	}

	.toc-nav::-webkit-scrollbar-thumb {
		background: #324463;
		border-radius: 999px;
	}

	.toc-nav a {
		position: relative;
		display: block;
		margin-left: -0.72rem;
		color: #9aa6be;
		text-decoration: none;
		font-size: 0.83rem;
		line-height: 1.35;
		padding: 0.32rem 0.44rem 0.32rem 0.72rem;
		transition: color 120ms ease, background-color 120ms ease;
		font-weight: 500;
		text-wrap: balance;
		border-radius: 0.38rem;
		font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
	}

	.toc-nav a.is-sub {
		padding-left: 1.08rem;
		font-size: 0.79rem;
		color: #8793ab;
	}

	.toc-nav a:hover {
		color: #d0dcf1;
		background: rgba(118, 146, 197, 0.11);
	}

	.toc-nav a::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.42rem;
		bottom: 0.42rem;
		width: 2px;
		border-radius: 999px;
		background: transparent;
		transition: background-color 120ms ease;
	}

	.toc-nav a.active {
		color: #eef4ff;
		background: rgba(89, 116, 162, 0.19);
		font-weight: 600;
	}

	.toc-nav a.active::before {
		background: #8ca9dd;
	}

	.toc-nav a:focus-visible {
		outline: 2px solid rgba(255, 186, 137, 0.92);
		outline-offset: 2px;
	}

	@media (max-width: 1080px) {
		.docs-toc {
			display: none;
		}
	}
</style>

<script>
	(() => {
		const toc = document.querySelector(".docs-toc[data-toc-root='1']");
		if (!(toc instanceof HTMLElement) || toc.dataset.bound === "1") {
			return;
		}
		toc.dataset.bound = "1";
		const nav = toc.querySelector("[data-toc-nav='1']");
		if (!(nav instanceof HTMLElement)) {
			toc.classList.add("is-empty");
			return;
		}

		const slugify = (value) =>
			value
				.toLowerCase()
				.trim()
				.replace(/[`"'.,!?():]/g, "")
				.replace(/[^a-z0-9]+/g, "-")
				.replace(/^-+|-+$/g, "");

		const usedIds = new Set(Array.from(document.querySelectorAll("[id]")).map((node) => node.id));
		const ensureId = (heading) => {
			if (!(heading instanceof HTMLElement)) {
				return null;
			}
			if (heading.id) {
				usedIds.add(heading.id);
				return heading.id;
			}
			const base = slugify(heading.textContent || "");
			if (!base) {
				return null;
			}
			let nextId = base;
			let counter = 2;
			while (usedIds.has(nextId)) {
				nextId = `${base}-${counter}`;
				counter += 1;
			}
			heading.id = nextId;
			usedIds.add(nextId);
			return nextId;
		};

		const collectItems = () => {
			const links = Array.from(nav.querySelectorAll("a[data-toc-link][href^='#']"));
			return links
				.map((link) => {
					if (!(link instanceof HTMLAnchorElement)) {
						return null;
					}
					const id = decodeURIComponent(link.hash.slice(1));
					const heading = id ? document.getElementById(id) : null;
					if (!heading) {
						return null;
					}
					return { id, heading, link };
				})
				.filter((item) => item !== null);
		};

		let items = collectItems();

		if (items.length === 0) {
			const renderedHeadings = Array.from(document.querySelectorAll(".docs-content h2, .docs-content h3")).filter(
				(node) =>
					node instanceof HTMLHeadingElement &&
					!node.closest(".docs-page-header") &&
					Boolean(node.textContent?.trim()),
			);
			for (const heading of renderedHeadings) {
				const id = ensureId(heading);
				if (!id) {
					continue;
				}
				const link = document.createElement("a");
				link.href = `#${id}`;
				if (heading.tagName === "H3") {
					link.classList.add("is-sub");
				}
				link.setAttribute("data-toc-link", "1");
				link.textContent = heading.textContent?.trim() ?? id;
				nav.append(link);
			}
			items = collectItems();
		}

		if (items.length === 0) {
			toc.classList.add("is-empty");
			return;
		}

		const setActive = (id) => {
			for (const item of items) {
				item.link.classList.toggle("active", item.id === id);
			}
		};

		const refresh = () => {
			let activeId = items[0].id;
			for (const item of items) {
				const top = item.heading.getBoundingClientRect().top;
				if (top <= 140) {
					activeId = item.id;
					continue;
				}
				break;
			}
			setActive(activeId);
		};

		window.addEventListener("scroll", refresh, { passive: true });
		window.addEventListener("hashchange", refresh);
		toc.classList.add("is-ready");
		refresh();
	})();
</script>
