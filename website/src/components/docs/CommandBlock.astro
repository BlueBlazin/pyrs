---
import { cn } from "../../lib/cn";

interface Props {
	commands: string[];
	label?: string;
	class?: string;
}

const { commands, label = "Shell", class: className } = Astro.props;
const copyPayload = commands.join("\n");
---

<div class={cn("docs-block command-block overflow-hidden rounded-xl border border-[#2a3345] bg-[#0b1019]", className)}>
	<div
		class="flex items-center justify-between gap-2.5 border-b border-[#1f293a] bg-[linear-gradient(180deg,#111b2e_0%,#0b1423_100%)] px-3.5 py-1.5"
	>
		<div class="flex items-center gap-3">
			<div class="inline-flex gap-1.5" aria-hidden="true">
				<span class="size-2.5 rounded-full bg-[#ff6b57]"></span>
				<span class="size-2.5 rounded-full bg-[#fcbf4e]"></span>
				<span class="size-2.5 rounded-full bg-[#35cd67]"></span>
			</div>
			<span class="text-[0.63rem] font-semibold uppercase tracking-[0.16em] text-[#b6c5e2]">{label}</span>
		</div>
		<button
			type="button"
			data-copy={copyPayload}
			data-copy-button="1"
			class="copy-control"
			style="--copy-border:#394f73;--copy-bg:#17233a;--copy-text:#e3eafa;--copy-hover-bg:#223452;--copy-hover-border:#5372a7;--copy-focus:rgba(111,146,202,0.88);--copy-success-bg:#1c334f;--copy-success-border:#5673a7;--copy-success-text:#f0f5ff;--copy-fail-bg:#522333;--copy-fail-border:#a64f68;--copy-fail-text:#ffe6ed;"
		>
			Copy
		</button>
	</div>
	<div class="command-lines overflow-x-auto px-4 py-2.5">
		<code class="block font-['IBM_Plex_Mono',ui-monospace,SFMono-Regular,Menlo,monospace] text-[0.8rem] leading-6 text-[#e4e9f6]">
			{commands.map((command) => (
				<span class="command-line">
					<span class="command-prompt select-none pr-3 text-[#efb087]">$</span>
					<span class="command-text">{command}</span>
				</span>
			))}
		</code>
	</div>
</div>

<style>
	.command-block {
		box-shadow: 0 10px 28px rgba(2, 5, 12, 0.28);
	}

	.command-line {
		display: flex;
		gap: 0.28rem;
		align-items: flex-start;
	}

	.command-text {
		white-space: pre;
		min-width: 0;
		flex: 1;
	}

	.command-lines {
		overflow-y: hidden;
		scrollbar-width: thin;
		scrollbar-color: rgba(124, 141, 174, 0.58) rgba(18, 26, 39, 0.68);
		scrollbar-gutter: stable both-edges;
	}

	.command-lines::-webkit-scrollbar {
		height: 0.46rem;
	}

	.command-lines::-webkit-scrollbar-track {
		background: rgba(17, 24, 36, 0.72);
		border-radius: 999px;
	}

	.command-lines::-webkit-scrollbar-thumb {
		background: linear-gradient(90deg, rgba(120, 139, 176, 0.74) 0%, rgba(98, 118, 156, 0.74) 100%);
		border: 1px solid rgba(12, 17, 27, 0.92);
		border-radius: 999px;
	}

	.command-lines::-webkit-scrollbar-thumb:hover {
		background: linear-gradient(90deg, rgba(140, 158, 194, 0.78) 0%, rgba(111, 131, 169, 0.78) 100%);
	}

	.command-lines::-webkit-scrollbar-corner {
		background: transparent;
	}

	@media (max-width: 760px) {
		.command-lines {
			overflow-x: auto;
			padding-inline: 0.9rem;
		}

		.command-lines code {
			font-size: 0.76rem;
			line-height: 1.52;
		}

		.command-line {
			min-width: 0;
			gap: 0.34rem;
		}

		.command-text {
			white-space: pre-wrap;
			overflow-wrap: anywhere;
			word-break: break-word;
		}
	}

</style>
