---
import { existsSync, readFileSync } from "node:fs";
import path from "node:path";

import HighlightChip from "../ui/HighlightChip.astro";
import Callout from "./Callout.astro";
import DataTable from "./DataTable.astro";

type RankedRow = {
	name?: string;
	count?: number;
};

type BenchmarkSummary = {
	generated_at_utc?: string;
	run_state?: {
		status?: string;
		completed_at_utc?: string;
		elapsed_total_secs?: number;
	};
	host?: {
		system?: string;
		release?: string;
		machine?: string;
		cpu_count?: number;
	};
	runner?: {
		path?: string;
		sha256?: string;
	};
	config?: {
		jobs?: number;
		inventory_timeout_secs?: number;
		run_timeout_secs?: number;
	};
	dispatch?: {
		aggregate_batch_elapsed_secs?: number;
		planned_batch_count?: number;
	};
	inventory?: {
		entry_count?: number;
		discoverable_case_count?: number;
		host_skip_entries?: number;
	};
	results?: {
		module_statuses?: Record<string, number>;
		case_outcomes?: Record<string, number>;
		subtest_outcomes?: Record<string, number>;
		fixture_outcomes?: Record<string, number>;
		executed_case_count?: number;
		executed_subtest_count?: number;
	};
};

type DerivedSummary = {
	top_modules_by_nonpass?: RankedRow[];
	failure_signatures?: {
		case?: RankedRow[];
		subtest?: RankedRow[];
	};
};

const locateBenchmarkFile = (name: string): string | null => {
	const candidates = [
		path.resolve(process.cwd(), "..", "perf", "cpython_compat_benchmark_latest", name),
		path.resolve(process.cwd(), "perf", "cpython_compat_benchmark_latest", name),
	];
	for (const candidate of candidates) {
		if (existsSync(candidate)) {
			return candidate;
		}
	}
	return null;
};

const summaryPath = locateBenchmarkFile("summary.json");
const derivedPath = locateBenchmarkFile("derived_summary.json");

let summary: BenchmarkSummary | null = null;
let derived: DerivedSummary | null = null;
let loadError: string | null = null;

try {
	if (!summaryPath) {
		throw new Error("summary.json not found under perf/cpython_compat_benchmark_latest");
	}
	summary = JSON.parse(readFileSync(summaryPath, "utf8"));
	if (derivedPath) {
		try {
			derived = JSON.parse(readFileSync(derivedPath, "utf8"));
		} catch (error) {
			loadError = error instanceof Error ? error.message : String(error);
		}
	} else {
		loadError = "derived_summary.json not found under perf/cpython_compat_benchmark_latest";
	}
} catch (error) {
	loadError = error instanceof Error ? error.message : String(error);
}

const formatNumber = (value: number | null | undefined): string =>
	typeof value === "number" ? new Intl.NumberFormat("en-US").format(value) : "n/a";

const formatPercent = (value: number, total: number, digits = 1): string => {
	if (!total) {
		return "0%";
	}
	return `${((value / total) * 100).toFixed(digits)}%`;
};

const formatDuration = (value: number | null | undefined): string => {
	if (typeof value !== "number" || Number.isNaN(value)) {
		return "n/a";
	}
	if (value < 1) {
		return `${value.toFixed(3)}s`;
	}
	const totalSeconds = Math.round(value);
	const hours = Math.floor(totalSeconds / 3600);
	const minutes = Math.floor((totalSeconds % 3600) / 60);
	const seconds = totalSeconds % 60;
	if (hours > 0) {
		return `${hours}h ${minutes}m ${seconds}s`;
	}
	if (minutes > 0) {
		return `${minutes}m ${seconds}s`;
	}
	return `${seconds}s`;
};

const formatTimestamp = (value: string | null | undefined): string => {
	if (!value) {
		return "n/a";
	}
	const date = new Date(value);
	if (Number.isNaN(date.getTime())) {
		return value;
	}
	return `${new Intl.DateTimeFormat("en-US", {
		dateStyle: "medium",
		timeStyle: "short",
		timeZone: "UTC",
	}).format(date)} UTC`;
};

const prettyLabel = (value: string): string =>
	value
		.split("_")
		.map((part) => part.charAt(0).toUpperCase() + part.slice(1))
		.join(" ");

const caseOutcomes = summary?.results?.case_outcomes ?? {};
const subtestOutcomes = summary?.results?.subtest_outcomes ?? {};
const moduleStatuses = summary?.results?.module_statuses ?? {};
const fixtureOutcomes = summary?.results?.fixture_outcomes ?? {};

const discoverableCases = summary?.inventory?.discoverable_case_count ?? 0;
const discoverableEntries = summary?.inventory?.entry_count ?? 0;
const executedCases = summary?.results?.executed_case_count ?? 0;
const executedSubtests = summary?.results?.executed_subtest_count ?? 0;
const passedCases = caseOutcomes.passed ?? 0;
const passedSubtests = subtestOutcomes.passed ?? 0;
const hostSkippedInventories = summary?.inventory?.host_skip_entries ?? 0;
const aggregateElapsed = summary?.dispatch?.aggregate_batch_elapsed_secs ?? summary?.run_state?.elapsed_total_secs ?? null;
const updatedAt = summary?.run_state?.completed_at_utc ?? summary?.generated_at_utc ?? null;

const metricCards = summary
	? [
			{
				label: "Discoverable entries",
				value: formatNumber(discoverableEntries),
				note: "Host-visible CPython test modules.",
			},
			{
				label: "Discoverable cases",
				value: formatNumber(discoverableCases),
				note: "Canonical denominator for this platform.",
			},
			{
				label: "Executed case outcomes",
				value: formatNumber(executedCases),
				note: `${formatPercent(executedCases, discoverableCases)} of discoverable cases produced a case-level outcome.`,
			},
			{
				label: "Executed subtests",
				value: formatNumber(executedSubtests),
				note: "Captured separately from case outcomes.",
			},
			{
				label: "Aggregate suite time",
				value: formatDuration(aggregateElapsed),
				note: "Summed batch execution time from the full run.",
			},
			{
				label: "Artifact updated",
				value: formatTimestamp(updatedAt),
				note: "UTC timestamp for the latest published snapshot.",
			},
	  ]
	: [];

const coverageCards = summary
	? [
			{
				label: "Case execution reach",
				value: formatPercent(executedCases, discoverableCases),
				note: `${formatNumber(executedCases)} of ${formatNumber(discoverableCases)} discoverable cases reached a case-level result.`,
				tone: "coverage",
			},
			{
				label: "Executed case pass rate",
				value: formatPercent(passedCases, executedCases),
				note: `${formatNumber(passedCases)} passed case outcomes.`,
				tone: "success",
			},
			{
				label: "Executed subtest pass rate",
				value: formatPercent(passedSubtests, executedSubtests),
				note: `${formatNumber(passedSubtests)} passed subtest outcomes.`,
				tone: "success",
			},
			{
				label: "Inventory host skips",
				value: formatNumber(hostSkippedInventories),
				note: "Entries skipped before execution because the host does not expose the required platform surface.",
				tone: "warning",
			},
	  ]
	: [];

const moduleStatusRows = Object.entries(moduleStatuses).sort((left, right) => right[1] - left[1]);
const caseOutcomeRows = Object.entries(caseOutcomes).sort((left, right) => right[1] - left[1]);
const subtestOutcomeRows = Object.entries(subtestOutcomes).sort((left, right) => right[1] - left[1]);
const fixtureOutcomeRows = Object.entries(fixtureOutcomes).sort((left, right) => right[1] - left[1]);

const topModules = (derived?.top_modules_by_nonpass ?? []).slice(0, 10);
const caseSignatures = (derived?.failure_signatures?.case ?? []).slice(0, 10);
const subtestSignatures = (derived?.failure_signatures?.subtest ?? []).slice(0, 10);

const summaryAvailable = summary !== null;
const runnerSha = summary?.runner?.sha256 ? summary.runner.sha256.slice(0, 12) : null;
const runnerPath = summary?.runner?.path ?? "n/a";
const hostLabel = summary?.host
	? [summary.host.system, summary.host.release, summary.host.machine].filter(Boolean).join(" ")
	: "n/a";
---

{
	!summaryAvailable ? (
		<Callout title="Benchmark artifact unavailable" variant="warning">
			This page renders from <code>perf/cpython_compat_benchmark_latest</code> when the benchmark artifact
			is present at build time. The UI is in place, but this build did not include the summary JSON.
			{loadError && (
				<>
					{" "}
					Last load error: <code>{loadError}</code>.
				</>
			)}
		</Callout>
	) : (
		<div class="benchmark-page">
			<section class="benchmark-hero docs-block">
				<div class="hero-copy">
					<div class="hero-chip-row">
						<HighlightChip label="Latest Snapshot" />
						<span class="hero-chip-text">CPython 3.14 product benchmark</span>
					</div>
					<h3>Runs all discoverable CPython test entries on this host and records both case and subtest outcomes.</h3>
					<p>
						This page is intentionally separate from CI and internal development probes. It is the public
						product-facing snapshot for interpreter compatibility, using the local CPython test suite as the
						source of truth.
					</p>
				</div>
				<div class="hero-meta-card">
					<div>
						<span class="meta-label">Runner</span>
						<strong>{runnerPath}</strong>
						{runnerSha && <code>{runnerSha}</code>}
					</div>
					<div>
						<span class="meta-label">Host</span>
						<strong>{hostLabel}</strong>
					</div>
					<div>
						<span class="meta-label">Parallelism</span>
						<strong>{formatNumber(summary?.config?.jobs)} workers</strong>
					</div>
					<div>
						<span class="meta-label">Timeout policy</span>
						<strong>
							Inventory {formatDuration(summary?.config?.inventory_timeout_secs)} / run {formatDuration(summary?.config?.run_timeout_secs)}
						</strong>
					</div>
				</div>
			</section>

			<div class="metric-grid">
				{metricCards.map((card) => (
					<article class="metric-card">
						<p class="metric-label">{card.label}</p>
						<strong class="metric-value">{card.value}</strong>
						<p class="metric-note">{card.note}</p>
					</article>
				))}
			</div>

			<Callout title="Interpretation">
				Discoverable test cases and executed outcome events are separate counts by design. Some modules never reach
				case execution because they fail to load, crash, or time out first. Aggregate suite time is taken from the
				underlying full batch run, not from any later cached refresh.
			</Callout>

			<div class="signal-grid">
				{coverageCards.map((card) => (
					<article class={`signal-card tone-${card.tone}`}>
						<p class="signal-label">{card.label}</p>
						<strong class="signal-value">{card.value}</strong>
						<p class="signal-note">{card.note}</p>
					</article>
				))}
			</div>

			<div class="table-stack">
				<DataTable headers={["Module status", "Count"]}>
					{moduleStatusRows.map(([label, count]) => (
						<tr>
							<td>{prettyLabel(label)}</td>
							<td>{formatNumber(count)}</td>
						</tr>
					))}
				</DataTable>

				<DataTable headers={["Case outcome", "Count"]}>
					{caseOutcomeRows.map(([label, count]) => (
						<tr>
							<td>{prettyLabel(label)}</td>
							<td>{formatNumber(count)}</td>
						</tr>
					))}
				</DataTable>

				<DataTable headers={["Subtest outcome", "Count"]}>
					{subtestOutcomeRows.map(([label, count]) => (
						<tr>
							<td>{prettyLabel(label)}</td>
							<td>{formatNumber(count)}</td>
						</tr>
					))}
				</DataTable>

				{fixtureOutcomeRows.length > 0 && (
					<DataTable headers={["Fixture outcome", "Count"]}>
						{fixtureOutcomeRows.map(([label, count]) => (
							<tr>
								<td>{prettyLabel(label)}</td>
								<td>{formatNumber(count)}</td>
							</tr>
						))}
					</DataTable>
				)}
			</div>

			<div class="bench-grid">
				<div class="bench-grid-main">
					<h3 class="section-kicker">Top non-pass modules</h3>
					<DataTable headers={["Module", "Non-pass events"]}>
						{topModules.map((row) => (
							<tr>
								<td><code>{row.name ?? "n/a"}</code></td>
								<td>{formatNumber(row.count)}</td>
							</tr>
						))}
					</DataTable>
				</div>
				<div class="bench-grid-side">
					<h3 class="section-kicker">Run profile</h3>
					<DataTable headers={["Field", "Value"]}>
						<tr>
							<td>Snapshot updated</td>
							<td>{formatTimestamp(updatedAt)}</td>
						</tr>
						<tr>
							<td>Aggregate batch time</td>
							<td>{formatDuration(aggregateElapsed)}</td>
						</tr>
						<tr>
							<td>Planned batches</td>
							<td>{formatNumber(summary?.dispatch?.planned_batch_count)}</td>
						</tr>
						<tr>
							<td>Runner SHA</td>
							<td><code>{runnerSha ?? "n/a"}</code></td>
						</tr>
						<tr>
							<td>CPU count</td>
							<td>{formatNumber(summary?.host?.cpu_count)}</td>
						</tr>
						<tr>
							<td>Inventory host skips</td>
							<td>{formatNumber(hostSkippedInventories)}</td>
						</tr>
					</DataTable>
				</div>
			</div>

			<div class="signature-grid">
				<section>
					<h3 class="section-kicker">Repeated case signatures</h3>
					<DataTable headers={["Signature", "Count"]}>
						{caseSignatures.map((row) => (
							<tr>
								<td>{row.name ?? "n/a"}</td>
								<td>{formatNumber(row.count)}</td>
							</tr>
						))}
					</DataTable>
				</section>
				<section>
					<h3 class="section-kicker">Repeated subtest signatures</h3>
					<DataTable headers={["Signature", "Count"]}>
						{subtestSignatures.map((row) => (
							<tr>
								<td>{row.name ?? "n/a"}</td>
								<td>{formatNumber(row.count)}</td>
							</tr>
						))}
					</DataTable>
				</section>
			</div>

			{loadError && (
				<Callout title="Derived summary note" variant="warning">
					The main benchmark summary loaded, but the derived rollup reported an issue while loading:
					<code>{loadError}</code>.
				</Callout>
			)}
		</div>
	)
}

<style>
	.benchmark-page {
		display: flex;
		flex-direction: column;
		gap: 1.6rem;
	}

	.benchmark-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.45fr) minmax(19rem, 0.9fr);
		gap: 1rem;
		padding: 1.15rem;
		border: 1px solid #30405a;
		border-radius: 1rem;
		background:
			radial-gradient(circle at top right, rgba(107, 153, 219, 0.18), transparent 36%),
			linear-gradient(180deg, rgba(18, 26, 41, 0.96), rgba(11, 15, 23, 0.96));
		box-shadow: 0 16px 40px rgba(2, 5, 12, 0.28);
	}

	.hero-copy h3 {
		margin: 0.58rem 0 0;
		font-size: clamp(1.12rem, 2.1vw, 1.48rem);
		line-height: 1.2;
		color: #f2f6ff;
		max-width: 24ch;
	}

	.hero-copy p {
		margin: 0.85rem 0 0;
		max-width: 60ch;
		color: #b2bfd8;
	}

	.hero-chip-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem;
	}

	.hero-chip-text {
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.09em;
		text-transform: uppercase;
		color: #aab6cf;
	}

	.hero-meta-card {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		align-content: start;
		padding: 0.95rem;
		border: 1px solid rgba(112, 136, 176, 0.24);
		border-radius: 0.86rem;
		background: rgba(8, 12, 19, 0.68);
	}

	.hero-meta-card > div {
		display: flex;
		flex-direction: column;
		gap: 0.26rem;
		padding: 0.72rem;
		border-radius: 0.7rem;
		background: rgba(15, 22, 36, 0.85);
		border: 1px solid rgba(65, 83, 113, 0.42);
	}

	.meta-label,
	.metric-label,
	.signal-label,
	.section-kicker {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #9eabc7;
	}

	.hero-meta-card strong {
		font-size: 0.94rem;
		line-height: 1.35;
		color: #ecf2ff;
	}

	.hero-meta-card code {
		width: fit-content;
	}

	.metric-grid,
	.signal-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.82rem;
	}

	.metric-card,
	.signal-card {
		padding: 0.92rem 0.94rem;
		border-radius: 0.88rem;
		border: 1px solid #2c374b;
		background: linear-gradient(180deg, rgba(14, 18, 27, 0.96), rgba(10, 14, 21, 0.96));
		box-shadow: 0 10px 26px rgba(2, 5, 12, 0.22);
	}

	.metric-value,
	.signal-value {
		display: block;
		margin-top: 0.54rem;
		font-size: clamp(1.18rem, 2vw, 1.65rem);
		line-height: 1.05;
		color: #f2f6ff;
		letter-spacing: -0.03em;
	}

	.metric-note,
	.signal-note {
		margin: 0.68rem 0 0;
		font-size: 0.84rem;
		line-height: 1.54;
		color: #98a6c2;
	}

	.signal-card.tone-success {
		border-color: rgba(59, 113, 88, 0.72);
		background:
			radial-gradient(circle at top right, rgba(51, 110, 77, 0.22), transparent 42%),
			linear-gradient(180deg, rgba(12, 20, 17, 0.96), rgba(9, 15, 13, 0.96));
	}

	.signal-card.tone-warning {
		border-color: rgba(136, 106, 49, 0.68);
		background:
			radial-gradient(circle at top right, rgba(168, 127, 58, 0.18), transparent 42%),
			linear-gradient(180deg, rgba(25, 19, 9, 0.96), rgba(17, 12, 6, 0.96));
	}

	.signal-card.tone-coverage {
		border-color: rgba(74, 104, 153, 0.7);
		background:
			radial-gradient(circle at top right, rgba(85, 125, 194, 0.2), transparent 42%),
			linear-gradient(180deg, rgba(14, 20, 32, 0.96), rgba(9, 13, 20, 0.96));
	}

	.table-stack {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.9rem;
	}

	.bench-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(18rem, 0.9fr);
		gap: 1rem;
		align-items: start;
	}

	.bench-grid-main,
	.bench-grid-side,
	.signature-grid section {
		display: flex;
		flex-direction: column;
		gap: 0.72rem;
	}

	.signature-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		align-items: start;
	}

	.section-kicker {
		margin: 0;
	}

	@media (max-width: 980px) {
		.benchmark-hero,
		.bench-grid,
		.signature-grid {
			grid-template-columns: 1fr;
		}

		.metric-grid,
		.signal-grid,
		.table-stack {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.hero-meta-card,
		.metric-grid,
		.signal-grid,
		.table-stack,
		.signature-grid {
			grid-template-columns: 1fr;
		}

		.benchmark-hero {
			padding: 0.94rem;
		}

		.hero-meta-card {
			padding: 0.76rem;
		}
	}
</style>
