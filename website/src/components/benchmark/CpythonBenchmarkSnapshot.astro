---
import { existsSync, readFileSync } from "node:fs";
import path from "node:path";

type RankedRow = {
	name?: string;
	count?: number;
};

type BenchmarkSummary = {
	generated_at_utc?: string;
	run_state?: {
		status?: string;
		completed_at_utc?: string;
		elapsed_total_secs?: number;
	};
	host?: {
		system?: string;
		machine?: string;
	};
	dispatch?: {
		aggregate_batch_elapsed_secs?: number;
	};
	inventory?: {
		entry_count?: number;
		discoverable_case_count?: number;
		host_skip_entries?: number;
	};
	results?: {
		module_statuses?: Record<string, number>;
		case_outcomes?: Record<string, number>;
		subtest_outcomes?: Record<string, number>;
	};
};

type DerivedSummary = {
	top_modules_by_nonpass?: RankedRow[];
	failure_signatures?: {
		case?: RankedRow[];
		subtest?: RankedRow[];
	};
};

const locateBenchmarkFile = (name: string): string | null => {
	const candidates = [
		path.resolve(process.cwd(), "..", "perf", "cpython_compat_benchmark_latest", name),
		path.resolve(process.cwd(), "perf", "cpython_compat_benchmark_latest", name),
	];
	for (const candidate of candidates) {
		if (existsSync(candidate)) {
			return candidate;
		}
	}
	return null;
};

const summaryPath = locateBenchmarkFile("summary.json");
const derivedPath = locateBenchmarkFile("derived_summary.json");

let summary: BenchmarkSummary | null = null;
let derived: DerivedSummary | null = null;
let loadError: string | null = null;

try {
	if (!summaryPath) {
		throw new Error("summary.json not found under perf/cpython_compat_benchmark_latest");
	}
	summary = JSON.parse(readFileSync(summaryPath, "utf8"));
	if (derivedPath) {
		derived = JSON.parse(readFileSync(derivedPath, "utf8"));
	}
} catch (error) {
	loadError = error instanceof Error ? error.message : String(error);
}

const formatNumber = (value: number | null | undefined): string =>
	typeof value === "number" ? new Intl.NumberFormat("en-US").format(value) : "n/a";

const formatPercent = (value: number, total: number, digits = 1): string => {
	if (!total) {
		return "0%";
	}
	return `${((value / total) * 100).toFixed(digits)}%`;
};

const formatDuration = (value: number | null | undefined): string => {
	if (typeof value !== "number" || Number.isNaN(value)) {
		return "n/a";
	}
	const totalSeconds = Math.round(value);
	const hours = Math.floor(totalSeconds / 3600);
	const minutes = Math.floor((totalSeconds % 3600) / 60);
	const seconds = totalSeconds % 60;
	if (hours > 0) {
		return `${hours}h ${minutes}m ${seconds}s`;
	}
	if (minutes > 0) {
		return `${minutes}m ${seconds}s`;
	}
	return `${seconds}s`;
};

const formatTimestamp = (value: string | null | undefined): string => {
	if (!value) {
		return "n/a";
	}
	const date = new Date(value);
	if (Number.isNaN(date.getTime())) {
		return value;
	}
	return new Intl.DateTimeFormat("en-US", {
		dateStyle: "medium",
		timeStyle: "short",
		timeZone: "UTC",
	}).format(date);
};

const shorten = (value: string | undefined, limit = 86): string => {
	if (!value) {
		return "n/a";
	}
	return value.length > limit ? `${value.slice(0, limit - 1)}…` : value;
};

const humanHostName = (value: string | undefined): string | undefined => {
	if (!value) {
		return value;
	}
	if (value === "Darwin") {
		return "macOS";
	}
	return value;
};

const summaryAvailable = summary !== null;
const caseOutcomes = summary?.results?.case_outcomes ?? {};
const subtestOutcomes = summary?.results?.subtest_outcomes ?? {};
const suiteStatuses = summary?.results?.module_statuses ?? {};

const discoverableEntries = summary?.inventory?.entry_count ?? 0;
const discoverableCases = summary?.inventory?.discoverable_case_count ?? 0;
const hostSkips = summary?.inventory?.host_skip_entries ?? 0;

const executedCases = summary?.results?.executed_case_count ?? 0;
const passedCases = caseOutcomes.passed ?? 0;
const executedSubtests = summary?.results?.executed_subtest_count ?? 0;
const passedSubtests = subtestOutcomes.passed ?? 0;

const redSuites = suiteStatuses.failed ?? 0;
const passingSuites = suiteStatuses.passed ?? 0;
const blockedSuites = (suiteStatuses.load_error ?? 0) + (suiteStatuses.process_error ?? 0) + (suiteStatuses.process_timeout ?? 0);
const runtimeSkippedSuites = suiteStatuses.skipped ?? 0;

const unreachedCases = Math.max(discoverableCases - executedCases, 0);
const reachedButNotGreenCases = Math.max(executedCases - passedCases, 0);

const updatedAt = summary?.run_state?.completed_at_utc ?? summary?.generated_at_utc ?? null;
const lastFullRun = summary?.dispatch?.aggregate_batch_elapsed_secs ?? null;
const hostLabel = [humanHostName(summary?.host?.system), summary?.host?.machine].filter(Boolean).join(" ") || "Current host";

const headlineCards = summary
	? [
			{
				eyebrow: "Passing today",
				value: formatPercent(passedCases, discoverableCases),
				body: `${formatNumber(passedCases)} discoverable CPython cases are already green on this host.`,
			},
			{
				eyebrow: "Execution reach",
				value: formatPercent(executedCases, discoverableCases),
				body: `${formatNumber(executedCases)} cases currently reach a case-level result instead of failing before execution.`,
			},
			{
				eyebrow: "Subtest pass rate",
				value: formatPercent(passedSubtests, executedSubtests),
				body: `${formatNumber(passedSubtests)} captured subtests are currently passing.`,
			},
			{
				eyebrow: "Current inventory",
				value: formatNumber(discoverableCases),
				body: `Across ${formatNumber(discoverableEntries)} discoverable CPython test suites in the latest ${hostLabel} run.`,
			},
	  ]
	: [];

const suiteCards = summary
	? [
			{
				label: "Passing suites",
				value: formatNumber(passingSuites),
				body: "Suites that currently run through and finish green.",
			},
			{
				label: "Red suites",
				value: formatNumber(redSuites),
				body: "Suites that execute far enough to assert behavior and still mismatch CPython.",
			},
			{
				label: "Blocked suites",
				value: formatNumber(blockedSuites),
				body: "Suites still stopped by load failures, crashes, or timeouts before they become useful parity signals.",
			},
			{
				label: "Host-specific skips",
				value: formatNumber(hostSkips),
				body: "Discoverable entries intentionally omitted because this platform lacks the required surface.",
			},
	  ]
	: [];

const topModules = (derived?.top_modules_by_nonpass ?? []).slice(0, 8);
const caseSignatures = (derived?.failure_signatures?.case ?? []).slice(0, 8);
const subtestSignatures = derived?.failure_signatures?.subtest ?? [];

const moduleCount = (name: string): number | null => {
	const row = (derived?.top_modules_by_nonpass ?? []).find((item) => item.name === name);
	return typeof row?.count === "number" ? row.count : null;
};

const signatureCount = (pattern: RegExp, source: RankedRow[] = derived?.failure_signatures?.case ?? []): RankedRow | null =>
	source.find((row) => pattern.test(row.name ?? "")) ?? null;

const evidenceRow = (label: string, count: number | null): string | null => (typeof count === "number" ? `${label} (${formatNumber(count)})` : null);
const evidenceSig = (pattern: RegExp, fallback: string, source?: RankedRow[]): string | null => {
	const row = signatureCount(pattern, source);
	return row ? `${shorten(row.name)} (${formatNumber(row.count)})` : fallback ? fallback : null;
};

const gapThemes = [
	{
		title: "Socket and selector behavior",
		body: "Low-level networking still accounts for one of the largest remaining parity gaps.",
		highlights: [
			evidenceRow("test.test_socket", moduleCount("test.test_socket")),
			evidenceRow("test.test_selectors", moduleCount("test.test_selectors")),
			evidenceSig(/socket.*bind/i, "", derived?.failure_signatures?.case),
			evidenceSig(/recvmsg|sendmsg/i, "", derived?.failure_signatures?.case),
		].filter(Boolean),
	},
	{
		title: "Filesystem and OS edge cases",
		body: "Platform-facing stdlib behavior is still leaving a visible amount of CPython coverage on the table.",
		highlights: [
			evidenceRow("test.test_os", moduleCount("test.test_os")),
			evidenceRow("test.test_mailbox", moduleCount("test.test_mailbox")),
			evidenceSig(/DirEntry.*is_junction/i, "", derived?.failure_signatures?.case),
			evidenceSig(/listdir failed/i, "", derived?.failure_signatures?.case),
		].filter(Boolean),
	},
	{
		title: "C-backed stdlib helpers",
		body: "Several extension-backed stdlib surfaces still fail because key helper modules or symbols are missing.",
		highlights: [
			evidenceRow("test.test_functools", moduleCount("test.test_functools")),
			evidenceRow("test.test_codecs", moduleCount("test.test_codecs")),
			evidenceSig(/requires the C _functools module/i, "", derived?.failure_signatures?.case),
			evidenceSig(/_testclinic is missing|ascii_encode|new_instruction_sequence|xmlparser/i, "", derived?.failure_signatures?.case),
		].filter(Boolean),
	},
	{
		title: "Compiler, parser, and traceback fidelity",
		body: "A smaller but still important slice of failures is clustered around compiler and diagnostic edge cases.",
		highlights: [
			evidenceRow("test.test_traceback", moduleCount("test.test_traceback")),
			evidenceRow("test.test_call", moduleCount("test.test_call")),
			evidenceSig(/_varname_from_oparg/i, "", derived?.failure_signatures?.subtest),
			evidenceSig(/Constant.*kind|SyntaxError not raised/i, "", subtestSignatures),
		].filter(Boolean),
	},
].filter((theme) => theme.highlights.length > 0);

const progressSegments = [
	{
		label: "Passing cases",
		value: passedCases,
		className: "segment-passing",
		percent: discoverableCases ? (passedCases / discoverableCases) * 100 : 0,
	},
	{
		label: "Reached but still failing",
		value: reachedButNotGreenCases,
		className: "segment-red",
		percent: discoverableCases ? (reachedButNotGreenCases / discoverableCases) * 100 : 0,
	},
	{
		label: "Not yet reaching case execution",
		value: unreachedCases,
		className: "segment-unreached",
		percent: discoverableCases ? (unreachedCases / discoverableCases) * 100 : 0,
	},
];
---

{
	!summaryAvailable ? (
		<section class="benchmark-fallback" aria-live="polite">
			<p class="panel-kicker">Snapshot unavailable</p>
			<h2>The benchmark UI is ready, but this build did not include the latest artifact.</h2>
			<p>
				This page reads from <code>perf/cpython_compat_benchmark_latest</code> at build time. If that snapshot is
				not present, the page falls back to this empty state.
			</p>
			{loadError && <p class="fallback-error">Last load error: <code>{loadError}</code></p>}
		</section>
	) : (
		<div class="benchmark-snapshot">
			<section class="snapshot-frame">
				<div class="snapshot-meta">
					<div>
						<p class="panel-kicker">Latest snapshot</p>
						<h2>How far along is PYRS on the discoverable CPython suite for this platform?</h2>
					</div>
					<div class="snapshot-meta-rail">
						<div class="meta-pill">
							<span>Platform</span>
							<strong>{hostLabel}</strong>
						</div>
						<div class="meta-pill">
							<span>Updated</span>
							<strong>{formatTimestamp(updatedAt)} UTC</strong>
						</div>
						<div class="meta-pill">
							<span>Last full run</span>
							<strong>{formatDuration(lastFullRun)}</strong>
						</div>
					</div>
				</div>

				<div class="headline-grid">
					{headlineCards.map((card) => (
						<article class="headline-card">
							<p class="headline-eyebrow">{card.eyebrow}</p>
							<strong>{card.value}</strong>
							<p>{card.body}</p>
						</article>
					))}
				</div>
			</section>

			<section class="coverage-story" aria-labelledby="coverage-story-title">
				<div class="section-head">
					<p class="panel-kicker">Coverage shape</p>
					<h3 id="coverage-story-title">A useful way to read the current snapshot</h3>
					<p>
						Not every discoverable case is reachable yet. The bar below separates what already passes, what is
						reached but still red, and what still fails before meaningful case execution.
					</p>
				</div>
				<div class="story-bar" aria-hidden="true">
					{progressSegments.map((segment) => (
						<div class:list={["story-segment", segment.className]} style={`width:${segment.percent}%`} />
					))}
				</div>
				<ul class="story-legend">
					{progressSegments.map((segment) => (
						<li class="story-legend-item">
							<span class:list={["legend-swatch", segment.className]} />
							<div>
								<strong>{segment.label}</strong>
								<p>
									{formatNumber(segment.value)} cases, {formatPercent(segment.value, discoverableCases)}
								</p>
							</div>
						</li>
					))}
				</ul>
			</section>

			<section class="suite-summary" aria-labelledby="suite-summary-title">
				<div class="section-head">
					<p class="panel-kicker">Suite-level picture</p>
					<h3 id="suite-summary-title">What users should take away from the current run</h3>
				</div>
				<div class="suite-grid">
					{suiteCards.map((card) => (
						<article class="suite-card">
							<p class="suite-label">{card.label}</p>
							<strong>{card.value}</strong>
							<p>{card.body}</p>
						</article>
					))}
				</div>
				<p class="suite-footnote">
					{formatNumber(runtimeSkippedSuites)} additional suites currently finish as runtime skips after they begin executing.
				</p>
			</section>

			{gapThemes.length > 0 && (
				<section class="theme-section" aria-labelledby="theme-section-title">
					<div class="section-head">
						<p class="panel-kicker">Major remaining themes</p>
						<h3 id="theme-section-title">The biggest compatibility gaps are clustered, not random</h3>
						<p>
							These are the broad areas most obviously holding the benchmark back right now, based on the highest-impact suites
							and repeated failure signatures in the latest run.
						</p>
					</div>
					<div class="theme-grid">
						{gapThemes.map((theme) => (
							<article class="theme-card">
								<h4>{theme.title}</h4>
								<p>{theme.body}</p>
								<ul>
									{theme.highlights.map((highlight) => (
										<li>{highlight}</li>
									))}
								</ul>
							</article>
						))}
					</div>
				</section>
			)}

			<section class="rank-section" aria-labelledby="rank-section-title">
				<div class="section-head">
					<p class="panel-kicker">Where the work is concentrated</p>
					<h3 id="rank-section-title">The current benchmark is being dragged down by a relatively small set of large clusters</h3>
				</div>
				<div class="rank-grid">
					<article class="rank-card">
						<h4>Biggest suites still red</h4>
						<ol class="rank-list">
							{topModules.map((row, index) => (
								<li>
									<span class="rank-number">{String(index + 1).padStart(2, "0")}</span>
									<div class="rank-copy">
										<strong><code>{row.name ?? "n/a"}</code></strong>
										<p>{formatNumber(row.count)} non-pass events</p>
									</div>
								</li>
							))}
						</ol>
					</article>
					<article class="rank-card">
						<h4>Most common failure patterns</h4>
						<ul class="pattern-list">
							{caseSignatures.map((row) => (
								<li>
									<span>{shorten(row.name)}</span>
									<strong>{formatNumber(row.count)}</strong>
								</li>
							))}
						</ul>
					</article>
				</div>
			</section>
		</div>
	)
}

<style>
	.benchmark-snapshot,
	.benchmark-fallback {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.snapshot-frame,
	.coverage-story,
	.suite-summary,
	.theme-section,
	.rank-card,
	.benchmark-fallback {
		border: 1px solid rgba(86, 58, 44, 0.82);
		border-radius: 1rem;
		background: linear-gradient(180deg, rgba(25, 16, 12, 0.92), rgba(14, 9, 7, 0.96));
		box-shadow: 0 14px 34px rgba(6, 2, 1, 0.18);
	}

	.snapshot-frame {
		padding: 1.25rem;
		background:
			radial-gradient(circle at top right, rgba(218, 141, 92, 0.16), transparent 34%),
			linear-gradient(180deg, rgba(29, 18, 14, 0.96), rgba(14, 9, 7, 0.98));
	}

	.snapshot-meta {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(20rem, 0.9fr);
		gap: 1rem;
		align-items: start;
	}

	.panel-kicker,
	.headline-eyebrow,
	.suite-label,
	.section-head p {
		margin: 0;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #d7a280;
	}

	.snapshot-meta h2,
	.section-head h3,
	.rank-card h4,
	.theme-card h4,
	.benchmark-fallback h2 {
		margin: 0.6rem 0 0;
		line-height: 1.08;
		letter-spacing: -0.03em;
		color: #f8eee8;
	}

	.snapshot-meta h2 {
		max-width: 18ch;
		font-size: clamp(1.5rem, 3.5vw, 2.2rem);
	}

	.snapshot-meta-rail {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.68rem;
	}

	.meta-pill {
		padding: 0.84rem 0.88rem;
		border-radius: 0.84rem;
		background: rgba(36, 22, 17, 0.86);
		border: 1px solid rgba(104, 71, 52, 0.68);
	}

	.meta-pill span {
		display: block;
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #b8917a;
	}

	.meta-pill strong {
		display: block;
		margin-top: 0.34rem;
		font-size: 0.95rem;
		line-height: 1.35;
		color: #fff2ea;
	}

	.headline-grid,
	.suite-grid,
	.theme-grid,
	.rank-grid {
		display: grid;
		gap: 0.9rem;
	}

	.headline-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
		margin-top: 1rem;
	}

	.headline-card,
	.suite-card,
	.theme-card {
		padding: 1rem;
		border-radius: 0.92rem;
		border: 1px solid rgba(91, 61, 46, 0.72);
		background: rgba(23, 15, 11, 0.82);
	}

	.headline-card strong,
	.suite-card strong {
		display: block;
		margin-top: 0.5rem;
		font-size: clamp(1.35rem, 2.2vw, 1.85rem);
		line-height: 1;
		letter-spacing: -0.04em;
		color: #fff3eb;
	}

	.headline-card p:last-child,
	.suite-card p:last-child,
	.theme-card p,
	.section-head p:last-child,
	.benchmark-fallback p {
		margin: 0.72rem 0 0;
		color: var(--text-muted);
		line-height: 1.58;
		font-size: 0.93rem;
		max-width: 58ch;
	}

	.coverage-story,
	.suite-summary,
	.theme-section {
		padding: 1.15rem;
	}

	.story-bar {
		display: flex;
		width: 100%;
		height: 1rem;
		margin-top: 1rem;
		border-radius: 999px;
		overflow: hidden;
		background: rgba(61, 40, 31, 0.48);
		border: 1px solid rgba(93, 62, 48, 0.68);
	}

	.story-segment {
		min-width: 0;
	}

	.segment-passing {
		background: linear-gradient(90deg, #efb27d, #e88e53);
	}

	.segment-red {
		background: linear-gradient(90deg, #b4604d, #8a4138);
	}

	.segment-unreached {
		background: linear-gradient(90deg, #4b3429, #35231c);
	}

	.story-legend {
		list-style: none;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
		margin: 0.95rem 0 0;
		padding: 0;
	}

	.story-legend-item {
		display: flex;
		gap: 0.72rem;
		align-items: flex-start;
		padding: 0.85rem 0.88rem;
		border-radius: 0.84rem;
		background: rgba(22, 14, 10, 0.72);
		border: 1px solid rgba(82, 56, 43, 0.68);
	}

	.legend-swatch {
		display: block;
		width: 0.82rem;
		height: 0.82rem;
		margin-top: 0.18rem;
		border-radius: 999px;
		flex: 0 0 auto;
	}

	.story-legend-item strong,
	.rank-copy strong {
		display: block;
		color: #f8eee8;
		font-size: 0.94rem;
		line-height: 1.35;
	}

	.story-legend-item p,
	.rank-copy p,
	.suite-footnote,
	.theme-card li {
		margin: 0.26rem 0 0;
		color: var(--text-muted);
		font-size: 0.87rem;
		line-height: 1.52;
	}

	.suite-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
		margin-top: 0.95rem;
	}

	.suite-footnote {
		margin: 0.9rem 0 0;
	}

	.theme-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		margin-top: 0.95rem;
	}

	.theme-card ul {
		margin: 0.9rem 0 0;
		padding-left: 1rem;
	}

	.rank-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.rank-card {
		padding: 1.15rem;
	}

	.rank-list,
	.pattern-list {
		list-style: none;
		margin: 1rem 0 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.62rem;
	}

	.rank-list li,
	.pattern-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.8rem;
		padding: 0.82rem 0.88rem;
		border-radius: 0.84rem;
		background: rgba(22, 14, 10, 0.76);
		border: 1px solid rgba(82, 56, 43, 0.68);
	}

	.rank-number {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		flex: 0 0 auto;
		border-radius: 0.65rem;
		background: rgba(224, 145, 94, 0.14);
		border: 1px solid rgba(220, 136, 81, 0.32);
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.8rem;
		font-weight: 600;
		color: #edb183;
	}

	.rank-copy code {
		font-size: 0.84rem;
	}

	.pattern-list li {
		justify-content: space-between;
