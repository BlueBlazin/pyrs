---
interface Props {
	label: string;
}

const { label } = Astro.props;
---

<span class="highlight-chip">{label}</span>

<style>
	.highlight-chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-size: 0.67rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-weight: 700;
		color: #241108;
		background: linear-gradient(135deg, #dda06f 0%, #cb7647 100%);
		border: 1px solid rgba(203, 118, 71, 0.42);
		border-radius: 999px;
		padding: 0.21rem 0.44rem;
		white-space: nowrap;
	}
</style>
