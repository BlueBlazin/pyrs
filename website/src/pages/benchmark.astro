---
import ButtonLink from "../components/ButtonLink.astro";
import CpythonBenchmarkSnapshot from "../components/docs/CpythonBenchmarkSnapshot.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
	title="PYRS | CPython Test Benchmark"
	description="Product-facing CPython 3.14 compatibility benchmark snapshot for PYRS."
>
	<section class="benchmark-page">
		<header class="benchmark-intro">
			<p class="benchmark-kicker">Compatibility Benchmark</p>
			<h1>CPython test-suite progress, shown as a public product snapshot.</h1>
			<p class="benchmark-lead">
				PYRS runs the discoverable CPython 3.14 test-suite entries on the current host and records both
				case-level and subtest-level outcomes. This page is the user-facing benchmark surface, separate from
				internal CI and development probes.
			</p>
			<div class="benchmark-actions">
				<ButtonLink href="/docs/compatibility/" variant="secondary">Open Compatibility Docs</ButtonLink>
				<a class="benchmark-inline-link" href="https://github.com/BlueBlazin/pyrs" rel="noreferrer" target="_blank">
					View repository
				</a>
			</div>
		</header>

		<section class="benchmark-snapshot">
			<CpythonBenchmarkSnapshot />
		</section>
	</section>
</SiteLayout>

<style>
	.benchmark-page {
		display: flex;
		flex-direction: column;
		gap: 1.4rem;
		padding-top: 0.2rem;
	}

	.benchmark-intro {
		padding: 1.35rem 1.4rem;
		border: 1px solid rgba(87, 58, 41, 0.96);
		border-radius: 1rem;
		background:
			radial-gradient(circle at top right, rgba(233, 125, 70, 0.18), transparent 36%),
			linear-gradient(180deg, rgba(24, 14, 11, 0.95), rgba(13, 8, 7, 0.96));
		box-shadow: 0 18px 44px rgba(4, 2, 1, 0.28);
	}

	.benchmark-kicker {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.11em;
		text-transform: uppercase;
		color: #e0a177;
	}

	.benchmark-intro h1 {
		margin: 0.68rem 0 0;
		max-width: 16ch;
		font-size: clamp(2rem, 5vw, 3.4rem);
		line-height: 0.98;
		letter-spacing: -0.05em;
		text-wrap: balance;
	}

	.benchmark-lead {
		margin: 0.96rem 0 0;
		max-width: 66ch;
		color: #c7b4ab;
		font-size: 1rem;
		line-height: 1.68;
	}

	.benchmark-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.9rem;
		margin-top: 1.2rem;
	}

	.benchmark-inline-link {
		color: #f0d2bf;
		text-decoration: none;
		font-size: 0.92rem;
		font-weight: 600;
	}

	.benchmark-inline-link:hover {
		color: #fff1e6;
	}

	.benchmark-inline-link:focus-visible {
		outline: 2px solid rgba(255, 186, 137, 0.92);
		outline-offset: 2px;
		border-radius: 0.36rem;
	}

	.benchmark-snapshot {
		padding-bottom: 1rem;
	}

	@media (max-width: 760px) {
		.benchmark-intro {
			padding: 1.05rem 1rem;
		}

		.benchmark-intro h1 {
			max-width: none;
			font-size: clamp(1.86rem, 10vw, 2.55rem);
		}
	}
</style>
