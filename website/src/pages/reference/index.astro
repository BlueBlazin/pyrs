---
import DocsLayout from "../../layouts/DocsLayout.astro";
---

<DocsLayout
	title="PYRS Reference | CLI and Environment"
	description="Reference documentation for PYRS command-line modes, flags, and environment variables."
	active="reference"
>
	<section class="page-hero">
		<p class="eyebrow">Reference</p>
		<h1>CLI modes, startup flags, and environment variables.</h1>
		<p class="lede">
			This page is based on the current command-line implementation in `src/cli/mod.rs` and
			runtime behavior used by the project test harness.
		</p>
	</section>

	<section class="ref-section">
		<h2>Invocation Modes</h2>
		<div class="table-wrap">
			<table>
				<thead>
					<tr>
						<th>Command</th>
						<th>Behavior</th>
					</tr>
				</thead>
				<tbody>
					<tr>
						<td><code>pyrs</code></td>
						<td>Start interactive REPL (or read from stdin when piped).</td>
					</tr>
					<tr>
						<td><code>pyrs path/to/script.py</code></td>
						<td>Run a Python source file.</td>
					</tr>
					<tr>
						<td><code>pyrs path/to/module.pyc</code></td>
						<td>Run a CPython bytecode file.</td>
					</tr>
					<tr>
						<td><code>pyrs -c "code"</code></td>
						<td>Execute inline source passed on the command line.</td>
					</tr>
				</tbody>
			</table>
		</div>
	</section>

	<section class="ref-section">
		<h2>CLI Flags</h2>
		<div class="table-wrap">
			<table>
				<thead>
					<tr>
						<th>Flag</th>
						<th>Behavior</th>
					</tr>
				</thead>
				<tbody>
					<tr>
						<td><code>-h</code>, <code>--help</code></td>
						<td>Print CLI usage help.</td>
					</tr>
					<tr>
						<td><code>-V</code>, <code>--version</code></td>
						<td>Print interpreter version.</td>
					</tr>
					<tr>
						<td><code>--ast path.py</code></td>
						<td>Print parsed AST for the given source file.</td>
					</tr>
					<tr>
						<td><code>--bytecode path.py</code></td>
						<td>Print bytecode disassembly for the source file.</td>
					</tr>
					<tr>
						<td><code>-S</code>, <code>--no-site</code></td>
						<td>Disable automatic site import at startup.</td>
					</tr>
					<tr>
						<td><code>-W &lt;option&gt;</code>, <code>-Woption</code></td>
						<td>Configure warning filters.</td>
					</tr>
					<tr>
						<td><code>-X no_debug_ranges</code></td>
						<td>Disable traceback caret range debug metadata.</td>
					</tr>
					<tr>
						<td><code>-X tracemalloc</code>, <code>-X tracemalloc=&lt;N&gt;</code></td>
						<td>Enable tracemalloc startup configuration.</td>
					</tr>
					<tr>
						<td><code>-I</code>, <code>-E</code>, <code>-u</code>, <code>-B</code></td>
						<td>Accepted CPython-compat startup flags (`-I`/`-E` disable env-based config).</td>
					</tr>
				</tbody>
			</table>
		</div>
	</section>

	<section class="ref-section">
		<h2>Environment Variables</h2>
		<div class="table-wrap">
			<table>
				<thead>
					<tr>
						<th>Variable</th>
						<th>Purpose</th>
					</tr>
				</thead>
				<tbody>
					<tr>
						<td><code>PYRS_CPYTHON_LIB</code></td>
						<td>Set explicit CPython stdlib root for imports.</td>
					</tr>
					<tr>
						<td><code>PYRS_REPL_THEME</code></td>
						<td>Set REPL theme mode: <code>auto</code>, <code>dark</code>, or <code>light</code>.</td>
					</tr>
					<tr>
						<td><code>PYTHONWARNINGS</code></td>
						<td>Default warning filters consumed by startup warning configuration.</td>
					</tr>
					<tr>
						<td><code>PYTHONPATH</code>, <code>PYTHONHOME</code></td>
						<td>Participate in stdlib/module path resolution.</td>
					</tr>
					<tr>
						<td><code>COLORFGBG</code></td>
						<td>Used for auto light/dark terminal color tuning in CLI output and REPL theme resolution.</td>
					</tr>
				</tbody>
			</table>
		</div>
	</section>
</DocsLayout>

<style>
	.page-hero {
		padding: 0.6rem 0 0.25rem;
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		color: var(--accent-2);
		letter-spacing: 0.09em;
		text-transform: uppercase;
		font-size: 0.76rem;
		font-weight: 600;
	}

	h1 {
		margin: 0;
		font-size: clamp(1.8rem, 5vw, 2.5rem);
		line-height: 1.09;
		letter-spacing: -0.01em;
	}

	.lede {
		margin: 0.95rem 0 0;
		max-width: 72ch;
		color: var(--text-muted);
		line-height: 1.56;
	}

	.ref-section {
		margin-top: 1.35rem;
		border: 1px solid var(--line);
		border-radius: 0.92rem;
		background: rgba(18, 12, 10, 0.72);
		padding: 1rem;
	}

	.ref-section h2 {
		margin: 0;
		font-size: 1.2rem;
	}

	.table-wrap {
		margin-top: 0.76rem;
		overflow-x: auto;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		min-width: 680px;
	}

	th,
	td {
		padding: 0.68rem 0.7rem;
		text-align: left;
		vertical-align: top;
		font-size: 0.88rem;
		line-height: 1.5;
	}

	th {
		color: #f4e6dc;
		font-weight: 600;
		border-bottom: 1px solid #493225;
		background: rgba(8, 6, 5, 0.52);
	}

	td {
		color: var(--text-muted);
		border-bottom: 1px solid rgba(73, 50, 37, 0.45);
	}

	tr:last-child td {
		border-bottom: none;
	}

	code {
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.84em;
		color: #f0ddcf;
	}
</style>
