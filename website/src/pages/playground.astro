---
import SiteLayout from "../layouts/SiteLayout.astro";
import HighlightChip from "../components/ui/HighlightChip.astro";
---

<SiteLayout
	title="PYRS Playground | Browser REPL"
	description="Run PYRS in a browser REPL powered by wasm."
	navContext="playground"
	noindex={true}
>
	<section class="playground-page">
		<header class="playground-header">
			<div class="playground-kicker-row">
				<p class="playground-kicker">WASM Playground</p>
				<HighlightChip label="Experimental" />
			</div>
			<h1>Run PYRS in your browser</h1>
			<p>
				The runtime initializes automatically when this page loads. Type directly into the REPL,
				press <kbd>Enter</kbd> to run, and use <kbd>Shift</kbd> + <kbd>Enter</kbd> for multiline input.
			</p>
		</header>

		<div class="playground-status" id="playground-status-shell" data-state="idle" aria-live="polite">
			<span class="status-dot" aria-hidden="true"></span>
			<span id="playground-status-text">Initializing runtime…</span>
		</div>

		<section class="playground-shell" aria-label="Browser REPL">
			<div class="playground-transcript" id="playground-transcript"></div>
			<form class="playground-input-row" id="playground-form" autocomplete="off">
				<label for="playground-input" class="sr-only">Python REPL input</label>
				<span class="playground-prompt" aria-hidden="true">&gt;&gt;&gt;</span>
				<textarea
					id="playground-input"
					name="source"
					spellcheck="false"
					autocapitalize="off"
					autocorrect="off"
					rows="1"
					placeholder="Try: 1 + 1"
				></textarea>
				<button type="submit" id="playground-run">Run</button>
			</form>
		</section>

		<div class="playground-actions">
			<button type="button" id="playground-clear">Clear Output</button>
			<button type="button" id="playground-reset">Reset Session</button>
		</div>
	</section>

	<script is:inline>
		const statusShell = document.getElementById("playground-status-shell");
		const statusText = document.getElementById("playground-status-text");
		const transcriptEl = document.getElementById("playground-transcript");
		const formEl = document.getElementById("playground-form");
		const runButton = document.getElementById("playground-run");
		const inputEl = document.getElementById("playground-input");
		const clearButton = document.getElementById("playground-clear");
		const resetButton = document.getElementById("playground-reset");

		const baseUrl = import.meta.env.BASE_URL || "/";
		const wasmEntrypoint = `${baseUrl.replace(/\/?$/, "/")}wasm/pyrs.js`;

		let runtimeModule = null;
		let runtimeLoadPromise = null;
		let replSession = null;
		let commandIndex = 1;

		const readField = (object, key) => {
			if (!object) return undefined;
			const value = object[key];
			if (typeof value === "function") {
				try {
					return value.call(object);
				} catch {
					return undefined;
				}
			}
			return value;
		};

		const appendTranscriptLine = (text, kind = "output") => {
			if (!(transcriptEl instanceof HTMLElement)) return;
			const line = document.createElement("div");
			line.className = `transcript-line transcript-line-${kind}`;
			line.textContent = text;
			transcriptEl.appendChild(line);
			requestAnimationFrame(() => {
				transcriptEl.scrollTop = transcriptEl.scrollHeight;
			});
		};

		const appendPromptInput = (source) => {
			const lines = source.split("\n");
			lines.forEach((line, index) => {
				const prompt = index === 0 ? ">>>" : "...";
				appendTranscriptLine(`${prompt} ${line}`, "input");
			});
		};

		const setStatus = (state, message) => {
			if (statusShell instanceof HTMLElement) {
				statusShell.dataset.state = state;
			}
			if (statusText instanceof HTMLElement) {
				statusText.textContent = message;
			}
		};

		const setBusy = (busy) => {
			if (runButton instanceof HTMLButtonElement) {
				runButton.disabled = busy;
			}
			if (inputEl instanceof HTMLTextAreaElement) {
				inputEl.disabled = busy;
			}
		};

		const resizeInput = () => {
			if (!(inputEl instanceof HTMLTextAreaElement)) return;
			inputEl.style.height = "0px";
			const nextHeight = Math.min(Math.max(inputEl.scrollHeight, 40), 220);
			inputEl.style.height = `${nextHeight}px`;
		};

		const summarizeExecutionResult = (result) => {
			const phase = readField(result, "phase") || "unknown";
			const success = Boolean(readField(result, "success"));
			const stdout = readField(result, "stdout") || "";
			const stderr = readField(result, "stderr") || "";
			const error = readField(result, "error") || "";
			const blockerKey = readField(result, "blocker_key") || "";
			const line = Number(readField(result, "line") || 0);
			const column = Number(readField(result, "column") || 0);
			return {
				phase,
				success,
				stdout,
				stderr,
				error,
				blockerKey,
				line,
				column,
			};
		};

		const renderExecutionResult = (result) => {
			const summary = summarizeExecutionResult(result);
			if (summary.stdout.trim().length > 0) {
				summary.stdout
					.split("\n")
					.filter((line) => line.length > 0)
					.forEach((line) => appendTranscriptLine(line, "stdout"));
			}
			if (summary.stderr.trim().length > 0) {
				summary.stderr
					.split("\n")
					.filter((line) => line.length > 0)
					.forEach((line) => appendTranscriptLine(line, "stderr"));
			}
			if (!summary.success && summary.error && summary.stderr.trim().length === 0) {
				appendTranscriptLine(summary.error, "stderr");
			}
			if (!summary.success && summary.blockerKey) {
				appendTranscriptLine(`blocker: ${summary.blockerKey}`, "meta");
			}
			if (summary.line > 0) {
				appendTranscriptLine(`at line ${summary.line}, column ${Math.max(summary.column, 1)}`, "meta");
			}
			if (summary.success && summary.stdout.trim().length === 0 && summary.stderr.trim().length === 0) {
				appendTranscriptLine(`${summary.phase}`, "meta");
			}
		};

		const getReplSession = () => {
			if (!runtimeModule) return null;
			if (replSession) return replSession;
			if (typeof runtimeModule.WasmReplSession === "function") {
				replSession = new runtimeModule.WasmReplSession();
				return replSession;
			}
			if (typeof runtimeModule.WasmSession === "function") {
				replSession = new runtimeModule.WasmSession();
				return replSession;
			}
			return null;
		};

		const ensureRuntimeLoaded = async () => {
			if (runtimeModule) {
				return true;
			}
			if (runtimeLoadPromise) {
				return runtimeLoadPromise;
			}
			runtimeLoadPromise = (async () => {
				setStatus("loading", "Loading runtime…");
				try {
					const moduleRef = await import(wasmEntrypoint);
					const initExport = moduleRef.default;
					if (typeof initExport === "function") {
						await initExport();
					}
					if (typeof moduleRef.init_wasm_runtime === "function") {
						moduleRef.init_wasm_runtime();
					}
					runtimeModule = moduleRef;
					getReplSession();
					const runtimeInfo =
						typeof moduleRef.wasm_runtime_info === "function"
							? moduleRef.wasm_runtime_info()
							: null;
					const backend = readField(runtimeInfo, "execution_backend") || "unknown";
					const executionEnabled = Boolean(readField(runtimeInfo, "supports_execution"));
					const executionState = executionEnabled ? "ready" : "compile-only";
					setStatus("ready", `Runtime loaded (${executionState})`);
					appendTranscriptLine(
						`# runtime loaded (${backend})`,
						"meta",
					);
					if (!executionEnabled) {
						appendTranscriptLine(
							"# execution backend is currently compile-only in this build",
							"meta",
						);
					}
					return true;
				} catch (error) {
					const message = error instanceof Error ? error.message : String(error);
					setStatus("error", "Runtime failed to load");
					appendTranscriptLine(message, "stderr");
					return false;
				} finally {
					runtimeLoadPromise = null;
				}
			})();
			return runtimeLoadPromise;
		};

		const runSource = async (source) => {
			const normalized = source.trimEnd();
			if (!normalized.trim()) return;
			appendTranscriptLine(`\n#${commandIndex}`, "meta");
			appendPromptInput(normalized);
			commandIndex += 1;
			setBusy(true);
			const loaded = await ensureRuntimeLoaded();
			if (!loaded || !runtimeModule) {
				setBusy(false);
				return;
			}
			try {
				const session = getReplSession();
				if (session && typeof session.execute_input === "function") {
					renderExecutionResult(session.execute_input(normalized));
				} else if (session && typeof session.execute === "function") {
					renderExecutionResult(session.execute(normalized));
				} else if (typeof runtimeModule.execute === "function") {
					renderExecutionResult(runtimeModule.execute(normalized));
				} else {
					appendTranscriptLine("Runtime loaded but no execute entrypoint is available.", "stderr");
				}
			} catch (error) {
				const message = error instanceof Error ? error.message : String(error);
				appendTranscriptLine(message, "stderr");
			} finally {
				setBusy(false);
			}
		};

		if (inputEl instanceof HTMLTextAreaElement) {
			inputEl.addEventListener("keydown", (event) => {
				if (event.key === "Enter" && !event.shiftKey) {
					event.preventDefault();
					if (formEl instanceof HTMLFormElement) {
						formEl.requestSubmit();
					}
				}
			});
			inputEl.addEventListener("input", resizeInput);
			resizeInput();
		}

		if (formEl instanceof HTMLFormElement && inputEl instanceof HTMLTextAreaElement) {
			formEl.addEventListener("submit", async (event) => {
				event.preventDefault();
				const source = inputEl.value;
				inputEl.value = "";
				resizeInput();
				await runSource(source);
				inputEl.focus();
			});
		}

		if (clearButton instanceof HTMLButtonElement) {
			clearButton.addEventListener("click", () => {
				if (transcriptEl instanceof HTMLElement) {
					transcriptEl.innerHTML = "";
				}
				appendTranscriptLine("# transcript cleared", "meta");
			});
		}

		if (resetButton instanceof HTMLButtonElement) {
			resetButton.addEventListener("click", () => {
				const session = getReplSession();
				if (session && typeof session.reset === "function") {
					session.reset();
					appendTranscriptLine("# session reset", "meta");
					commandIndex = 1;
					return;
				}
				appendTranscriptLine("# runtime session reset unavailable", "meta");
			});
		}

		appendTranscriptLine("# loading wasm runtime", "meta");
		ensureRuntimeLoaded().then(() => {
			if (inputEl instanceof HTMLTextAreaElement) {
				inputEl.focus();
			}
		});
	</script>
</SiteLayout>

<style>
	.playground-page {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding-bottom: 2rem;
	}

	.playground-header {
		display: grid;
		gap: 0.72rem;
	}

	.playground-kicker-row {
		display: inline-flex;
		align-items: center;
		gap: 0.46rem;
	}

	.playground-kicker {
		margin: 0;
		font-size: 0.74rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: #f9d3ba;
		font-weight: 700;
	}

	.playground-header h1 {
		margin: 0;
		font-size: clamp(2rem, 3vw, 2.8rem);
		line-height: 1.08;
	}

	.playground-header p {
		margin: 0;
		color: var(--text-muted);
		max-width: 72ch;
		font-size: 1.03rem;
		line-height: 1.62;
	}

	.playground-header kbd {
		font-family: "JetBrains Mono", "SFMono-Regular", ui-monospace, Menlo, monospace;
		font-size: 0.76em;
		padding: 0.12rem 0.34rem;
		border-radius: 0.34rem;
		border: 1px solid rgba(212, 146, 103, 0.44);
		background: rgba(32, 16, 11, 0.72);
		color: #f5d4bd;
	}

	.playground-status {
		display: inline-flex;
		align-items: center;
		gap: 0.54rem;
		width: fit-content;
		padding: 0.43rem 0.72rem;
		border-radius: 999px;
		border: 1px solid rgba(71, 47, 36, 0.9);
		background: rgba(15, 9, 7, 0.68);
		color: #d8c5b6;
		font-size: 0.84rem;
		letter-spacing: 0.01em;
	}

	.status-dot {
		width: 0.52rem;
		height: 0.52rem;
		border-radius: 999px;
		background: #997d6d;
	}

	.playground-status[data-state="loading"] .status-dot {
		background: #f2ad79;
		animation: pulse 1s ease-in-out infinite;
	}

	.playground-status[data-state="ready"] .status-dot {
		background: #5ac98f;
	}

	.playground-status[data-state="error"] .status-dot {
		background: #ff7d70;
	}

	.playground-shell {
		display: flex;
		flex-direction: column;
		width: 100%;
		min-height: 60vh;
		border-radius: 0.94rem;
		border: 1px solid rgba(70, 47, 36, 0.82);
		background: linear-gradient(180deg, rgba(8, 11, 17, 0.96) 0%, rgba(5, 8, 13, 0.98) 100%);
		overflow: hidden;
		box-shadow: 0 12px 50px rgba(0, 0, 0, 0.34);
	}

	.playground-transcript {
		flex: 1;
		padding: 1.12rem 1.22rem 1.2rem;
		overflow-y: auto;
		font-family: "JetBrains Mono", "SFMono-Regular", ui-monospace, Menlo, monospace;
		font-size: 0.95rem;
		line-height: 1.58;
		word-break: break-word;
		background: transparent;
	}

	.transcript-line {
		white-space: pre-wrap;
	}

	.transcript-line + .transcript-line {
		margin-top: 0.28rem;
	}

	.transcript-line-input {
		color: #f8f2ec;
	}

	.transcript-line-stdout {
		color: #d9f3df;
	}

	.transcript-line-stderr {
		color: #ffbab2;
	}

	.transcript-line-meta {
		color: #9aa4b3;
		font-size: 0.85rem;
		letter-spacing: 0.01em;
	}

	.playground-input-row {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: end;
		gap: 0.72rem;
		padding: 0.92rem 1rem;
		border-top: 1px solid rgba(52, 64, 86, 0.88);
		background: linear-gradient(180deg, rgba(14, 26, 47, 0.64) 0%, rgba(11, 22, 41, 0.82) 100%);
	}

	.playground-prompt {
		font-family: "JetBrains Mono", "SFMono-Regular", ui-monospace, Menlo, monospace;
		font-size: 0.92rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: #f0a677;
		padding-bottom: 0.5rem;
	}

	.playground-input-row textarea {
		width: 100%;
		resize: none;
		font-family: "JetBrains Mono", "SFMono-Regular", ui-monospace, Menlo, monospace;
		font-size: 0.95rem;
		line-height: 1.5;
		background: transparent;
		color: #f8f2ec;
		border: none;
		outline: none;
		padding: 0.32rem 0;
		min-height: 2.5rem;
		max-height: 220px;
	}

	.playground-input-row textarea::placeholder {
		color: #8e9db3;
	}

	.playground-input-row button,
	.playground-actions button {
		appearance: none;
		border: 1px solid rgba(113, 143, 198, 0.42);
		background: rgba(25, 46, 83, 0.82);
		color: #e8f0ff;
		border-radius: 0.58rem;
		padding: 0.45rem 0.82rem;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 120ms ease, border-color 120ms ease;
	}

	.playground-input-row button:hover,
	.playground-actions button:hover {
		background: rgba(31, 61, 109, 0.9);
		border-color: rgba(133, 165, 224, 0.64);
	}

	.playground-input-row button:disabled {
		opacity: 0.56;
		cursor: not-allowed;
	}

	.playground-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.56rem;
	}

	.playground-actions button {
		padding: 0.36rem 0.68rem;
		font-size: 0.74rem;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}

	@keyframes pulse {
		0% {
			opacity: 1;
		}
		50% {
			opacity: 0.35;
		}
		100% {
			opacity: 1;
		}
	}

	@media (max-width: 760px) {
		.playground-header h1 {
			font-size: 1.9rem;
		}

		.playground-shell {
			min-height: 55vh;
		}

		.playground-transcript {
			padding: 0.96rem 0.88rem 1rem;
			font-size: 0.88rem;
		}

		.playground-input-row {
			grid-template-columns: auto 1fr;
			row-gap: 0.5rem;
		}

		.playground-input-row button {
			grid-column: 2;
			justify-self: start;
		}
	}
</style>
