---
import SiteLayout from "../layouts/SiteLayout.astro";
import HighlightChip from "../components/ui/HighlightChip.astro";

const baseUrl = import.meta.env.BASE_URL || "/";
const wasmEntrypoint = `${baseUrl.replace(/\/?$/, "/")}wasm/pyrs.js`;
---

<SiteLayout
	title="PYRS Playground | Browser REPL"
	description="Run PYRS in a browser REPL powered by wasm."
	navContext="playground"
	noindex={true}
>
	<section class="playground-page" data-wasm-entrypoint={wasmEntrypoint}>
		<header class="playground-header">
			<div class="playground-kicker-row">
				<p class="playground-kicker">WASM Playground</p>
				<HighlightChip label="Experimental" />
			</div>
			<h1>Browser REPL</h1>
			<p>
				Runtime loads automatically on first visit. Use <kbd>Enter</kbd> to execute and
				<kbd>Shift</kbd> + <kbd>Enter</kbd> for multiline blocks.
			</p>
		</header>

		<div class="playground-status" id="playground-status-shell" data-state="idle" aria-live="polite">
			<span class="status-dot" aria-hidden="true"></span>
			<span id="playground-status-text">Loading runtime…</span>
		</div>

		<section class="playground-shell" aria-label="Browser REPL">
			<div class="playground-shell-bar" aria-hidden="true">
				<div class="playground-shell-lights">
					<span class="light-red"></span>
					<span class="light-yellow"></span>
					<span class="light-green"></span>
				</div>
				<p class="playground-shell-title">PYRS REPL</p>
			</div>

			<div class="playground-transcript" id="playground-transcript"></div>

			<form class="playground-input-row" id="playground-form" autocomplete="off">
				<label for="playground-input" class="sr-only">Python REPL input</label>
				<span class="playground-prompt" aria-hidden="true">&gt;&gt;&gt;</span>
				<textarea
					id="playground-input"
					name="source"
					spellcheck="false"
					autocapitalize="off"
					autocorrect="off"
					rows="1"
					placeholder="Try: 1 + 1"
				></textarea>
			</form>
		</section>

		<div class="playground-actions">
			<button type="button" id="playground-clear">Clear</button>
			<button type="button" id="playground-reset">Reset Session</button>
		</div>
	</section>

	<script is:inline>
		const statusShell = document.getElementById("playground-status-shell");
		const statusText = document.getElementById("playground-status-text");
		const transcriptEl = document.getElementById("playground-transcript");
		const formEl = document.getElementById("playground-form");
		const inputEl = document.getElementById("playground-input");
		const clearButton = document.getElementById("playground-clear");
		const resetButton = document.getElementById("playground-reset");

		const pageRoot = document.querySelector(".playground-page");
		const wasmEntrypoint =
			pageRoot instanceof HTMLElement && pageRoot.dataset.wasmEntrypoint
				? pageRoot.dataset.wasmEntrypoint
				: "/wasm/pyrs.js";

		let runtimeModule = null;
		let runtimeLoadPromise = null;
		let replSession = null;
		let lastRuntimeInfo = null;
		let bannerRendered = false;
		const commandHistory = [];
		let historyIndex = -1;

		const readField = (object, key) => {
			if (!object) return undefined;
			const value = object[key];
			if (typeof value === "function") {
				try {
					return value.call(object);
				} catch {
					return undefined;
				}
			}
			return value;
		};

		const scrollTranscriptToEnd = () => {
			if (!(transcriptEl instanceof HTMLElement)) return;
			requestAnimationFrame(() => {
				transcriptEl.scrollTop = transcriptEl.scrollHeight;
			});
		};

		const appendTranscriptLine = (text, kind = "stdout") => {
			if (!(transcriptEl instanceof HTMLElement)) return;
			const line = document.createElement("div");
			line.className = `transcript-line transcript-line-${kind}`;
			line.textContent = text;
			transcriptEl.appendChild(line);
			scrollTranscriptToEnd();
		};

		const appendPromptLine = (prompt, text) => {
			if (!(transcriptEl instanceof HTMLElement)) return;
			const line = document.createElement("div");
			line.className = "transcript-line transcript-line-input";

			const promptSpan = document.createElement("span");
			promptSpan.className = "transcript-prompt";
			promptSpan.textContent = prompt;

			const codeSpan = document.createElement("span");
			codeSpan.className = "transcript-input-text";
			codeSpan.textContent = text;

			line.appendChild(promptSpan);
			line.appendChild(codeSpan);
			transcriptEl.appendChild(line);
			scrollTranscriptToEnd();
		};

		const appendPromptInput = (source) => {
			const lines = source.split("\n");
			lines.forEach((line, index) => {
				appendPromptLine(index === 0 ? ">>>" : "...", line);
			});
		};

		const appendMultilineOutput = (text, kind) => {
			const lines = text.replace(/\r/g, "").split("\n");
			while (lines.length > 0 && lines[lines.length - 1] === "") {
				lines.pop();
			}
			lines.forEach((line) => appendTranscriptLine(line, kind));
		};

		const setStatus = (state, message) => {
			if (statusShell instanceof HTMLElement) {
				statusShell.dataset.state = state;
			}
			if (statusText instanceof HTMLElement) {
				statusText.textContent = message;
			}
		};

		const setBusy = (busy) => {
			if (inputEl instanceof HTMLTextAreaElement) {
				inputEl.disabled = busy;
			}
			if (clearButton instanceof HTMLButtonElement) {
				clearButton.disabled = busy;
			}
			if (resetButton instanceof HTMLButtonElement) {
				resetButton.disabled = busy;
			}
		};

		const setInputValue = (value) => {
			if (!(inputEl instanceof HTMLTextAreaElement)) return;
			inputEl.value = value;
			resizeInput();
			const end = value.length;
			inputEl.setSelectionRange(end, end);
		};

		const resizeInput = () => {
			if (!(inputEl instanceof HTMLTextAreaElement)) return;
			inputEl.style.height = "0px";
			const nextHeight = Math.min(Math.max(inputEl.scrollHeight, 40), 220);
			inputEl.style.height = `${nextHeight}px`;
		};

		const summarizeExecutionResult = (result) => {
			const success = Boolean(readField(result, "success"));
			const stdout = readField(result, "stdout") || "";
			const stderr = readField(result, "stderr") || "";
			const error = readField(result, "error") || "";
			return { success, stdout, stderr, error };
		};

		const renderExecutionResult = (result) => {
			const summary = summarizeExecutionResult(result);
			if (summary.stdout.trim().length > 0) {
				appendMultilineOutput(summary.stdout, "stdout");
			}
			if (summary.stderr.trim().length > 0) {
				appendMultilineOutput(summary.stderr, "stderr");
			}
			if (!summary.success && summary.error && summary.stderr.trim().length === 0) {
				appendTranscriptLine(summary.error, "stderr");
			}
		};

		const renderStartupBanner = (force = false) => {
			if (!runtimeModule) return;
			if (bannerRendered && !force) return;
			const version = String(readField(lastRuntimeInfo, "pyrs_version") || "dev");
			const backend = String(readField(lastRuntimeInfo, "execution_backend") || "wasm");
			appendTranscriptLine(`PYRS ${version} (${backend})`, "banner");
			appendTranscriptLine(
				'Type "help", "copyright", "credits" or "license" for more information.',
				"banner",
			);
			bannerRendered = true;
		};

		const clearTranscript = (preserveBanner = true) => {
			if (transcriptEl instanceof HTMLElement) {
				transcriptEl.innerHTML = "";
			}
			bannerRendered = false;
			if (preserveBanner && runtimeModule) {
				renderStartupBanner(true);
			}
		};

		const getReplSession = () => {
			if (!runtimeModule) return null;
			if (replSession) return replSession;
			if (typeof runtimeModule.WasmReplSession === "function") {
				replSession = new runtimeModule.WasmReplSession();
				return replSession;
			}
			if (typeof runtimeModule.WasmSession === "function") {
				replSession = new runtimeModule.WasmSession();
				return replSession;
			}
			return null;
		};

		const ensureRuntimeLoaded = async () => {
			if (runtimeModule) return true;
			if (runtimeLoadPromise) return runtimeLoadPromise;

			runtimeLoadPromise = (async () => {
				setStatus("loading", "Loading runtime…");
				try {
					const moduleRef = await import(wasmEntrypoint);
					if (typeof moduleRef.default === "function") {
						await moduleRef.default();
					}
					if (typeof moduleRef.init_wasm_runtime === "function") {
						moduleRef.init_wasm_runtime();
					}

					runtimeModule = moduleRef;
					replSession = null;
					getReplSession();

					lastRuntimeInfo =
						typeof moduleRef.wasm_runtime_info === "function"
							? moduleRef.wasm_runtime_info()
							: null;
					const backend = String(readField(lastRuntimeInfo, "execution_backend") || "wasm");
					const executionEnabled = Boolean(readField(lastRuntimeInfo, "supports_execution"));
					setStatus(
						"ready",
						executionEnabled
							? `Runtime ready (${backend})`
							: `Runtime compile-only (${backend})`,
					);
					renderStartupBanner();
					return true;
				} catch (error) {
					const message = error instanceof Error ? error.message : String(error);
					setStatus("error", "Runtime failed to load");
					appendTranscriptLine(`Runtime load error: ${message}`, "stderr");
					return false;
				} finally {
					runtimeLoadPromise = null;
				}
			})();

			return runtimeLoadPromise;
		};

		const runSource = async (source) => {
			const normalized = source.trimEnd();
			if (!normalized.trim()) return;

			if (commandHistory.at(-1) !== normalized) {
				commandHistory.push(normalized);
			}
			historyIndex = commandHistory.length;
			appendPromptInput(normalized);

			setBusy(true);
			const loaded = await ensureRuntimeLoaded();
			if (!loaded || !runtimeModule) {
				setBusy(false);
				return;
			}

			try {
				const session = getReplSession();
				if (session && typeof session.execute_input === "function") {
					renderExecutionResult(session.execute_input(normalized));
				} else if (session && typeof session.execute === "function") {
					renderExecutionResult(session.execute(normalized));
				} else if (typeof runtimeModule.execute === "function") {
					renderExecutionResult(runtimeModule.execute(normalized));
				} else {
					appendTranscriptLine("Runtime execute entrypoint is unavailable.", "stderr");
				}
			} catch (error) {
				const message = error instanceof Error ? error.message : String(error);
				appendTranscriptLine(message, "stderr");
			} finally {
				setBusy(false);
			}
		};

		if (inputEl instanceof HTMLTextAreaElement) {
			inputEl.addEventListener("keydown", (event) => {
				if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "l") {
					event.preventDefault();
					clearTranscript(true);
					return;
				}
				if (event.key === "Enter" && !event.shiftKey) {
					event.preventDefault();
					if (formEl instanceof HTMLFormElement) {
						formEl.requestSubmit();
					}
					return;
				}
				if (event.key === "ArrowUp") {
					const atStart = inputEl.selectionStart === 0 && inputEl.selectionEnd === 0;
					if (atStart && commandHistory.length > 0) {
						event.preventDefault();
						historyIndex = Math.max(0, historyIndex - 1);
						setInputValue(commandHistory[historyIndex] || "");
					}
					return;
				}
				if (event.key === "ArrowDown") {
					const atEnd =
						inputEl.selectionStart === inputEl.value.length &&
						inputEl.selectionEnd === inputEl.value.length;
					if (atEnd && commandHistory.length > 0) {
						event.preventDefault();
						historyIndex = Math.min(commandHistory.length, historyIndex + 1);
						if (historyIndex >= commandHistory.length) {
							setInputValue("");
						} else {
							setInputValue(commandHistory[historyIndex] || "");
						}
					}
				}
			});
			inputEl.addEventListener("input", resizeInput);
			resizeInput();
		}

		if (formEl instanceof HTMLFormElement && inputEl instanceof HTMLTextAreaElement) {
			formEl.addEventListener("submit", async (event) => {
				event.preventDefault();
				const source = inputEl.value;
				inputEl.value = "";
				resizeInput();
				await runSource(source);
				inputEl.focus();
			});
		}

		if (clearButton instanceof HTMLButtonElement) {
			clearButton.addEventListener("click", () => {
				clearTranscript(true);
				if (inputEl instanceof HTMLTextAreaElement) {
					inputEl.focus();
				}
			});
		}

		if (resetButton instanceof HTMLButtonElement) {
			resetButton.addEventListener("click", () => {
				const session = getReplSession();
				if (session && typeof session.reset === "function") {
					session.reset();
				} else {
					replSession = null;
					getReplSession();
				}
				clearTranscript(true);
				setStatus("ready", "Runtime ready");
				if (inputEl instanceof HTMLTextAreaElement) {
					inputEl.focus();
				}
			});
		}

		ensureRuntimeLoaded().then(() => {
			if (inputEl instanceof HTMLTextAreaElement) {
				inputEl.focus();
			}
		});
	</script>
</SiteLayout>

<style>
	.playground-page {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding-bottom: 2rem;
	}

	.playground-header {
		display: grid;
		gap: 0.72rem;
	}

	.playground-kicker-row {
		display: inline-flex;
		align-items: center;
		gap: 0.46rem;
	}

	.playground-kicker {
		margin: 0;
		font-size: 0.74rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: #f9d3ba;
		font-weight: 700;
	}

	.playground-header h1 {
		margin: 0;
		font-size: clamp(2rem, 3vw, 2.8rem);
		line-height: 1.08;
	}

	.playground-header p {
		margin: 0;
		color: var(--text-muted);
		max-width: 72ch;
		font-size: 1.03rem;
		line-height: 1.62;
	}

	.playground-header kbd {
		font-family: "JetBrains Mono", "SFMono-Regular", ui-monospace, Menlo, monospace;
		font-size: 0.76em;
		padding: 0.12rem 0.34rem;
		border-radius: 0.34rem;
		border: 1px solid rgba(212, 146, 103, 0.44);
		background: rgba(32, 16, 11, 0.72);
		color: #f5d4bd;
	}

	.playground-status {
		display: inline-flex;
		align-items: center;
		gap: 0.54rem;
		width: fit-content;
		padding: 0.43rem 0.72rem;
		border-radius: 999px;
		border: 1px solid rgba(71, 47, 36, 0.9);
		background: rgba(15, 9, 7, 0.68);
		color: #d8c5b6;
		font-size: 0.84rem;
		letter-spacing: 0.01em;
	}

	.status-dot {
		width: 0.52rem;
		height: 0.52rem;
		border-radius: 999px;
		background: #997d6d;
	}

	.playground-status[data-state="loading"] .status-dot {
		background: #f2ad79;
		animation: pulse 1s ease-in-out infinite;
	}

	.playground-status[data-state="ready"] .status-dot {
		background: #5ac98f;
	}

	.playground-status[data-state="error"] .status-dot {
		background: #ff7d70;
	}

	.playground-shell {
		display: flex;
		flex-direction: column;
		width: 100%;
		min-height: 60vh;
		border-radius: 0.94rem;
		border: 1px solid rgba(70, 47, 36, 0.82);
		background: linear-gradient(180deg, rgba(8, 11, 17, 0.97) 0%, rgba(5, 8, 13, 0.99) 100%);
		overflow: hidden;
		box-shadow: 0 12px 50px rgba(0, 0, 0, 0.34);
	}

	.playground-shell-bar {
		display: flex;
		align-items: center;
		gap: 0.72rem;
		padding: 0.62rem 0.9rem;
		border-bottom: 1px solid rgba(63, 44, 35, 0.8);
		background: rgba(24, 16, 12, 0.56);
	}

	.playground-shell-lights {
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
	}

	.playground-shell-lights span {
		width: 0.68rem;
		height: 0.68rem;
		border-radius: 999px;
		display: inline-block;
	}

	.light-red {
		background: #ff6f61;
	}

	.light-yellow {
		background: #f5c04e;
	}

	.light-green {
		background: #34c16f;
	}

	.playground-shell-title {
		margin: 0;
		font-family: "JetBrains Mono", "SFMono-Regular", ui-monospace, Menlo, monospace;
		font-size: 0.76rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: #d0bdaf;
		font-weight: 700;
	}

	.playground-transcript {
		flex: 1;
		padding: 1rem 1.1rem 1.1rem;
		overflow-y: auto;
		font-family: "JetBrains Mono", "SFMono-Regular", ui-monospace, Menlo, monospace;
		font-size: 0.94rem;
		line-height: 1.56;
		word-break: break-word;
		background: transparent;
	}

	.transcript-line {
		white-space: pre-wrap;
		animation: line-in 120ms ease;
	}

	.transcript-line + .transcript-line {
		margin-top: 0.24rem;
	}

	.transcript-line-input {
		display: flex;
		align-items: flex-start;
		gap: 0.62rem;
		color: #f8f2ec;
	}

	.transcript-prompt {
		min-width: 2.35rem;
		color: #4fc3ff;
		font-weight: 700;
		letter-spacing: 0.03em;
	}

	.transcript-input-text {
		color: #f8f2ec;
		flex: 1;
	}

	.transcript-line-banner {
		color: #b2bac7;
	}

	.transcript-line-stdout {
		color: #f4f8ff;
	}

	.transcript-line-stderr {
		color: #ffb7aa;
	}

	.playground-input-row {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: end;
		gap: 0.72rem;
		padding: 0.86rem 1rem;
		border-top: 1px solid rgba(52, 64, 86, 0.86);
		background: linear-gradient(180deg, rgba(16, 25, 39, 0.74) 0%, rgba(11, 18, 30, 0.88) 100%);
	}

	.playground-prompt {
		font-family: "JetBrains Mono", "SFMono-Regular", ui-monospace, Menlo, monospace;
		font-size: 0.92rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: #4fc3ff;
		padding-bottom: 0.5rem;
	}

	.playground-input-row textarea {
		width: 100%;
		resize: none;
		font-family: "JetBrains Mono", "SFMono-Regular", ui-monospace, Menlo, monospace;
		font-size: 0.94rem;
		line-height: 1.5;
		background: transparent;
		color: #f8f2ec;
		border: none;
		outline: none;
		padding: 0.32rem 0;
		min-height: 2.5rem;
		max-height: 220px;
	}

	.playground-input-row textarea::placeholder {
		color: #8e9db3;
	}

	.playground-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.52rem;
	}

	.playground-actions button {
		appearance: none;
		border: 1px solid rgba(113, 143, 198, 0.4);
		background: rgba(25, 46, 83, 0.66);
		color: #e8f0ff;
		border-radius: 0.55rem;
		padding: 0.38rem 0.68rem;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 120ms ease, border-color 120ms ease;
	}

	.playground-actions button:hover {
		background: rgba(31, 61, 109, 0.82);
		border-color: rgba(133, 165, 224, 0.62);
	}

	.playground-actions button:disabled {
		opacity: 0.56;
		cursor: not-allowed;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}

	@keyframes pulse {
		0% {
			opacity: 1;
		}
		50% {
			opacity: 0.35;
		}
		100% {
			opacity: 1;
		}
	}

	@keyframes line-in {
		from {
			opacity: 0;
			transform: translateY(3px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 760px) {
		.playground-header h1 {
			font-size: 1.9rem;
		}

		.playground-shell {
			min-height: 55vh;
		}

		.playground-transcript {
			padding: 0.92rem 0.84rem 0.96rem;
			font-size: 0.87rem;
		}

		.playground-shell-bar {
			padding: 0.56rem 0.72rem;
		}

		.transcript-prompt {
			min-width: 2.05rem;
		}
	}
</style>
