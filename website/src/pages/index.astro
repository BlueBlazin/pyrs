---
import InstallMethod from "../components/home/InstallMethod.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

type InstallLine = string | { text: string; prompt?: boolean };
type InstallMethodData = {
	title: string;
	description: string;
	recommended?: boolean;
	lines: InstallLine[];
};

const installMethods: Record<"macos" | "linux", InstallMethodData[]> = {
	macos: [
		{
			title: "Cargo install (GitHub)",
			description: "Install pyrs into your cargo bin directory directly from GitHub.",
			recommended: true,
			lines: [
				"cargo install --locked --git https://github.com/BlueBlazin/pyrs --bin pyrs",
				"pyrs --version",
			],
		},
		{
			title: "Cargo (source build)",
			description: "Build directly from source with Rust stable.",
			lines: [
				"git clone https://github.com/BlueBlazin/pyrs.git",
				"cd pyrs",
				"cargo build --release",
				"target/release/pyrs",
			],
		},
		{
			title: "Docker (nightly container)",
			description: "Run the latest published nightly image from GHCR.",
			lines: [
				"docker pull ghcr.io/blueblazin/pyrs:nightly",
				"docker run --rm -it ghcr.io/blueblazin/pyrs:nightly",
			],
		},
		{
			title: "Nightly archive",
			description: "Download the latest MacOS nightly archive for your architecture.",
			lines: [
				"ARCH=\"$(uname -m)\"",
				"case \"$ARCH\" in",
				{ text: "  arm64) PKG=\"pyrs-nightly-aarch64-apple-darwin.tar.gz\" ;;", prompt: false },
				{ text: "  *)     PKG=\"pyrs-nightly-x86_64-apple-darwin.tar.gz\" ;;", prompt: false },
				{ text: "esac", prompt: false },
				"curl -L \"https://github.com/BlueBlazin/pyrs/releases/download/nightly/$PKG\" -o \"$PKG\"",
				"tar -xzf \"$PKG\"",
				"./pyrs --version",
			],
		},
	],
	linux: [
		{
			title: "Cargo install (GitHub)",
			description: "Install pyrs into your cargo bin directory directly from GitHub.",
			recommended: true,
			lines: [
				"cargo install --locked --git https://github.com/BlueBlazin/pyrs --bin pyrs",
				"pyrs --version",
			],
		},
		{
			title: "Cargo (source build)",
			description: "Build from source and run the release binary locally.",
			lines: [
				"git clone https://github.com/BlueBlazin/pyrs.git",
				"cd pyrs",
				"cargo build --release",
				"target/release/pyrs",
			],
		},
		{
			title: "Docker (nightly container)",
			description: "Use the nightly container as a fast runtime path.",
			lines: [
				"docker pull ghcr.io/blueblazin/pyrs:nightly",
				"docker run --rm -it ghcr.io/blueblazin/pyrs:nightly",
			],
		},
		{
			title: "Nightly archive",
			description: "Fetch the latest Linux nightly binary archive.",
			lines: [
				"PKG=\"pyrs-nightly-x86_64-unknown-linux-gnu.tar.gz\"",
				"curl -L \"https://github.com/BlueBlazin/pyrs/releases/download/nightly/$PKG\" -o \"$PKG\"",
				"tar -xzf \"$PKG\"",
				"./pyrs --version",
			],
		},
	],
};
---

<SiteLayout
	title="PYRS | Python Interpreter in Rust"
	description="PYRS is a production-focused Python interpreter in Rust targeting CPython 3.14 compatibility."
>
	<section class="hero">
					<div class="hero-copy">
						<p class="eyebrow">Python in Rust</p>
						<h1>CPython 3.14 compatibility, built for real execution.</h1>
						<p class="lede">
							PYRS is a fully AI agent developed Python interpreter in Rust focused on CPython semantic
							parity, C-API closure, and production-grade runtime behavior.
						</p>
						<div class="cta-row">
							<a class="btn btn-primary" href="https://github.com/BlueBlazin/pyrs">Explore Repo</a>
							<a class="btn btn-secondary" href="#install">Install</a>
						</div>
						<div class="metrics">
							<div class="metric">
								<span>Target</span>
								<strong>CPython 3.14</strong>
							</div>
							<div class="metric">
								<span>Platforms</span>
								<strong>Linux + macOS</strong>
							</div>
							<div class="metric">
								<span>Implementation</span>
								<strong>Rust VM + stdlib parity</strong>
							</div>
						</div>
					</div>
					<div class="hero-visual">
						<div class="shot-stack" role="img" aria-label="PYRS REPL screenshots">
							<img
								class="shot shot-base"
								src="/images/repl/repl1.png"
								alt="PYRS REPL screenshot showing syntax highlighting and dataclass usage"
								loading="eager"
								decoding="async"
							/>
							<img
								class="shot shot-overlay"
								src="/images/repl/repl2.png"
								alt="PYRS REPL screenshot showing refined syntax highlighting and output"
								loading="eager"
								decoding="async"
							/>
						</div>
						<p class="visual-note">Real PYRS REPL captures from local runtime sessions.</p>
					</div>
				</section>

				<section class="pillars">
					<article class="card">
						<h2>Parser + VM Parity</h2>
						<p>CPython-aligned grammar, bytecode execution, and strict differential behavior gates.</p>
					</article>
					<article class="card">
						<h2>Extension Bring-Up</h2>
						<p>Focused C-API closure for scientific-stack compatibility and ABI surface confidence.</p>
					</article>
					<article class="card">
						<h2>Release Discipline</h2>
						<p>Parity profiles, nextest checkpoints, and integrity audits drive launch readiness.</p>
					</article>
				</section>

				<section class="install" id="install">
					<div class="install-head">
						<p class="eyebrow">Install</p>
						<h2>Install on MacOS or Linux.</h2>
						<p class="install-lede">
							Choose your platform, then pick the installation path that matches your workflow.
						</p>
					</div>

					<div class="install-tabs">
						<input
							class="install-tab-input"
							type="radio"
							name="install-platform"
							id="install-tab-macos"
							checked
						/>
						<input
							class="install-tab-input"
							type="radio"
							name="install-platform"
							id="install-tab-linux"
						/>

						<div class="install-tab-list" role="tablist" aria-label="Installation platform">
							<label class="install-tab-btn" for="install-tab-macos">MacOS</label>
							<label class="install-tab-btn" for="install-tab-linux">Linux</label>
						</div>

						<div class="install-surface">
							<div class="install-panels">
								<div class="install-panel" id="install-panel-macos">
									{
										installMethods.macos.map((method) => (
											<InstallMethod
												title={method.title}
												description={method.description}
												recommended={method.recommended}
												lines={method.lines}
											/>
										))
									}
								</div>

								<div class="install-panel" id="install-panel-linux">
									{
										installMethods.linux.map((method) => (
											<InstallMethod
												title={method.title}
												description={method.description}
												recommended={method.recommended}
												lines={method.lines}
											/>
										))
									}
								</div>
							</div>
						</div>
					</div>
	</section>
</SiteLayout>

<style>
	.hero {
		display: block;
		padding: 1.6rem 0 0;
	}

	.hero-copy {
		max-width: 62rem;
	}

	.eyebrow {
		margin: 0 0 0.9rem;
		color: var(--accent-2);
		letter-spacing: 0.09em;
		text-transform: uppercase;
		font-size: 0.78rem;
		font-weight: 600;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 5.8vw, 3.4rem);
		line-height: 1.04;
		letter-spacing: -0.02em;
	}

	.lede {
		margin: 1.15rem 0 0;
		max-width: 56ch;
		color: var(--text-muted);
		font-size: 1.02rem;
		line-height: 1.6;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.72rem;
		margin-top: 1.35rem;
	}

	.btn {
		padding: 0.72rem 1rem;
		border-radius: 0.72rem;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.91rem;
		transition: transform 150ms ease, box-shadow 150ms ease;
	}

	.btn:hover {
		transform: translateY(-1px);
		box-shadow: 0 8px 18px rgba(0, 0, 0, 0.24);
	}

	.btn:focus-visible {
		outline: 2px solid rgba(255, 163, 105, 0.9);
		outline-offset: 2px;
	}

	.btn-primary {
		background: linear-gradient(135deg, #df8b5a 0%, #c76638 100%);
		color: #231108;
	}

	.btn-secondary {
		color: var(--text);
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.02);
	}

	.metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.72rem;
		margin-top: 1.3rem;
	}

	.metric {
		border: 1px solid var(--line);
		border-radius: 0.78rem;
		background: rgba(28, 17, 13, 0.76);
		padding: 0.72rem 0.78rem;
	}

	.metric span {
		display: block;
		color: var(--text-muted);
		font-size: 0.73rem;
		margin-bottom: 0.33rem;
	}

	.metric strong {
		font-size: 0.86rem;
	}

	.hero-visual {
		position: relative;
		margin-top: 1.8rem;
	}

	.shot-stack {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(0, 1.02fr);
		gap: 0.8rem;
		align-items: start;
	}

	.shot {
		display: block;
		width: 100%;
		max-width: none;
		height: auto;
		border: 1px solid #4a3024;
		border-radius: 0.95rem;
		box-shadow: 0 18px 44px rgba(16, 8, 4, 0.5);
	}

	.shot-base {
		background: #0f0907;
	}

	.shot-overlay {
		background: #1a120f;
		position: relative;
		z-index: 2;
		margin-top: 1rem;
		margin-left: -3.6rem;
	}

	.visual-note {
		margin: 0.78rem 0 0;
		font-size: 0.8rem;
		color: #b99985;
	}

	.pillars {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 0;
	}

	.card {
		background: var(--bg-card);
		border: 1px solid var(--line);
		border-radius: 0.9rem;
		padding: 1rem;
	}

	.card h2 {
		margin: 0 0 0.55rem;
		font-size: 1.05rem;
	}

	.card p {
		margin: 0;
		font-size: 0.92rem;
		color: var(--text-muted);
		line-height: 1.52;
	}

	.install {
		margin-top: 0;
	}

	.install-head h2 {
		margin: 0;
		font-size: clamp(1.4rem, 3.1vw, 1.95rem);
		line-height: 1.2;
		letter-spacing: -0.01em;
	}

	.install-lede {
		margin: 0.75rem 0 0;
		color: var(--text-muted);
		font-size: 0.94rem;
		line-height: 1.55;
		max-width: 62ch;
	}

	.install-tabs {
		margin-top: 1.12rem;
	}

	.install-tab-input {
		display: none;
	}

	.install-tab-list {
		display: inline-flex;
		gap: 0.26rem;
		padding: 0.24rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(15, 10, 8, 0.88);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
	}

	.install-tab-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.44rem 0.96rem;
		border-radius: 999px;
		font-size: 0.84rem;
		font-weight: 600;
		color: var(--text-muted);
		border: 1px solid transparent;
		cursor: pointer;
		transition: color 140ms ease, background-color 140ms ease, border-color 140ms ease;
	}

	.install-tab-btn:hover {
		color: #e4c8b8;
	}

	#install-tab-macos:checked ~ .install-tab-list label[for="install-tab-macos"],
	#install-tab-linux:checked ~ .install-tab-list label[for="install-tab-linux"] {
		color: #241108;
		background: linear-gradient(135deg, #df9664 0%, #c66a3e 100%);
		border-color: rgba(198, 106, 62, 0.46);
	}

	.install-surface {
		margin-top: 0.92rem;
		border: 1px solid #563628;
		border-radius: 1rem;
		background:
			linear-gradient(180deg, rgba(201, 110, 66, 0.05) 0%, rgba(201, 110, 66, 0.01) 100%),
			rgba(11, 8, 7, 0.93);
		overflow: hidden;
		box-shadow: 0 16px 32px rgba(0, 0, 0, 0.2);
	}

	.install-panels {
		display: grid;
		grid-template-areas: "stack";
	}

	.install-panel {
		grid-area: stack;
		display: flex;
		flex-direction: column;
		gap: 0;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transform: translateY(4px);
		transition: opacity 180ms ease, transform 180ms ease;
	}

	#install-tab-macos:checked ~ .install-surface .install-panels #install-panel-macos,
	#install-tab-linux:checked ~ .install-surface .install-panels #install-panel-linux {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transform: translateY(0);
	}

	.install-method {
		padding: 1rem 1.08rem 1.06rem;
	}

	.install-method + .install-method {
		border-top: 1px solid rgba(83, 52, 39, 0.72);
	}

	.install-method-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
	}

	.install-method h3 {
		margin: 0;
		font-size: 0.94rem;
		letter-spacing: 0.01em;
	}

	.install-chip {
		font-size: 0.67rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-weight: 700;
		color: #241108;
		background: linear-gradient(135deg, #dda06f 0%, #cb7647 100%);
		border: 1px solid rgba(203, 118, 71, 0.42);
		border-radius: 999px;
		padding: 0.21rem 0.44rem;
	}

	.install-method p {
		margin: 0.43rem 0 0;
		color: var(--text-muted);
		font-size: 0.86rem;
		line-height: 1.52;
	}

	.terminal {
		margin-top: 0.74rem;
		border: 1px solid #322117;
		border-radius: 0.82rem;
		background: #060505;
		box-shadow: 0 12px 24px rgba(0, 0, 0, 0.24);
		overflow: hidden;
	}

	.terminal-bar {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		padding: 0.52rem 0.62rem;
		border-bottom: 1px solid #261912;
		background: linear-gradient(180deg, #130d0a 0%, #0d0907 100%);
	}

	.terminal-lights {
		display: inline-flex;
		gap: 0.28rem;
	}

	.term-light {
		width: 0.53rem;
		height: 0.53rem;
		border-radius: 50%;
		display: inline-block;
	}

	.term-light-red {
		background: #ff6b62;
	}

	.term-light-amber {
		background: #ffbe58;
	}

	.term-light-green {
		background: #34c46a;
	}

	.terminal-title {
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.7rem;
		color: #b69f91;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.cmd-copy {
		margin-left: auto;
		padding: 0.2rem 0.52rem;
		border-radius: 0.42rem;
		border: 1px solid #5f3d2d;
		background: #21140f;
		color: #e9d0c2;
		font-family: "Space Grotesk", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
		font-size: 0.72rem;
		font-weight: 600;
		cursor: pointer;
		transition: background-color 120ms ease, border-color 120ms ease, color 120ms ease;
	}

	.cmd-copy:hover {
		background: #2d1b14;
		border-color: #714735;
	}

	.cmd-copy:focus-visible {
		outline: 2px solid rgba(223, 150, 100, 0.88);
		outline-offset: 2px;
	}

	.cmd-copy.copied {
		background: #1d3a2d;
		border-color: #2b6e51;
		color: #e9fff3;
	}

	.cmd-copy.copy-failed {
		background: #47201a;
		border-color: #8a3d2e;
		color: #ffe6df;
	}

	.cmd-box {
		margin: 0;
		overflow-x: auto;
		padding: 0.84rem 0.92rem 0.88rem;
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.78rem;
		line-height: 1.52;
		color: #ecd9cd;
		background: #070605;
	}

	.cmd-box code {
		display: block;
		white-space: normal;
	}

	.cmd-line {
		display: flex;
		align-items: flex-start;
		gap: 0.54rem;
	}

	.cmd-line + .cmd-line {
		margin-top: 0;
	}

	.cmd-prompt {
		display: inline-block;
		width: 0.7rem;
		user-select: none;
		color: #dd9463;
		font-weight: 600;
		text-align: center;
		flex: 0 0 0.7rem;
	}

	.cmd-prompt-empty {
		color: transparent;
	}

	.cmd-text {
		color: #ecd9cd;
		white-space: pre;
	}

	.cmd-box ::selection {
		background: rgba(201, 110, 66, 0.28);
		color: #fff5ef;
	}

	@media (max-width: 1024px) {
		.shot-stack {
			grid-template-columns: 1fr 1fr;
			gap: 0.9rem;
		}

		.shot-overlay {
			margin-left: -1.35rem;
		}
	}

	@media (max-width: 760px) {
		.metrics,
		.pillars {
			grid-template-columns: 1fr;
		}

		.install-method {
			padding: 0.9rem 0.86rem;
		}

		.shot-stack {
			grid-template-columns: 1fr;
			gap: 0.85rem;
		}

		.shot-overlay {
			margin-top: 0;
			margin-left: 0;
		}
	}

	@media (max-width: 520px) {
		.hero-visual {
			margin-top: 1.3rem;
		}
	}
</style>
