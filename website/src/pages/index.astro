---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="64x64" href="/images/logo/logo-64.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>PYRS | Python Interpreter in Rust</title>
		<meta
			name="description"
			content="PYRS is a production-focused Python interpreter in Rust targeting CPython 3.14 compatibility."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="site-shell">
			<header class="topbar">
				<a class="brand" href="/">
					<img src="/images/logo/logo-64.png" alt="PYRS logo" width="36" height="36" />
					<span>PYRS</span>
				</a>
				<nav class="topnav">
					<a href="https://github.com/BlueBlazin/pyrs">GitHub</a>
					<a href="https://github.com/BlueBlazin/pyrs/tree/master/docs">Internal Docs</a>
				</nav>
			</header>

			<main>
				<section class="hero">
					<div class="hero-copy">
						<p class="eyebrow">Python in Rust</p>
						<h1>CPython 3.14 compatibility, built for real execution.</h1>
						<p class="lede">
							PYRS is an actively developed Python interpreter in Rust focused on CPython semantic
							parity, C-API closure, and production-grade runtime behavior.
						</p>
						<div class="cta-row">
							<a class="btn btn-primary" href="https://github.com/BlueBlazin/pyrs">Explore Repo</a>
							<a class="btn btn-secondary" href="https://github.com/BlueBlazin/pyrs/actions"
								>View CI Status</a
							>
						</div>
						<div class="metrics">
							<div class="metric">
								<span>Target</span>
								<strong>CPython 3.14</strong>
							</div>
							<div class="metric">
								<span>Platforms</span>
								<strong>Linux + macOS</strong>
							</div>
							<div class="metric">
								<span>Implementation</span>
								<strong>Rust VM + stdlib parity</strong>
							</div>
						</div>
					</div>
					<div class="hero-visual">
						<div class="shot-stack" role="img" aria-label="PYRS REPL screenshots">
							<img
								class="shot shot-base"
								src="/images/repl/repl1.png"
								alt="PYRS REPL screenshot showing syntax highlighting and dataclass usage"
								loading="eager"
								decoding="async"
							/>
							<img
								class="shot shot-overlay"
								src="/images/repl/repl2.png"
								alt="PYRS REPL screenshot showing refined syntax highlighting and output"
								loading="eager"
								decoding="async"
							/>
						</div>
						<p class="visual-note">Real PYRS REPL captures from local runtime sessions.</p>
					</div>
				</section>

				<section class="pillars">
					<article class="card">
						<h2>Parser + VM Parity</h2>
						<p>CPython-aligned grammar, bytecode execution, and strict differential behavior gates.</p>
					</article>
					<article class="card">
						<h2>Extension Bring-Up</h2>
						<p>Focused C-API closure for scientific-stack compatibility and ABI surface confidence.</p>
					</article>
					<article class="card">
						<h2>Release Discipline</h2>
						<p>Parity profiles, nextest checkpoints, and integrity audits drive launch readiness.</p>
					</article>
				</section>
			</main>
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #070b14;
		--bg-card: #0f1829;
		--line: #253853;
		--text: #e8f1ff;
		--text-muted: #9dafce;
		--accent: #3dc4ff;
		--accent-2: #31d39f;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: "Space Grotesk", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
		color: var(--text);
		background:
			radial-gradient(70rem 38rem at 90% -10%, rgba(61, 196, 255, 0.22), transparent),
			radial-gradient(68rem 36rem at -5% 8%, rgba(49, 211, 159, 0.16), transparent),
			linear-gradient(180deg, #050911 0%, var(--bg) 36%, #04070f 100%);
	}

	.site-shell {
		width: min(1160px, calc(100% - 2.8rem));
		margin: 0 auto;
		padding-bottom: 4rem;
	}

	.topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.4rem 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.68rem;
		text-decoration: none;
		color: var(--text);
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.brand img {
		border-radius: 0.52rem;
		border: 1px solid rgba(255, 255, 255, 0.14);
	}

	.topnav {
		display: inline-flex;
		gap: 0.95rem;
	}

	.topnav a {
		text-decoration: none;
		font-size: 0.92rem;
		color: var(--text-muted);
	}

	.topnav a:hover {
		color: var(--text);
	}

	.hero {
		display: grid;
		grid-template-columns: 1.02fr 0.98fr;
		gap: 2.25rem;
		align-items: center;
		padding: 1.6rem 0 0.7rem;
	}

	.eyebrow {
		margin: 0 0 0.9rem;
		color: var(--accent-2);
		letter-spacing: 0.09em;
		text-transform: uppercase;
		font-size: 0.78rem;
		font-weight: 600;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 5.8vw, 3.4rem);
		line-height: 1.04;
		letter-spacing: -0.02em;
	}

	.lede {
		margin: 1.15rem 0 0;
		max-width: 56ch;
		color: var(--text-muted);
		font-size: 1.02rem;
		line-height: 1.6;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.72rem;
		margin-top: 1.35rem;
	}

	.btn {
		padding: 0.72rem 1rem;
		border-radius: 0.72rem;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.91rem;
		transition: transform 150ms ease;
	}

	.btn:hover {
		transform: translateY(-1px);
	}

	.btn-primary {
		background: linear-gradient(135deg, #3dc4ff 0%, #28a4db 100%);
		color: #031b29;
	}

	.btn-secondary {
		color: var(--text);
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.02);
	}

	.metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.72rem;
		margin-top: 1.3rem;
	}

	.metric {
		border: 1px solid var(--line);
		border-radius: 0.78rem;
		background: rgba(16, 25, 43, 0.75);
		padding: 0.72rem 0.78rem;
	}

	.metric span {
		display: block;
		color: var(--text-muted);
		font-size: 0.73rem;
		margin-bottom: 0.33rem;
	}

	.metric strong {
		font-size: 0.86rem;
	}

	.hero-visual {
		position: relative;
	}

	.shot-stack {
		position: relative;
		min-height: 23rem;
	}

	.shot {
		display: block;
		max-width: 100%;
		height: auto;
		border: 1px solid #2a3d58;
		border-radius: 0.95rem;
		box-shadow: 0 18px 44px rgba(0, 0, 0, 0.42);
	}

	.shot-base {
		width: min(100%, 44rem);
		background: #05070b;
	}

	.shot-overlay {
		position: absolute;
		width: 57%;
		right: -2%;
		top: 11%;
		background: #13161c;
	}

	.visual-note {
		margin: 0.78rem 0 0;
		font-size: 0.8rem;
		color: #95a8ca;
	}

	.pillars {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 2rem;
	}

	.card {
		background: var(--bg-card);
		border: 1px solid var(--line);
		border-radius: 0.9rem;
		padding: 1rem;
	}

	.card h2 {
		margin: 0 0 0.55rem;
		font-size: 1.05rem;
	}

	.card p {
		margin: 0;
		font-size: 0.92rem;
		color: var(--text-muted);
		line-height: 1.52;
	}

	@media (max-width: 1024px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.shot-stack {
			min-height: 19rem;
		}
	}

	@media (max-width: 760px) {
		.site-shell {
			width: min(1160px, calc(100% - 1.2rem));
		}

		.topbar {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.6rem;
		}

		.metrics,
		.pillars {
			grid-template-columns: 1fr;
		}

		.shot-overlay {
			width: 68%;
			right: 0;
			top: 14%;
		}
	}

	@media (max-width: 520px) {
		.shot-stack {
			min-height: auto;
		}

		.shot-overlay {
			position: relative;
			width: 92%;
			margin: -1.3rem 0 0 auto;
			top: 0;
			right: 0;
		}
	}

	@media (min-width: 1240px) {
		.hero {
			grid-template-columns: 0.9fr 1.1fr;
			gap: 1.9rem;
		}

		.hero-visual {
			margin-right: -2rem;
		}

		.shot-stack {
			min-height: 30rem;
		}

		.shot-base {
			width: min(118%, 56rem);
			max-width: none;
		}

		.shot-overlay {
			width: 82%;
			right: -15%;
			top: 6%;
		}
	}
</style>
