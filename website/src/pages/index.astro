---
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="64x64" href="/images/logo/logo-64.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>PYRS | Python Interpreter in Rust</title>
		<meta
			name="description"
			content="PYRS is a production-focused Python interpreter in Rust targeting CPython 3.14 compatibility."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="site-shell">
			<header class="topbar">
				<a class="brand" href="/">
					<img src="/images/logo/logo-64.png" alt="PYRS logo" width="36" height="36" />
					<span>PYRS</span>
				</a>
				<nav class="topnav">
					<a href="https://github.com/BlueBlazin/pyrs">GitHub</a>
					<a href="https://github.com/BlueBlazin/pyrs/tree/master/docs">Internal Docs</a>
				</nav>
			</header>

			<main>
				<section class="hero">
					<div class="hero-copy">
						<p class="eyebrow">Python in Rust</p>
						<h1>CPython 3.14 compatibility, built for real execution.</h1>
						<p class="lede">
							PYRS is an actively developed Python interpreter in Rust focused on CPython semantic
							parity, C-API closure, and production-grade runtime behavior.
						</p>
						<div class="cta-row">
							<a class="btn btn-primary" href="https://github.com/BlueBlazin/pyrs">Explore Repo</a>
							<a class="btn btn-secondary" href="#install">Install</a>
						</div>
						<div class="metrics">
							<div class="metric">
								<span>Target</span>
								<strong>CPython 3.14</strong>
							</div>
							<div class="metric">
								<span>Platforms</span>
								<strong>Linux + macOS</strong>
							</div>
							<div class="metric">
								<span>Implementation</span>
								<strong>Rust VM + stdlib parity</strong>
							</div>
						</div>
					</div>
					<div class="hero-visual">
						<div class="shot-stack" role="img" aria-label="PYRS REPL screenshots">
							<img
								class="shot shot-base"
								src="/images/repl/repl1.png"
								alt="PYRS REPL screenshot showing syntax highlighting and dataclass usage"
								loading="eager"
								decoding="async"
							/>
							<img
								class="shot shot-overlay"
								src="/images/repl/repl2.png"
								alt="PYRS REPL screenshot showing refined syntax highlighting and output"
								loading="eager"
								decoding="async"
							/>
						</div>
						<p class="visual-note">Real PYRS REPL captures from local runtime sessions.</p>
					</div>
				</section>

				<section class="pillars">
					<article class="card">
						<h2>Parser + VM Parity</h2>
						<p>CPython-aligned grammar, bytecode execution, and strict differential behavior gates.</p>
					</article>
					<article class="card">
						<h2>Extension Bring-Up</h2>
						<p>Focused C-API closure for scientific-stack compatibility and ABI surface confidence.</p>
					</article>
					<article class="card">
						<h2>Release Discipline</h2>
						<p>Parity profiles, nextest checkpoints, and integrity audits drive launch readiness.</p>
					</article>
				</section>

				<section class="install" id="install">
					<div class="install-head">
						<p class="eyebrow">Install</p>
						<h2>Install on Apple or Linux.</h2>
						<p class="install-lede">
							Choose your platform, then pick the installation path that fits your workflow.
						</p>
					</div>

					<div class="install-tabs">
						<input
							class="install-tab-input"
							type="radio"
							name="install-platform"
							id="install-tab-apple"
							checked
						/>
						<input
							class="install-tab-input"
							type="radio"
							name="install-platform"
							id="install-tab-linux"
						/>

						<div class="install-tab-list" role="tablist" aria-label="Installation platform">
							<label class="install-tab-btn" for="install-tab-apple">Apple</label>
							<label class="install-tab-btn" for="install-tab-linux">Linux</label>
						</div>

						<div class="install-surface">
							<div class="install-panels">
								<div class="install-panel" id="install-panel-apple">
									<article class="install-method">
										<h3>Cargo (source build)</h3>
										<p>Build directly from source with Rust stable.</p>
										<pre class="cmd-box"><code>$ git clone https://github.com/BlueBlazin/pyrs.git
$ cd pyrs
$ cargo build --release
$ target/release/pyrs</code></pre>
									</article>
									<article class="install-method">
										<h3>Docker (nightly container)</h3>
										<p>Run the latest published nightly image from GHCR.</p>
										<pre class="cmd-box"><code>$ docker pull ghcr.io/blueblazin/pyrs:nightly
$ docker run --rm -it ghcr.io/blueblazin/pyrs:nightly</code></pre>
									</article>
									<article class="install-method">
										<h3>Nightly archive</h3>
										<p>Download the latest macOS nightly tarball for your architecture.</p>
										<pre class="cmd-box"><code>$ ARCH="$(uname -m)"
$ case "$ARCH" in
    arm64) PKG="pyrs-nightly-aarch64-apple-darwin.tar.gz" ;;
    *)     PKG="pyrs-nightly-x86_64-apple-darwin.tar.gz" ;;
  esac
$ curl -L "https://github.com/BlueBlazin/pyrs/releases/download/nightly/$PKG" -o "$PKG"
$ tar -xzf "$PKG"
$ ./pyrs --version</code></pre>
									</article>
								</div>

								<div class="install-panel" id="install-panel-linux">
									<article class="install-method">
										<h3>Cargo (source build)</h3>
										<p>Build from source and run the release binary locally.</p>
										<pre class="cmd-box"><code>$ git clone https://github.com/BlueBlazin/pyrs.git
$ cd pyrs
$ cargo build --release
$ target/release/pyrs</code></pre>
									</article>
									<article class="install-method">
										<h3>Docker (nightly container)</h3>
										<p>Use the nightly container as a fast runtime path.</p>
										<pre class="cmd-box"><code>$ docker pull ghcr.io/blueblazin/pyrs:nightly
$ docker run --rm -it ghcr.io/blueblazin/pyrs:nightly</code></pre>
									</article>
									<article class="install-method">
										<h3>Nightly archive</h3>
										<p>Fetch the latest Linux nightly binary archive.</p>
										<pre class="cmd-box"><code>$ PKG="pyrs-nightly-x86_64-unknown-linux-gnu.tar.gz"
$ curl -L "https://github.com/BlueBlazin/pyrs/releases/download/nightly/$PKG" -o "$PKG"
$ tar -xzf "$PKG"
$ ./pyrs --version</code></pre>
									</article>
								</div>
							</div>
						</div>
					</div>
				</section>

			</main>
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #120a08;
		--bg-card: #1b110f;
		--line: #503225;
		--text: #f7eee8;
		--text-muted: #ccb2a2;
		--accent: #ff8a4c;
		--accent-2: #ffb36e;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: "Space Grotesk", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
		color: var(--text);
		background:
			radial-gradient(70rem 38rem at 88% -10%, rgba(255, 138, 76, 0.22), transparent),
			radial-gradient(68rem 36rem at -5% 10%, rgba(255, 179, 110, 0.14), transparent),
			linear-gradient(180deg, #0c0605 0%, var(--bg) 36%, #090504 100%);
	}

	.site-shell {
		width: min(1280px, calc(100% - 2.8rem));
		margin: 0 auto;
		padding-bottom: 4rem;
	}

	.topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.4rem 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.68rem;
		text-decoration: none;
		color: var(--text);
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.brand img {
		border-radius: 0.52rem;
		border: 1px solid rgba(255, 255, 255, 0.14);
	}

	.topnav {
		display: inline-flex;
		gap: 0.95rem;
	}

	.topnav a {
		text-decoration: none;
		font-size: 0.92rem;
		color: var(--text-muted);
	}

	.topnav a:hover {
		color: var(--text);
	}

	.hero {
		display: block;
		padding: 1.6rem 0 0.7rem;
	}

	.hero-copy {
		max-width: 62rem;
	}

	.eyebrow {
		margin: 0 0 0.9rem;
		color: var(--accent-2);
		letter-spacing: 0.09em;
		text-transform: uppercase;
		font-size: 0.78rem;
		font-weight: 600;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 5.8vw, 3.4rem);
		line-height: 1.04;
		letter-spacing: -0.02em;
	}

	.lede {
		margin: 1.15rem 0 0;
		max-width: 56ch;
		color: var(--text-muted);
		font-size: 1.02rem;
		line-height: 1.6;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.72rem;
		margin-top: 1.35rem;
	}

	.btn {
		padding: 0.72rem 1rem;
		border-radius: 0.72rem;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.91rem;
		transition: transform 150ms ease;
	}

	.btn:hover {
		transform: translateY(-1px);
	}

	.btn-primary {
		background: linear-gradient(135deg, #ff9b5d 0%, #ff6f34 100%);
		color: #2f1408;
	}

	.btn-secondary {
		color: var(--text);
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.02);
	}

	.metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.72rem;
		margin-top: 1.3rem;
	}

	.metric {
		border: 1px solid var(--line);
		border-radius: 0.78rem;
		background: rgba(38, 23, 18, 0.78);
		padding: 0.72rem 0.78rem;
	}

	.metric span {
		display: block;
		color: var(--text-muted);
		font-size: 0.73rem;
		margin-bottom: 0.33rem;
	}

	.metric strong {
		font-size: 0.86rem;
	}

	.hero-visual {
		position: relative;
		margin-top: 1.8rem;
	}

	.shot-stack {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(0, 1.02fr);
		gap: 0.8rem;
		align-items: start;
	}

	.shot {
		display: block;
		width: 100%;
		max-width: none;
		height: auto;
		border: 1px solid #5b3829;
		border-radius: 0.95rem;
		box-shadow: 0 18px 44px rgba(16, 8, 4, 0.5);
	}

	.shot-base {
		background: #0f0907;
	}

	.shot-overlay {
		background: #1a120f;
		position: relative;
		z-index: 2;
		margin-top: 1rem;
		margin-left: -3.6rem;
	}

	.visual-note {
		margin: 0.78rem 0 0;
		font-size: 0.8rem;
		color: #c8a38e;
	}

	.pillars {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 2rem;
	}

	.card {
		background: var(--bg-card);
		border: 1px solid var(--line);
		border-radius: 0.9rem;
		padding: 1rem;
	}

	.card h2 {
		margin: 0 0 0.55rem;
		font-size: 1.05rem;
	}

	.card p {
		margin: 0;
		font-size: 0.92rem;
		color: var(--text-muted);
		line-height: 1.52;
	}

	.install {
		margin-top: 2.4rem;
	}

	.install-head h2 {
		margin: 0;
		font-size: clamp(1.4rem, 3.1vw, 1.95rem);
		line-height: 1.2;
		letter-spacing: -0.01em;
	}

	.install-lede {
		margin: 0.75rem 0 0;
		color: var(--text-muted);
		font-size: 0.94rem;
		line-height: 1.55;
		max-width: 62ch;
	}

	.install-tabs {
		margin-top: 1.12rem;
	}

	.install-tab-input {
		display: none;
	}

	.install-tab-list {
		display: inline-flex;
		gap: 0.26rem;
		padding: 0.24rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(24, 14, 11, 0.72);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
	}

	.install-tab-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.44rem 0.96rem;
		border-radius: 999px;
		font-size: 0.84rem;
		font-weight: 600;
		color: var(--text-muted);
		border: 1px solid transparent;
		cursor: pointer;
		transition: color 140ms ease, background-color 140ms ease, border-color 140ms ease;
	}

	#install-tab-apple:checked ~ .install-tab-list label[for="install-tab-apple"],
	#install-tab-linux:checked ~ .install-tab-list label[for="install-tab-linux"] {
		color: #2f1408;
		background: linear-gradient(135deg, #ffae71 0%, #ff8a4c 100%);
		border-color: rgba(255, 138, 76, 0.45);
	}

	.install-surface {
		margin-top: 0.92rem;
		border: 1px solid #64402f;
		border-radius: 1rem;
		background:
			linear-gradient(180deg, rgba(255, 152, 86, 0.07) 0%, rgba(255, 152, 86, 0.01) 100%),
			rgba(19, 11, 8, 0.84);
		overflow: hidden;
	}

	.install-panels {
		display: grid;
		grid-template-areas: "stack";
	}

	.install-panel {
		grid-area: stack;
		display: flex;
		flex-direction: column;
		gap: 0;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transform: translateY(4px);
		transition: opacity 180ms ease, transform 180ms ease;
	}

	#install-tab-apple:checked ~ .install-surface .install-panels #install-panel-apple,
	#install-tab-linux:checked ~ .install-surface .install-panels #install-panel-linux {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transform: translateY(0);
	}

	.install-method {
		padding: 1rem 1.08rem;
	}

	.install-method + .install-method {
		border-top: 1px solid rgba(100, 64, 47, 0.65);
	}

	.install-method h3 {
		margin: 0;
		font-size: 0.94rem;
		letter-spacing: 0.01em;
	}

	.install-method p {
		margin: 0.43rem 0 0;
		color: var(--text-muted);
		font-size: 0.86rem;
		line-height: 1.52;
	}

	.cmd-box {
		margin: 0.72rem 0 0;
		overflow-x: auto;
		padding: 0.82rem 0.9rem;
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.78rem;
		line-height: 1.58;
		white-space: pre;
		color: #f8e2d3;
		border-radius: 0.78rem;
		border: 1px solid #5c3a2a;
		background: linear-gradient(180deg, #1a110e 0%, #130c09 100%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.03),
			0 10px 20px rgba(0, 0, 0, 0.2);
	}

	@media (max-width: 1024px) {
		.shot-stack {
			grid-template-columns: 1fr 1fr;
			gap: 0.9rem;
		}

		.shot-overlay {
			margin-left: -1.35rem;
		}
	}

	@media (max-width: 760px) {
		.site-shell {
			width: min(1160px, calc(100% - 1.2rem));
		}

		.topbar {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.6rem;
		}

		.metrics,
		.pillars {
			grid-template-columns: 1fr;
		}

		.install-method {
			padding: 0.9rem 0.86rem;
		}

		.shot-stack {
			grid-template-columns: 1fr;
			gap: 0.85rem;
		}

		.shot-overlay {
			margin-top: 0;
			margin-left: 0;
		}
	}

	@media (max-width: 520px) {
		.hero-visual {
			margin-top: 1.3rem;
		}
	}
</style>
