---
import TopNav from "../components/TopNav.astro";
import "../styles/global.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="64x64" href="/images/logo/logo-64.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>PYRS | Python Interpreter in Rust</title>
		<meta
			name="description"
			content="PYRS is a production-focused Python interpreter in Rust targeting CPython 3.14 compatibility."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="site-shell">
			<TopNav context="home" />

			<main>
				<section class="hero">
					<div class="hero-copy">
						<p class="eyebrow">Python in Rust</p>
						<h1>CPython 3.14 compatibility, built for real execution.</h1>
						<p class="lede">
							PYRS is a fully AI agent developed Python interpreter in Rust focused on CPython semantic
							parity, C-API closure, and production-grade runtime behavior.
						</p>
						<div class="cta-row">
							<a class="btn btn-primary" href="https://github.com/BlueBlazin/pyrs">Explore Repo</a>
							<a class="btn btn-secondary" href="#install">Install</a>
						</div>
						<div class="metrics">
							<div class="metric">
								<span>Target</span>
								<strong>CPython 3.14</strong>
							</div>
							<div class="metric">
								<span>Platforms</span>
								<strong>Linux + macOS</strong>
							</div>
							<div class="metric">
								<span>Implementation</span>
								<strong>Rust VM + stdlib parity</strong>
							</div>
						</div>
					</div>
					<div class="hero-visual">
						<div class="shot-stack" role="img" aria-label="PYRS REPL screenshots">
							<img
								class="shot shot-base"
								src="/images/repl/repl1.png"
								alt="PYRS REPL screenshot showing syntax highlighting and dataclass usage"
								loading="eager"
								decoding="async"
							/>
							<img
								class="shot shot-overlay"
								src="/images/repl/repl2.png"
								alt="PYRS REPL screenshot showing refined syntax highlighting and output"
								loading="eager"
								decoding="async"
							/>
						</div>
						<p class="visual-note">Real PYRS REPL captures from local runtime sessions.</p>
					</div>
				</section>

				<section class="pillars">
					<article class="card">
						<h2>Parser + VM Parity</h2>
						<p>CPython-aligned grammar, bytecode execution, and strict differential behavior gates.</p>
					</article>
					<article class="card">
						<h2>Extension Bring-Up</h2>
						<p>Focused C-API closure for scientific-stack compatibility and ABI surface confidence.</p>
					</article>
					<article class="card">
						<h2>Release Discipline</h2>
						<p>Parity profiles, nextest checkpoints, and integrity audits drive launch readiness.</p>
					</article>
				</section>

				<section class="install" id="install">
					<div class="install-head">
						<p class="eyebrow">Install</p>
						<h2>Install on MacOS or Linux.</h2>
						<p class="install-lede">
							Choose your platform, then pick the installation path that matches your workflow.
						</p>
					</div>

					<div class="install-tabs">
						<input
							class="install-tab-input"
							type="radio"
							name="install-platform"
							id="install-tab-macos"
							checked
						/>
						<input
							class="install-tab-input"
							type="radio"
							name="install-platform"
							id="install-tab-linux"
						/>

						<div class="install-tab-list" role="tablist" aria-label="Installation platform">
							<label class="install-tab-btn" for="install-tab-macos">MacOS</label>
							<label class="install-tab-btn" for="install-tab-linux">Linux</label>
						</div>

						<div class="install-surface">
							<div class="install-panels">
								<div class="install-panel" id="install-panel-macos">
									<article class="install-method">
										<div class="install-method-head">
											<h3>Cargo install (GitHub)</h3>
											<span class="install-chip">Recommended</span>
										</div>
										<p>Install pyrs into your cargo bin directory directly from GitHub.</p>
										<div class="terminal">
											<div class="terminal-bar">
												<div class="terminal-lights" aria-hidden="true">
													<span class="term-light term-light-red"></span>
													<span class="term-light term-light-amber"></span>
													<span class="term-light term-light-green"></span>
												</div>
												<span class="terminal-title">shell</span>
												<button class="cmd-copy" type="button">Copy</button>
											</div>
											<pre class="cmd-box"><code><span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">cargo install --locked --git https://github.com/BlueBlazin/pyrs --bin pyrs</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">pyrs --version</span></span></code></pre>
										</div>
									</article>

									<article class="install-method">
										<h3>Cargo (source build)</h3>
										<p>Build directly from source with Rust stable.</p>
										<div class="terminal">
											<div class="terminal-bar">
												<div class="terminal-lights" aria-hidden="true">
													<span class="term-light term-light-red"></span>
													<span class="term-light term-light-amber"></span>
													<span class="term-light term-light-green"></span>
												</div>
												<span class="terminal-title">shell</span>
												<button class="cmd-copy" type="button">Copy</button>
											</div>
											<pre class="cmd-box"><code><span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">git clone https://github.com/BlueBlazin/pyrs.git</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">cd pyrs</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">cargo build --release</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">target/release/pyrs</span></span></code></pre>
										</div>
									</article>

									<article class="install-method">
										<h3>Docker (nightly container)</h3>
										<p>Run the latest published nightly image from GHCR.</p>
										<div class="terminal">
											<div class="terminal-bar">
												<div class="terminal-lights" aria-hidden="true">
													<span class="term-light term-light-red"></span>
													<span class="term-light term-light-amber"></span>
													<span class="term-light term-light-green"></span>
												</div>
												<span class="terminal-title">shell</span>
												<button class="cmd-copy" type="button">Copy</button>
											</div>
											<pre class="cmd-box"><code><span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">docker pull ghcr.io/blueblazin/pyrs:nightly</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">docker run --rm -it ghcr.io/blueblazin/pyrs:nightly</span></span></code></pre>
										</div>
									</article>

									<article class="install-method">
										<h3>Nightly archive</h3>
										<p>Download the latest MacOS nightly archive for your architecture.</p>
										<div class="terminal">
											<div class="terminal-bar">
												<div class="terminal-lights" aria-hidden="true">
													<span class="term-light term-light-red"></span>
													<span class="term-light term-light-amber"></span>
													<span class="term-light term-light-green"></span>
												</div>
												<span class="terminal-title">shell</span>
												<button class="cmd-copy" type="button">Copy</button>
											</div>
											<pre class="cmd-box"><code><span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">ARCH="$(uname -m)"</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">case "$ARCH" in</span></span>
<span class="cmd-line"><span class="cmd-prompt cmd-prompt-empty" aria-hidden="true"></span><span class="cmd-text">  arm64) PKG="pyrs-nightly-aarch64-apple-darwin.tar.gz" ;;</span></span>
<span class="cmd-line"><span class="cmd-prompt cmd-prompt-empty" aria-hidden="true"></span><span class="cmd-text">  *)     PKG="pyrs-nightly-x86_64-apple-darwin.tar.gz" ;;</span></span>
<span class="cmd-line"><span class="cmd-prompt cmd-prompt-empty" aria-hidden="true"></span><span class="cmd-text">esac</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">curl -L "https://github.com/BlueBlazin/pyrs/releases/download/nightly/$PKG" -o "$PKG"</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">tar -xzf "$PKG"</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">./pyrs --version</span></span></code></pre>
										</div>
									</article>
								</div>

								<div class="install-panel" id="install-panel-linux">
									<article class="install-method">
										<div class="install-method-head">
											<h3>Cargo install (GitHub)</h3>
											<span class="install-chip">Recommended</span>
										</div>
										<p>Install pyrs into your cargo bin directory directly from GitHub.</p>
										<div class="terminal">
											<div class="terminal-bar">
												<div class="terminal-lights" aria-hidden="true">
													<span class="term-light term-light-red"></span>
													<span class="term-light term-light-amber"></span>
													<span class="term-light term-light-green"></span>
												</div>
												<span class="terminal-title">shell</span>
												<button class="cmd-copy" type="button">Copy</button>
											</div>
											<pre class="cmd-box"><code><span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">cargo install --locked --git https://github.com/BlueBlazin/pyrs --bin pyrs</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">pyrs --version</span></span></code></pre>
										</div>
									</article>

									<article class="install-method">
										<h3>Cargo (source build)</h3>
										<p>Build from source and run the release binary locally.</p>
										<div class="terminal">
											<div class="terminal-bar">
												<div class="terminal-lights" aria-hidden="true">
													<span class="term-light term-light-red"></span>
													<span class="term-light term-light-amber"></span>
													<span class="term-light term-light-green"></span>
												</div>
												<span class="terminal-title">shell</span>
												<button class="cmd-copy" type="button">Copy</button>
											</div>
											<pre class="cmd-box"><code><span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">git clone https://github.com/BlueBlazin/pyrs.git</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">cd pyrs</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">cargo build --release</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">target/release/pyrs</span></span></code></pre>
										</div>
									</article>

									<article class="install-method">
										<h3>Docker (nightly container)</h3>
										<p>Use the nightly container as a fast runtime path.</p>
										<div class="terminal">
											<div class="terminal-bar">
												<div class="terminal-lights" aria-hidden="true">
													<span class="term-light term-light-red"></span>
													<span class="term-light term-light-amber"></span>
													<span class="term-light term-light-green"></span>
												</div>
												<span class="terminal-title">shell</span>
												<button class="cmd-copy" type="button">Copy</button>
											</div>
											<pre class="cmd-box"><code><span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">docker pull ghcr.io/blueblazin/pyrs:nightly</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">docker run --rm -it ghcr.io/blueblazin/pyrs:nightly</span></span></code></pre>
										</div>
									</article>

									<article class="install-method">
										<h3>Nightly archive</h3>
										<p>Fetch the latest Linux nightly binary archive.</p>
										<div class="terminal">
											<div class="terminal-bar">
												<div class="terminal-lights" aria-hidden="true">
													<span class="term-light term-light-red"></span>
													<span class="term-light term-light-amber"></span>
													<span class="term-light term-light-green"></span>
												</div>
												<span class="terminal-title">shell</span>
												<button class="cmd-copy" type="button">Copy</button>
											</div>
											<pre class="cmd-box"><code><span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">PKG="pyrs-nightly-x86_64-unknown-linux-gnu.tar.gz"</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">curl -L "https://github.com/BlueBlazin/pyrs/releases/download/nightly/$PKG" -o "$PKG"</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">tar -xzf "$PKG"</span></span>
<span class="cmd-line"><span class="cmd-prompt" aria-hidden="true">$</span><span class="cmd-text">./pyrs --version</span></span></code></pre>
										</div>
									</article>
								</div>
							</div>
						</div>
					</div>
				</section>

			</main>
		</div>
		<script>
			(() => {
				const copyButtons = document.querySelectorAll(".cmd-copy");
				for (const button of copyButtons) {
					button.addEventListener("click", async () => {
						const terminal = button.closest(".terminal");
						if (!terminal) {
							return;
						}
						const lines = terminal.querySelectorAll(".cmd-text");
						const payload = Array.from(lines)
							.map((line) => line.textContent ?? "")
							.join("\n");
						const reset = () => {
							button.textContent = "Copy";
							button.classList.remove("copied");
							button.classList.remove("copy-failed");
						};
						try {
							await navigator.clipboard.writeText(payload);
							button.textContent = "Copied";
							button.classList.add("copied");
							window.setTimeout(reset, 1300);
						} catch {
							button.textContent = "Failed";
							button.classList.add("copy-failed");
							window.setTimeout(reset, 1500);
						}
					});
				}
			})();
		</script>
	</body>
</html>

<style>
	:root {
		--bg: #0f0907;
		--bg-card: #17100e;
		--line: #432d22;
		--text: #f7eee8;
		--text-muted: #beaa9f;
		--accent: #e97d46;
		--accent-2: #d89563;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: "Space Grotesk", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
		color: var(--text);
		background:
			radial-gradient(70rem 38rem at 88% -10%, rgba(233, 125, 70, 0.14), transparent),
			radial-gradient(68rem 36rem at -5% 10%, rgba(216, 149, 99, 0.09), transparent),
			linear-gradient(180deg, #090504 0%, var(--bg) 36%, #060404 100%);
	}

	.site-shell {
		width: min(1280px, calc(100% - 2.8rem));
		margin: 0 auto;
		padding-bottom: 4rem;
	}

	main {
		display: flex;
		flex-direction: column;
		gap: 2.25rem;
	}

	.hero {
		display: block;
		padding: 1.6rem 0 0;
	}

	.hero-copy {
		max-width: 62rem;
	}

	.eyebrow {
		margin: 0 0 0.9rem;
		color: var(--accent-2);
		letter-spacing: 0.09em;
		text-transform: uppercase;
		font-size: 0.78rem;
		font-weight: 600;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 5.8vw, 3.4rem);
		line-height: 1.04;
		letter-spacing: -0.02em;
	}

	.lede {
		margin: 1.15rem 0 0;
		max-width: 56ch;
		color: var(--text-muted);
		font-size: 1.02rem;
		line-height: 1.6;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.72rem;
		margin-top: 1.35rem;
	}

	.btn {
		padding: 0.72rem 1rem;
		border-radius: 0.72rem;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.91rem;
		transition: transform 150ms ease, box-shadow 150ms ease;
	}

	.btn:hover {
		transform: translateY(-1px);
		box-shadow: 0 8px 18px rgba(0, 0, 0, 0.24);
	}

	.btn:focus-visible {
		outline: 2px solid rgba(255, 163, 105, 0.9);
		outline-offset: 2px;
	}

	.btn-primary {
		background: linear-gradient(135deg, #df8b5a 0%, #c76638 100%);
		color: #231108;
	}

	.btn-secondary {
		color: var(--text);
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.02);
	}

	.metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.72rem;
		margin-top: 1.3rem;
	}

	.metric {
		border: 1px solid var(--line);
		border-radius: 0.78rem;
		background: rgba(28, 17, 13, 0.76);
		padding: 0.72rem 0.78rem;
	}

	.metric span {
		display: block;
		color: var(--text-muted);
		font-size: 0.73rem;
		margin-bottom: 0.33rem;
	}

	.metric strong {
		font-size: 0.86rem;
	}

	.hero-visual {
		position: relative;
		margin-top: 1.8rem;
	}

	.shot-stack {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(0, 1.02fr);
		gap: 0.8rem;
		align-items: start;
	}

	.shot {
		display: block;
		width: 100%;
		max-width: none;
		height: auto;
		border: 1px solid #4a3024;
		border-radius: 0.95rem;
		box-shadow: 0 18px 44px rgba(16, 8, 4, 0.5);
	}

	.shot-base {
		background: #0f0907;
	}

	.shot-overlay {
		background: #1a120f;
		position: relative;
		z-index: 2;
		margin-top: 1rem;
		margin-left: -3.6rem;
	}

	.visual-note {
		margin: 0.78rem 0 0;
		font-size: 0.8rem;
		color: #b99985;
	}

	.pillars {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 0;
	}

	.card {
		background: var(--bg-card);
		border: 1px solid var(--line);
		border-radius: 0.9rem;
		padding: 1rem;
	}

	.card h2 {
		margin: 0 0 0.55rem;
		font-size: 1.05rem;
	}

	.card p {
		margin: 0;
		font-size: 0.92rem;
		color: var(--text-muted);
		line-height: 1.52;
	}

	.install {
		margin-top: 0;
	}

	.install-head h2 {
		margin: 0;
		font-size: clamp(1.4rem, 3.1vw, 1.95rem);
		line-height: 1.2;
		letter-spacing: -0.01em;
	}

	.install-lede {
		margin: 0.75rem 0 0;
		color: var(--text-muted);
		font-size: 0.94rem;
		line-height: 1.55;
		max-width: 62ch;
	}

	.install-tabs {
		margin-top: 1.12rem;
	}

	.install-tab-input {
		display: none;
	}

	.install-tab-list {
		display: inline-flex;
		gap: 0.26rem;
		padding: 0.24rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(15, 10, 8, 0.88);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
	}

	.install-tab-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.44rem 0.96rem;
		border-radius: 999px;
		font-size: 0.84rem;
		font-weight: 600;
		color: var(--text-muted);
		border: 1px solid transparent;
		cursor: pointer;
		transition: color 140ms ease, background-color 140ms ease, border-color 140ms ease;
	}

	.install-tab-btn:hover {
		color: #e4c8b8;
	}

	#install-tab-macos:checked ~ .install-tab-list label[for="install-tab-macos"],
	#install-tab-linux:checked ~ .install-tab-list label[for="install-tab-linux"] {
		color: #241108;
		background: linear-gradient(135deg, #df9664 0%, #c66a3e 100%);
		border-color: rgba(198, 106, 62, 0.46);
	}

	.install-surface {
		margin-top: 0.92rem;
		border: 1px solid #563628;
		border-radius: 1rem;
		background:
			linear-gradient(180deg, rgba(201, 110, 66, 0.05) 0%, rgba(201, 110, 66, 0.01) 100%),
			rgba(11, 8, 7, 0.93);
		overflow: hidden;
		box-shadow: 0 16px 32px rgba(0, 0, 0, 0.2);
	}

	.install-panels {
		display: grid;
		grid-template-areas: "stack";
	}

	.install-panel {
		grid-area: stack;
		display: flex;
		flex-direction: column;
		gap: 0;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transform: translateY(4px);
