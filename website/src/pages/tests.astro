---
import SiteLayout from "../layouts/SiteLayout.astro";
import fs from "node:fs";
import path from "node:path";

/* ── data loading ─────────────────────────────────────────────── */
const locate = (name: string): string | null => {
	const candidates = [
		path.resolve(process.cwd(), "..", "perf", "cpython_compat_benchmark_latest", name),
		path.resolve(process.cwd(), "perf", "cpython_compat_benchmark_latest", name),
	];
	for (const c of candidates) if (fs.existsSync(c)) return c;
	return null;
};
const tryRead = (p: string | null) => {
	if (!p) return null;
	try { return JSON.parse(fs.readFileSync(p, "utf-8")); }
	catch { return null; }
};

const summary = tryRead(locate("summary.json"));
const derived = tryRead(locate("derived_summary.json"));
const ok = !!(summary && derived);

/* ── computed stats ───────────────────────────────────────────── */
const entries: any[] = summary?.entries ?? [];
const totals = derived?.totals ?? {};
const caseOut  = totals.case_outcomes ?? {};
const subOut   = totals.subtest_outcomes ?? {};

// resolve effective status: fall back to inventory_status when run_status is null
const effectiveStatus = (e: any) => e.run_status ?? e.inventory_status ?? "unknown";

// module-level counts (from raw entries for accuracy)
const sc: Record<string, number> = {};
for (const e of entries) { const s = effectiveStatus(e); sc[s] = (sc[s] || 0) + 1; }

const totalModules    = entries.length;
const passedModules   = sc.passed ?? 0;
const failedModules   = sc.failed ?? 0;
const erroredModules  = (sc.process_error ?? 0) + (sc.worker_crash ?? 0);
const timedOutModules = sc.process_timeout ?? 0;
const loadErrModules  = sc.load_error ?? 0;
const skippedModules  = (sc.skipped ?? 0) + (sc.host_skip ?? 0);

// case & subtest numbers
const totalCases    = totals.discoverable_case_count ?? 0;
const execCases     = totals.executed_case_count ?? 0;
const passedCases   = caseOut.passed ?? 0;
const passedSubs    = subOut.passed ?? 0;
const totalSubs     = totals.executed_subtest_count ?? 0;

const casePassRate    = execCases > 0 ? passedCases / execCases * 100 : 0;
const subtestPassRate = totalSubs > 0 ? passedSubs / totalSubs * 100 : 0;
const execReach       = totalCases > 0 ? execCases / totalCases * 100 : 0;
const overallPass     = totalCases > 0 ? passedCases / totalCases * 100 : 0;

// sort entries: passed first → failed → errors → timeouts → load errors → skipped
const pri: Record<string, number> = {
	passed: 0, failed: 1, process_error: 2, worker_crash: 2, process_timeout: 3,
	load_error: 4, skipped: 5, host_skip: 6,
};
const sorted = [...entries].sort((a: any, b: any) => {
	const pa = pri[effectiveStatus(a)] ?? 99, pb = pri[effectiveStatus(b)] ?? 99;
	return pa !== pb ? pa - pb : (a.module as string).localeCompare(b.module);
});

// top failure modules
const topMods = (derived?.top_modules_by_nonpass ?? []).slice(0, 8);
const maxGap  = topMods[0]?.count ?? 1;

// helpers (hoisted — used by computed data below)
const short = (m: string) => m.replace(/^test\./, "");

// case outcome breakdown
const failedCases  = caseOut.failed ?? 0;
const errorCases   = caseOut.error ?? 0;
const skippedCases = caseOut.skipped ?? 0;

// passing module names
const passingModules = sorted
	.filter((e: any) => effectiveStatus(e) === "passed")
	.map((e: any) => short(e.module));

// feature area categories
const catDefs: { label: string; patterns: string[] }[] = [
	{ label: "Async & Concurrency", patterns: ["test_asyncio", "test_asyncgen", "test_coroutines", "test_concurrent_futures", "test_thread", "test_threading", "test_threading_local", "test_threadedtempfile", "test_threadsignals", "test_queue", "test_sched", "test_free_threading", "test_context"] },
	{ label: "Networking & HTTP", patterns: ["test_socket", "test_ssl", "test_httplib", "test_httpservers", "test_urllib", "test_urllib2", "test_urlparse", "test_urllib_response", "test_ftplib", "test_imaplib", "test_smtplib", "test_poplib", "test_selectors", "test_select", "test_socketserver", "test_wsgiref", "test_xmlrpc", "test_ipaddress", "test_docxmlrpc", "test_timeout"] },
	{ label: "File System & OS", patterns: ["test_os", "test_pathlib", "test_posix", "test_posixpath", "test_stat", "test_shutil", "test_tempfile", "test_glob", "test_filecmp", "test_fileinput", "test_fileio", "test_file", "test_fileutils", "test_genericpath", "test_mmap", "test_io", "test_bufio", "test_signal", "test_fcntl", "test_linecache", "test_ntpath", "test_largefile"] },
	{ label: "Data Structures", patterns: ["test_list", "test_dict", "test_set", "test_tuple", "test_deque", "test_heapq", "test_bisect", "test_collections", "test_array", "test_bytes", "test_memoryview", "test_defaultdict", "test_ordered_dict", "test_weakref", "test_weakset", "test_buffer"] },
	{ label: "Strings & Encoding", patterns: ["test_str", "test_re", "test_string", "test_string_literals", "test_format", "test_textwrap", "test_difflib", "test_fnmatch", "test_codecs", "test_unicodedata", "test_fstring", "test_userstring", "test_shlex", "test_ucn", "test_stringprep"] },
	{ label: "Math & Numbers", patterns: ["test_int", "test_int_literal", "test_float", "test_complex", "test_decimal", "test_fractions", "test_math", "test_cmath", "test_statistics", "test_random", "test_long", "test_longexp", "test_abstract_numbers"] },
	{ label: "Data Formats", patterns: ["test_json", "test_pickle", "test_pickletools", "test_marshal", "test_struct", "test_csv", "test_configparser", "test_tomllib", "test_plistlib", "test_shelve", "test_dbm", "test_dbm_dumb", "test_dbm_ndbm", "test_dbm_sqlite3", "test_sqlite3"] },
	{ label: "XML & HTML", patterns: ["test_xml_etree", "test_xml_etree_c", "test_xml_dom_minicompat", "test_html", "test_htmlparser", "test_minidom", "test_sax", "test_pyexpat", "test_pulldom"] },
	{ label: "Type System & OOP", patterns: ["test_bool", "test_class", "test_descr", "test_descrtut", "test_metaclass", "test_super", "test_property", "test_abc", "test_enum", "test_dataclasses", "test_typing", "test_types", "test_typechecks", "test_type_aliases", "test_type_annotations", "test_type_params", "test_genericalias", "test_genericclass", "test_isinstance", "test_dynamicclassattribute", "test_subclassinit"] },
	{ label: "Functional & Iterators", patterns: ["test_functools", "test_itertools", "test_operator", "test_generators", "test_genexps", "test_iter", "test_enumerate", "test_listcomps", "test_dictcomps", "test_setcomps", "test_yield_from", "test_graphlib", "test_colorsys", "test_contextlib", "test_contextlib_async"] },
	{ label: "Compression & Archives", patterns: ["test_zlib", "test_gzip", "test_bz2", "test_lzma", "test_zipfile", "test_zipfile64", "test_tarfile", "test_zstd", "test_zipapp"] },
	{ label: "Subprocess & IPC", patterns: ["test_subprocess", "test_multiprocessing_fork", "test_multiprocessing_spawn", "test_multiprocessing_forkserver", "test_multiprocessing_main_handling", "test_popen", "test_pty", "test_fork1"] },
	{ label: "Date & Time", patterns: ["test_datetime", "test_time", "test_timeit", "test_strftime", "test_strptime", "test_calendar", "test_zoneinfo"] },
];
const matchesCat = (mod: string, patterns: string[]) =>
	patterns.some(p => mod === p || mod.startsWith(p + "."));
const catStats = catDefs.map(cat => {
	const mods = entries.filter((e: any) => matchesCat(short(e.module), cat.patterns));
	const passed = mods.filter((e: any) => effectiveStatus(e) === "passed");
	const invCases = mods.reduce((s: number, e: any) => s + (e.inventory_case_count ?? 0), 0);
	const testsRun = mods.reduce((s: number, e: any) => s + (e.tests_run ?? 0), 0);
	const reach = invCases > 0 ? testsRun / invCases * 100 : 0;
	return {
		label: cat.label,
		total: mods.length,
		passed: passed.length,
		reach,
		invCases,
		testsRun,
	};
}).sort((a, b) => b.reach - a.reach);
const catByVolume = [...catStats].sort((a, b) => b.invCases - a.invCases);
const maxCatVol = catByVolume[0]?.invCases ?? 1;

// meta
const hostOS   = summary?.host?.system === "Darwin" ? "macOS" : (summary?.host?.system ?? "");
const hostArch = summary?.host?.machine ?? "";
const pyVer    = summary?.host?.python ?? "";
const genDate  = derived?.generated_at_utc ?? "";

/* ── helpers ──────────────────────────────────────────────────── */
const fN = (n: number) => n.toLocaleString("en-US");
const fP = (n: number, d = 1) => n.toFixed(d) + "%";
const fD = (iso: string) => {
	if (!iso) return "";
	return new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
};
---

<SiteLayout
	title="CPython Test Suite — PYRS"
	description="Live results from running CPython 3.14's full test suite against PYRS."
>
{ok ? (
<div class="tests-page">

	<!-- ── HEADER ─────────────────────────────────────────── -->
	<section class="header">
		<span class="kicker">CPython 3.14 Test Suite</span>
		<h1 class="title">Compatibility, test&nbsp;by&nbsp;test.</h1>
		<p class="lead">
			We run every module in CPython's official test suite against PYRS.
			No cherry-picking — here's exactly where things stand.
		</p>
		<div class="meta-row">
			<span class="pill">{hostOS} {hostArch}</span>
			<span class="pill">Python {pyVer}</span>
			<span class="pill">{totalModules} modules</span>
			<span class="pill">Updated {fD(genDate)}</span>
		</div>
	</section>

	<!-- ── MODULE GRID ────────────────────────────────────── -->
	<section class="grid-section">
		<h2 class="sh">Every module at a glance</h2>
		<p class="sd">Each square is one of {totalModules} test modules. Color indicates outcome.</p>

		<div class="module-grid" id="module-grid">
			{sorted.map((e: any) => {
				const status = effectiveStatus(e);
				return (
					<div
						class={`gc st-${status}`}
						data-m={short(e.module)}
						data-s={status.replace(/_/g, " ")}
						data-t={e.tests_run ?? 0}
						aria-label={`${short(e.module)}: ${status.replace(/_/g, " ")}`}
					/>
				);
			})}
		</div>

		<div class="hover-info" id="hover-info">Hover a square to inspect</div>

		<div class="legend">
			<span class="li"><span class="ld st-passed" /><span>Passed ({passedModules})</span></span>
			<span class="li"><span class="ld st-failed" /><span>Failed ({failedModules})</span></span>
			<span class="li"><span class="ld st-process_error" /><span>Errored ({erroredModules})</span></span>
			<span class="li"><span class="ld st-process_timeout" /><span>Timed out ({timedOutModules})</span></span>
			<span class="li"><span class="ld st-load_error" /><span>Load error ({loadErrModules})</span></span>
			<span class="li"><span class="ld st-skipped" /><span>Skipped ({skippedModules})</span></span>
		</div>
	</section>

	<!-- ── KEY METRICS ────────────────────────────────────── -->
	<section class="metrics">
		<div class="mc">
			<span class="mv accent-value">{fN(passedCases)}</span>
			<span class="ml">test cases passing</span>
			<span class="mx">of {fN(execCases)} executed</span>
		</div>
		<div class="mc">
			<span class="mv">{fP(casePassRate)}</span>
			<span class="ml">case pass rate</span>
			<span class="mx">across executed tests</span>
		</div>
		<div class="mc">
			<span class="mv green-value">{fP(subtestPassRate)}</span>
			<span class="ml">subtest pass rate</span>
			<span class="mx">{fN(passedSubs)} of {fN(totalSubs)}</span>
		</div>
		<div class="mc">
			<span class="mv green-value">{passedModules}</span>
			<span class="ml">modules fully clean</span>
			<span class="mx">every test passing</span>
		</div>
	</section>

	<!-- ── EXECUTION PIPELINE ─────────────────────────────── -->
	<section class="pipeline">
		<h2 class="sh">From discovery to passing</h2>
		<p class="sd">How tests flow through PYRS — from the full suite to confirmed passes.</p>

		<div class="funnel">
			<div class="step">
				<div class="step-head">
					<span class="step-num">{fN(totalCases)}</span>
					<span class="step-lbl">discoverable test cases</span>
				</div>
				<div class="bar-track">
					<div class="bar-fill fill-disc" style="width:100%"></div>
				</div>
			</div>
			<div class="step">
				<div class="step-head">
					<span class="step-num">{fN(execCases)}</span>
					<span class="step-lbl">executed</span>
					<span class="step-pct">{fP(execReach)}</span>
				</div>
				<div class="bar-track">
					<div class="bar-fill fill-exec" style={`width:${execReach}%`}></div>
				</div>
			</div>
			<div class="step">
				<div class="step-head">
					<span class="step-num">{fN(passedCases)}</span>
					<span class="step-lbl">passed</span>
					<span class="step-pct">{fP(overallPass)}</span>
				</div>
				<div class="bar-track">
					<div class="bar-fill fill-pass" style={`width:${overallPass}%`}></div>
				</div>
			</div>
		</div>
	</section>

	<!-- ── CASE OUTCOMES ─────────────────────────────── -->
	<section class="outcomes">
		<h2 class="sh">How executed tests landed</h2>
		<p class="sd">{fN(execCases)} test cases ran — here's the breakdown.</p>

		<div class="seg-bar">
			<div class="seg seg-pass" style={`width:${passedCases / execCases * 100}%`} title={`Passed: ${fN(passedCases)}`} />
			<div class="seg seg-fail" style={`width:${failedCases / execCases * 100}%`} title={`Failed: ${fN(failedCases)}`} />
			<div class="seg seg-err" style={`width:${errorCases / execCases * 100}%`} title={`Error: ${fN(errorCases)}`} />
			<div class="seg seg-skip" style={`width:${skippedCases / execCases * 100}%`} title={`Skipped: ${fN(skippedCases)}`} />
		</div>

		<div class="seg-legend">
			<span class="seg-li"><span class="seg-dot seg-pass-bg" /><span>Passed <strong>{fN(passedCases)}</strong></span></span>
			<span class="seg-li"><span class="seg-dot seg-fail-bg" /><span>Failed <strong>{fN(failedCases)}</strong></span></span>
			<span class="seg-li"><span class="seg-dot seg-err-bg" /><span>Error <strong>{fN(errorCases)}</strong></span></span>
			<span class="seg-li"><span class="seg-dot seg-skip-bg" /><span>Skipped <strong>{fN(skippedCases)}</strong></span></span>
		</div>
	</section>

	<!-- ── STANDARD LIBRARY READINESS ────────────────────── -->
	<section class="readiness">
		<h2 class="sh">Standard library readiness</h2>
		<p class="sd">How major Python feature areas fare — reach shows how many discoverable tests PYRS can attempt.</p>

		<div class="cat-table">
			<div class="cat-header">
				<span class="cat-h-label">Category</span>
				<span class="cat-h-mods">Modules</span>
				<span class="cat-h-reach">Reach</span>
				<span class="cat-h-status">Status</span>
			</div>
			{catStats.map((c) => {
				const tag = c.passed === c.total && c.total > 0 ? "Solid"
					: c.passed > 0 ? "Partial"
					: c.reach > 20 ? "Early"
					: "Not yet";
				const tagClass = tag.toLowerCase().replace(" ", "-");
				return (
					<div class="cat-row">
						<span class="cat-label">{c.label}</span>
						<span class="cat-mods">{c.passed} of {c.total}</span>
						<div class="cat-reach">
							<div class="cat-track">
								<div class="cat-fill" style={`width:${Math.min(c.reach, 100)}%`}></div>
							</div>
							<span class="cat-pct">{fP(c.reach, 0)}</span>
						</div>
						<span class={`cat-tag cat-tag-${tagClass}`}>{tag}</span>
					</div>
				);
			})}
		</div>
	</section>

	<!-- ── TEST CONCENTRATION ────────────────────────────── -->
	<section class="depth">
		<h2 class="sh">Test concentration by area</h2>
		<p class="sd">Where CPython's {fN(totalCases)} discoverable test cases live — and how far PYRS reaches into each.</p>

		<div class="depth-list">
			{catByVolume.filter(c => c.invCases > 0).map((c) => (
				<div class="depth-row">
					<span class="depth-label">{c.label}</span>
					<div class="depth-bar">
						<div class="depth-track" style={`width:${(c.invCases / maxCatVol * 100)}%`}>
							<div class="depth-reached" style={`width:${Math.min(c.reach, 100)}%`}></div>
						</div>
					</div>
					<span class="depth-ct">{fN(c.invCases)}</span>
				</div>
			))}
		</div>

		<div class="depth-legend">
			<span class="depth-li"><span class="depth-ld depth-ld-exec" />Executed</span>
			<span class="depth-li"><span class="depth-ld depth-ld-total" />Discoverable</span>
		</div>
	</section>

	<!-- ── LARGEST GAPS ──────────────────────────────────── -->
	<section class="gaps">
		<h2 class="sh">Largest gaps by module</h2>
		<p class="sd">Modules with the most non-passing test cases.</p>

		<div class="gap-list">
			{topMods.map((m: any, i: number) => (
				<div class="gap-row">
					<span class="gap-rank">{i + 1}</span>
					<span class="gap-name">{short(m.name)}</span>
					<div class="gap-track">
						<div class="gap-fill" style={`width:${(m.count / maxGap * 100)}%`}></div>
					</div>
					<span class="gap-ct">{m.count}</span>
				</div>
			))}
		</div>
	</section>

	<!-- ── ALL PASSING MODULES ───────────────────────────── -->
	<section class="clean">
		<h2 class="sh">All passing modules</h2>
		<p class="sd">{passingModules.length} modules pass every single test — no failures, no errors.</p>

		<div class="clean-grid">
			{passingModules.map((m: string) => (
				<span class="clean-tag">{m}</span>
			))}
		</div>
	</section>

</div>
) : (
<div class="tests-page">
	<section class="header">
		<h1 class="title">Test Suite Results</h1>
		<p class="lead">Benchmark data not available. Run the benchmark to generate results.</p>
	</section>
</div>
)}
</SiteLayout>

<!-- ── STYLES ──────────────────────────────────────────────────── -->
<style>
	/* ── page ─────────────────────────────────── */
	.tests-page {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	/* ── header ───────────────────────────────── */
	.header {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		max-width: 700px;
	}
	.kicker {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		font-weight: 600;
	}
	.title {
		font-size: 2.6rem;
		font-weight: 700;
		line-height: 1.08;
		letter-spacing: -0.03em;
		margin: 0;
	}
	.lead {
		font-size: 1.05rem;
		color: var(--text-muted);
		line-height: 1.6;
		margin: 0.25rem 0 0;
	}
	.meta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 0.8rem;
	}
	.pill {
		font-size: 0.74rem;
		font-family: "IBM Plex Mono", ui-monospace, monospace;
		color: var(--text-muted);
		background: #201510;
		border: 1px solid #2e1f17;
		padding: 0.22rem 0.6rem;
		border-radius: 2rem;
	}

	/* ── grid section ─────────────────────────── */
	.grid-section {
		background: #110b08;
		border: 1px solid #2b1e15;
		border-radius: 0.75rem;
		padding: 2rem 2rem 1.6rem;
	}
	.sh {
		font-size: 1.25rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		margin: 0 0 0.2rem;
	}
	.sd {
		font-size: 0.9rem;
		color: var(--text-muted);
		margin: 0 0 1.4rem;
	}

	/* module grid */
	.module-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, 14px);
		gap: 3px;
		justify-content: center;
		padding: 0.5rem 0;
	}
	.gc {
		width: 14px;
		height: 14px;
		border-radius: 3px;
		cursor: pointer;
		transition: transform 120ms ease, box-shadow 120ms ease;
		position: relative;
	}
	.gc:hover {
		transform: scale(1.85);
		z-index: 2;
		box-shadow: 0 0 0 1.5px rgba(247, 238, 232, 0.45);
	}

	/* status colors */
	.st-passed          { background: #5ec97a; }
	.st-failed          { background: #e97d46; }
	.st-process_error   { background: #d94f4f; }
	.st-process_timeout { background: #d4a03a; }
	.st-load_error      { background: #7d6452; }
	.st-skipped,
	.st-host_skip       { background: #473d37; }
	.st-unknown         { background: #342c27; }
	.st-worker_crash    { background: #d94f4f; }

	/* hover info */
	.hover-info {
		text-align: center;
		font-size: 0.82rem;
		font-family: "IBM Plex Mono", ui-monospace, monospace;
		color: var(--text-muted);
		min-height: 1.6em;
		margin: 0.8rem 0 1rem;
		transition: color 100ms ease;
	}
	.hover-info.active {
		color: var(--text);
	}

	/* legend */
	.legend {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem 1.3rem;
		justify-content: center;
	}
	.li {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.8rem;
		color: var(--text-muted);
	}
	.ld {
		display: inline-block;
		width: 10px;
		height: 10px;
		border-radius: 2px;
		flex-shrink: 0;
	}

	/* ── metrics ──────────────────────────────── */
	.metrics {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
	}
	.mc {
		background: var(--bg-card);
		border: 1px solid var(--line);
		border-top: 2px solid #3a2414;
		border-radius: 0.6rem;
