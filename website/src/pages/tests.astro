<!-- ── CLIENT JS ──────────────────────────────────────────────── -->
<script>
	const grid = document.getElementById("module-grid");
	const info = document.getElementById("hover-info");
	if (grid && info) {
		const defaultText = "Hover a square to inspect";

		grid.addEventListener("mouseover", (e) => {
			const cell = (e.target as HTMLElement).closest(".gc") as HTMLElement | null;
			if (!cell) return;
			const m = cell.dataset.m ?? "";
			const s = cell.dataset.s ?? "";
			const t = cell.dataset.t ?? "0";
			info.innerHTML = `<strong>${m}</strong> &middot; ${s} &middot; ${t} tests run`;
			info.classList.add("active");
		});

		grid.addEventListener("mouseleave", () => {
			info.textContent = defaultText;
			info.classList.remove("active");
		});
	}

	/* ── count-up animation for metric values ── */
	const mvEls = document.querySelectorAll<HTMLElement>(".mv");
	const countUp = (el: HTMLElement) => {
		const raw = el.textContent?.trim() ?? "";
		const isPercent = raw.endsWith("%");
		const numStr = raw.replace(/[,%]/g, "");
		const target = parseFloat(numStr);
		if (isNaN(target)) return;
		const decimals = isPercent ? (raw.includes(".") ? raw.split(".")[1].replace("%", "").length : 0) : 0;
		const duration = 700;
		const start = performance.now();
		const fmt = (n: number) => {
			if (isPercent) return n.toFixed(decimals) + "%";
			return Math.round(n).toLocaleString("en-US");
		};
		el.textContent = fmt(0);
		const tick = (now: number) => {
			const t = Math.min((now - start) / duration, 1);
			const ease = 1 - Math.pow(1 - t, 3);
			el.textContent = fmt(target * ease);
			if (t < 1) requestAnimationFrame(tick);
		};
		requestAnimationFrame(tick);
	};
	const metricsObs = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				countUp(entry.target as HTMLElement);
				metricsObs.unobserve(entry.target);
			}
		});
	}, { threshold: 0.5 });
	mvEls.forEach(el => metricsObs.observe(el));
</script>
