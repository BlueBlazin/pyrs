---
import TopNav from "../components/TopNav.astro";
import SiteHead from "../components/SiteHead.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
	title: string;
	description: string;
	noindex?: boolean;
	navContext?: "home" | "docs" | "playground";
}

const { title, description, noindex = false, navContext = "home" } = Astro.props;
const copyScriptSrc = `${import.meta.env.BASE_URL}scripts/copy-buttons.js`;
---

<html lang="en">
	<head>
		<SiteHead title={title} description={description} url={Astro.url.toString()} noindex={noindex} />
	</head>
	<body>
		<div class="site-shell">
			<a class="skip-link" href="#main-content">Skip to content</a>
			<TopNav context={navContext} />
			<main class="home-main" id="main-content">
				<slot />
			</main>
			<Footer variant="home" />
		</div>
		<script is:inline src={copyScriptSrc}></script>
	</body>
</html>

<style>
	:root {
		--bg: #0f0907;
		--bg-card: #17100e;
		--line: #432d22;
		--text: #f7eee8;
		--text-muted: #beaa9f;
		--accent: #e97d46;
		--accent-2: #d89563;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: "Sora", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
		color: var(--text);
		background:
			radial-gradient(70rem 38rem at 88% -10%, rgba(233, 125, 70, 0.14), transparent),
			radial-gradient(68rem 36rem at -5% 10%, rgba(216, 149, 99, 0.09), transparent),
			linear-gradient(180deg, #090504 0%, var(--bg) 36%, #060404 100%);
	}

	.site-shell {
		width: min(1280px, calc(100vw - 2.8rem));
		margin: 0 auto;
		padding-bottom: 4rem;
	}

	.home-main {
		display: flex;
		flex-direction: column;
		gap: 2.25rem;
	}

	@media (max-width: 760px) {
		.site-shell {
			width: min(1160px, calc(100vw - 1.2rem));
		}
	}
</style>
