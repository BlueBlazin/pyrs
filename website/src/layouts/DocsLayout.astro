---
import TopNav from "../components/TopNav.astro";
import SiteHead from "../components/SiteHead.astro";
import DocsSidebar from "../components/docs/DocsSidebar.astro";
import DocsPageHeader from "../components/docs/DocsPageHeader.astro";
import "../styles/global.css";

interface Props {
	title: string;
	description: string;
	pageTitle: string;
}

const { title, description, pageTitle } = Astro.props;
const rawPath = Astro.url.pathname;
const path = rawPath.endsWith("/") ? rawPath : `${rawPath}/`;
---

<html lang="en">
	<head>
		<SiteHead title={title} description={description} />
	</head>
	<body>
		<div class="site-shell">
			<TopNav context="docs" />
			<main class="docs-shell">
				<DocsSidebar path={path} />
				<section class="docs-content">
					<DocsPageHeader title={pageTitle} description={description} />
					<slot />
				</section>
			</main>
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #090b11;
		--text: #f3f6fb;
		--text-muted: #a5aec0;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: "Space Grotesk", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
		color: var(--text);
		background:
			radial-gradient(74rem 36rem at 90% -8%, rgba(137, 149, 181, 0.08), transparent),
			radial-gradient(56rem 30rem at -6% 8%, rgba(81, 90, 110, 0.08), transparent),
			linear-gradient(180deg, #06070b 0%, var(--bg) 40%, #05060a 100%);
	}

	.site-shell {
		width: min(1280px, calc(100% - 2.8rem));
		margin: 0 auto;
		padding-bottom: 4rem;
	}

	.docs-shell {
		display: grid;
		grid-template-columns: 248px minmax(0, 1fr);
		gap: 1.45rem;
		align-items: start;
	}

	.docs-content {
		padding: 0.1rem 0 0.2rem;
		min-height: 72vh;
	}

	.docs-content h2 {
		margin: 1.3rem 0 0;
		font-size: 1.15rem;
	}

	.docs-content h2:first-of-type {
		margin-top: 0;
	}

	.docs-content p {
		color: var(--text-muted);
		line-height: 1.6;
		margin: 0.72rem 0 0;
	}

	.docs-content ul {
		margin: 0.72rem 0 0;
		padding-left: 1.15rem;
		color: var(--text-muted);
		line-height: 1.58;
	}

	.docs-content code {
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.86em;
		color: #d8def0;
	}

	@media (max-width: 760px) {
		.site-shell {
			width: min(1280px, calc(100% - 1.2rem));
		}

		.docs-shell {
			grid-template-columns: 1fr;
		}

		.docs-content {
			padding: 0.1rem 0 0.2rem;
		}
	}
</style>
