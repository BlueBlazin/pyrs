---
import TopNav from "../components/TopNav.astro";
import SiteHead from "../components/SiteHead.astro";
import Footer from "../components/Footer.astro";
import DocsSidebar from "../components/docs/DocsSidebar.astro";
import DocsPageHeader from "../components/docs/DocsPageHeader.astro";
import DocsPager from "../components/docs/DocsPager.astro";
import DocsToc from "../components/docs/DocsToc.astro";
import "../styles/global.css";

interface TocConfig {
	enabled?: boolean;
	minLevel?: number;
	maxLevel?: number;
	maxItems?: number;
	subheadings?: "all" | "active" | "none";
	include?: string[];
	exclude?: string[];
}

interface Props {
	title: string;
	description: string;
	pageTitle: string;
	frontmatter?: {
		title?: string;
		description?: string;
		pageTitle?: string;
		noindex?: boolean;
		toc?: TocConfig | boolean;
	};
	toc?: TocConfig | boolean;
	headings?: Array<{
		depth: number;
		slug?: string;
		text: string;
	}>;
}

const frontmatter = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? frontmatter.title ?? "PYRS Docs";
const description = Astro.props.description ?? frontmatter.description ?? "PYRS documentation.";
const pageTitle = Astro.props.pageTitle ?? frontmatter.pageTitle ?? "Docs";
const noindex = Astro.props.noindex ?? frontmatter.noindex ?? false;
const headings = Astro.props.headings ?? [];
const rawTocConfig = Astro.props.toc ?? frontmatter.toc ?? {};
const tocConfig: TocConfig = typeof rawTocConfig === "boolean" ? { enabled: rawTocConfig } : rawTocConfig;
const rawPath = Astro.url.pathname;
const path = rawPath.endsWith("/") ? rawPath : `${rawPath}/`;
const sourceFile = path === "/docs/" ? "docs/index.mdx" : `docs${path.slice("/docs".length, -1)}.mdx`;
const editUrl = `https://github.com/BlueBlazin/pyrs/edit/master/website/src/pages/${sourceFile}`;
---

<html lang="en">
	<head>
		<SiteHead title={title} description={description} url={Astro.url.toString()} noindex={noindex} />
	</head>
	<body>
		<div class="site-shell">
			<a class="skip-link" href="#main-content">Skip to content</a>
			<TopNav context="docs" />
			<main class="docs-shell">
				<DocsSidebar path={path} />
				<section class="docs-content" id="main-content">
					<DocsPageHeader title={pageTitle} description={description} editUrl={editUrl} />
					<slot />
					<DocsPager path={path} />
				</section>
				<DocsToc headings={headings} config={tocConfig} />
			</main>
			<Footer variant="docs" />
		</div>
		<script is:inline src="/scripts/copy-buttons.js"></script>
	</body>
</html>

<style>
	:root {
		--bg: #090b11;
		--text: #f3f6fb;
		--text-muted: #a5aec0;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: "Space Grotesk", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
		color: var(--text);
		background:
			radial-gradient(74rem 36rem at 90% -8%, rgba(137, 149, 181, 0.08), transparent),
			radial-gradient(56rem 30rem at -6% 8%, rgba(81, 90, 110, 0.08), transparent),
			linear-gradient(180deg, #06070b 0%, var(--bg) 40%, #05060a 100%);
	}

	.site-shell {
		width: min(1280px, calc(100% - 2.8rem));
		margin: 0 auto;
		padding-bottom: 4rem;
	}

	.docs-shell {
		display: grid;
		grid-template-columns: 258px minmax(0, 1fr) 236px;
		gap: 1.6rem;
		align-items: start;
	}

	.docs-content {
		padding: 0.25rem 0 0.2rem;
		min-height: 72vh;
		max-width: 860px;
	}

	@media (max-width: 1080px) {
		.docs-shell {
			grid-template-columns: 250px minmax(0, 1fr);
			gap: 1.2rem;
		}

		.docs-content {
			max-width: none;
		}
	}

	@media (max-width: 760px) {
		.site-shell {
			width: min(1280px, calc(100% - 1.2rem));
		}

		.docs-shell {
			grid-template-columns: 1fr;
		}

		.docs-content {
			padding: 0.1rem 0 0.2rem;
		}
	}
</style>
