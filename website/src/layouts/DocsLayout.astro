---
interface Props {
	title: string;
	description: string;
	pageTitle: string;
}

const { title, description, pageTitle } = Astro.props;
const rawPath = Astro.url.pathname;
const path = rawPath.endsWith("/") ? rawPath : `${rawPath}/`;
const navGroups = [
	{
		label: "Start",
		items: [
			{ href: "/docs/", label: "Getting Started" },
			{ href: "/docs/install/", label: "Installation" },
		],
	},
	{
		label: "Reference",
		items: [{ href: "/docs/reference/", label: "CLI and Environment" }],
	},
];
const isActive = (href: string) => {
	if (href === "/docs/") {
		return path === "/docs/";
	}
	return path.startsWith(href);
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="64x64" href="/images/logo/logo-64.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="site-shell">
			<header class="topbar">
				<a class="brand" href="/">
					<img src="/images/logo/logo-64.png" alt="PYRS logo" width="36" height="36" />
					<span>PYRS</span>
				</a>
				<nav class="topnav">
					<a href="https://github.com/BlueBlazin/pyrs">GitHub</a>
					<a href="/docs/">Docs</a>
				</nav>
			</header>
			<main class="docs-shell">
				<aside class="docs-sidebar">
					<div class="sidebar-inner">
						<div class="sidebar-title">Documentation</div>
						{navGroups.map((group) => (
							<section class="nav-group">
								<p class="group-label">{group.label}</p>
								<nav class="group-links">
									{group.items.map((item) => (
										<a href={item.href} class={isActive(item.href) ? "active" : ""}>{item.label}</a>
									))}
								</nav>
							</section>
						))}
					</div>
				</aside>
				<section class="docs-content">
					<header class="content-head">
						<h1>{pageTitle}</h1>
					</header>
					<slot />
				</section>
			</main>
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #0f0907;
		--bg-card: #17100e;
		--line: #432d22;
		--text: #f7eee8;
		--text-muted: #beaa9f;
		--accent: #e97d46;
		--accent-2: #d89563;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: "Space Grotesk", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
		color: var(--text);
		background:
			radial-gradient(62rem 34rem at 84% -10%, rgba(233, 125, 70, 0.12), transparent),
			radial-gradient(54rem 30rem at -4% 8%, rgba(216, 149, 99, 0.08), transparent),
			linear-gradient(180deg, #090504 0%, var(--bg) 38%, #060404 100%);
	}

	.site-shell {
		width: min(1280px, calc(100% - 2.8rem));
		margin: 0 auto;
		padding-bottom: 4rem;
	}

	.topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.4rem 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.68rem;
		text-decoration: none;
		color: var(--text);
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.brand img {
		border-radius: 0.52rem;
		border: 1px solid rgba(255, 255, 255, 0.14);
	}

	.topnav {
		display: inline-flex;
		gap: 0.95rem;
	}

	.topnav a {
		text-decoration: none;
		font-size: 0.92rem;
		color: var(--text-muted);
		transition: color 130ms ease;
	}

	.topnav a:hover {
		color: var(--text);
	}

	.docs-shell {
		display: grid;
		grid-template-columns: 262px minmax(0, 1fr);
		gap: 1.2rem;
		align-items: start;
	}

	.docs-sidebar {
		position: sticky;
		top: 1rem;
	}

	.sidebar-inner {
		border: 1px solid var(--line);
		border-radius: 0.95rem;
		background: rgba(16, 10, 8, 0.86);
		padding: 0.86rem 0.78rem 0.9rem;
	}

	.sidebar-title {
		font-size: 0.86rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--text);
		margin-bottom: 0.85rem;
	}

	.nav-group + .nav-group {
		margin-top: 0.8rem;
	}

	.group-label {
		margin: 0 0 0.42rem;
		font-size: 0.69rem;
		letter-spacing: 0.09em;
		text-transform: uppercase;
		color: var(--accent-2);
		font-weight: 600;
	}

	.group-links {
		display: flex;
		flex-direction: column;
		gap: 0.22rem;
	}

	.group-links a {
		text-decoration: none;
		font-size: 0.88rem;
		color: var(--text-muted);
		padding: 0.35rem 0.5rem;
		border-radius: 0.55rem;
		transition: color 120ms ease, background-color 120ms ease;
	}

	.group-links a:hover {
		color: var(--text);
		background: rgba(255, 255, 255, 0.05);
	}

	.group-links a.active {
		color: #241108;
		background: linear-gradient(135deg, #d99667 0%, #c66e43 100%);
		border: 1px solid rgba(198, 110, 67, 0.48);
	}

	.docs-content {
		border: 1px solid var(--line);
		border-radius: 0.95rem;
		background: rgba(15, 10, 8, 0.82);
		padding: 1.06rem 1.12rem 1.2rem;
		min-height: 72vh;
	}

	.content-head {
		padding-bottom: 0.74rem;
		border-bottom: 1px solid rgba(67, 45, 34, 0.7);
		margin-bottom: 1rem;
	}

	.content-head h1 {
		margin: 0;
		font-size: clamp(1.4rem, 3vw, 2.05rem);
		line-height: 1.15;
		letter-spacing: -0.01em;
	}

	.docs-content h2 {
		margin: 1.3rem 0 0;
		font-size: 1.2rem;
	}

	.docs-content h2:first-of-type {
		margin-top: 0;
	}

	.docs-content p {
		color: var(--text-muted);
		line-height: 1.6;
		margin: 0.72rem 0 0;
	}

	.docs-content ul {
		margin: 0.72rem 0 0;
		padding-left: 1.15rem;
		color: var(--text-muted);
		line-height: 1.58;
	}

	.docs-content code {
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.86em;
		color: #f0ddcf;
	}

	.docs-content pre {
		margin: 0.78rem 0 0;
		overflow-x: auto;
		padding: 0.82rem 0.9rem;
		border-radius: 0.75rem;
		border: 1px solid #3d281d;
		background: #080605;
		color: #ecd9cd;
		font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.8rem;
		line-height: 1.56;
	}

	table {
		width: 100%;
		border-collapse: collapse;
	}

	th,
	td {
		padding: 0.62rem 0.62rem;
		text-align: left;
		vertical-align: top;
		font-size: 0.87rem;
		line-height: 1.5;
	}

	th {
		color: #f4e6dc;
		font-weight: 600;
		border-bottom: 1px solid #483125;
		background: rgba(8, 6, 5, 0.52);
	}

	td {
		color: var(--text-muted);
		border-bottom: 1px solid rgba(72, 49, 37, 0.45);
	}

	tr:last-child td {
		border-bottom: none;
	}

	.table-wrap {
		margin-top: 0.8rem;
		overflow-x: auto;
	}

	@media (max-width: 760px) {
		.site-shell {
			width: min(1280px, calc(100% - 1.2rem));
		}

		.topbar {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.6rem;
		}

		.docs-shell {
			grid-template-columns: 1fr;
		}

		.docs-sidebar {
			position: static;
		}

		.docs-content {
			padding: 0.95rem 0.88rem 1rem;
		}
	}
</style>
